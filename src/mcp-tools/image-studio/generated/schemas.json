        },
        "name": {
          "type": "string",
          "description": "Name for the copy (defaults to \"Copy of {original name}\")"
        }
      },
      "required": ["image_id"]
    }
  },
  "img_edit": {
    "schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Text prompt describing the desired modifications"
        },
        "image_url": {
          "type": "string",
          "description": "URL of an external image to modify"
        },
        "image_base64": {
          "type": "string",
          "description": "Base64-encoded image data to modify"
        },
        "source_image_id": {
          "type": "string",
          "description": "Library image ID to use as source"
        },
        "mime_type": {
          "type": "string",
          "description": "MIME type of the image (e.g. image/jpeg). Defaults to image/jpeg"
        },
        "tier": {
          "type": "string",
          "description": "Enhancement tier — higher tiers produce better quality",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        },
        "model_preference": {
          "type": "string",
          "description": "Model preference: default, quality, speed, or latest",
          "enum": ["default", "quality", "speed", "latest"]
        }
      }
    }
  },
  "img_enhance": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "Image ID to enhance (single mode)"
        },
        "image_ids": {
          "type": "array",
          "description": "Image IDs to enhance (batch mode)",
          "items": {
            "type": "string",
            "description": "Image ID"
          }
        },
        "tier": {
          "type": "string",
          "description": "Enhancement tier — higher tiers produce better quality. Defaults to TIER_1K",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        },
        "preview": {
          "type": "boolean",
          "description": "If true, returns cost estimate without starting jobs"
        }
      }
    }
  },
  "img_export": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "ID of the image to export"
        },
        "format": {
          "type": "string",
          "description": "Output format: jpeg, png, webp, or pdf",
          "enum": ["png", "jpg", "webp"]
        },
        "quality": {
          "type": "number",
          "description": "Quality level 1-100 (for lossy formats)"
        }
      },
      "required": ["image_id"]
    }
  },
  "img_generate": {
    "schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Text prompt for image generation"
        },
        "negative_prompt": {
          "type": "string",
          "description": "What to avoid in the generated image"
        },
        "aspect_ratio": {
          "type": "string",
          "description": "Aspect ratio (default 1:1)",
          "enum": [
            "1:1",
            "3:2",
            "2:3",
            "3:4",
            "4:3",
            "4:5",
            "5:4",
            "9:16",
            "16:9",
            "21:9",
            "1:4",
            "1:8",
            "4:1",
            "8:1"
          ]
        },
        "tier": {
          "type": "string",
          "description": "Quality tier — higher tiers cost more credits",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        },
        "model_preference": {
          "type": "string",
          "description": "Model routing hint: default, quality, speed, latest",
          "enum": ["default", "quality", "speed", "latest"]
        },
        "resolution": {
          "type": "string",
          "description": "Output resolution (advanced)",
          "enum": ["0.5K", "512", "1K", "2K", "4K"]
        },
        "thinking_mode": {
          "type": "boolean",
          "description": "Enable thinking mode for better prompt interpretation"
        },
        "google_search_grounding": {
          "type": "boolean",
          "description": "Ground generation in current web knowledge"
        },
        "text_to_render": {
          "type": "string",
          "description": "Text to render inside the image"
        },
        "subject_refs": {
          "type": "array",
          "description": "Subject labels or IDs to include",
          "items": {
            "type": "string",
            "description": "Subject ID or label"
          }
        },
        "reference_images": {
          "type": "array",
          "description": "Reference images for style/subject transfer",
          "items": {
            "type": "object",
            "description": "Reference Image",
            "properties": {
              "url": {
                "type": "string",
                "description": "External URL of reference image"
              },
              "image_id": {
                "type": "string",
                "description": "ID of a user-owned image to use as reference"
              },
              "role": {
                "type": "string",
                "description": "Role: style, subject, composition, color",
                "enum": ["style", "subject", "composition"]
              }
            }
          }
        },
        "seed": {
          "type": "number",
          "description": "Random seed for reproducibility"
        },
        "output_format": {
          "type": "string",
          "description": "Output format: png, jpeg, webp",
          "enum": ["png", "jpeg", "webp"]
        },
        "num_images": {
          "type": "number",
          "description": "Number of images to generate (1-4)",
          "minimum": 1,
          "maximum": 4
        }
      }
    }
  },
  "img_history": {
    "schema": {

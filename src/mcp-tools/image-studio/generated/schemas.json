{
  "img_album_create": {
    "schema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the album"
        },
        "description": {
          "type": "string",
          "description": "Description for the album"
        },
        "privacy": {
          "type": "string",
          "description": "Privacy setting: PRIVATE, UNLISTED, or PUBLIC",
          "enum": ["PRIVATE", "UNLISTED", "PUBLIC"]
        },
        "default_tier": {
          "type": "string",
          "description": "Default enhancement tier for images in this album",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        }
      },
      "required": ["name", "privacy", "default_tier"]
    }
  },
  "img_album_delete": {
    "schema": {
      "type": "object",
      "properties": {
        "album_handle": {
          "type": "string",
          "description": "Handle of the album to delete"
        },
        "confirm": {
          "type": "boolean",
          "description": "Must be true to confirm permanent deletion"
        }
      },
      "required": ["album_handle", "confirm"]
    }
  },
  "img_album_images": {
    "schema": {
      "type": "object",
      "properties": {
        "album_handle": {
          "type": "string",
          "description": "Handle of the album to modify"
        },
        "action": {
          "type": "string",
          "description": "Action to perform: add or remove images",
          "enum": ["add", "remove"]
        },
        "image_ids": {
          "type": "array",
          "description": "Image IDs to add to or remove from the album",
          "items": {
            "type": "string",
            "description": "Image ID in the array"
          }
        }
      },
      "required": ["album_handle", "action", "image_ids"]
    }
  },
  "img_album_list": {
    "schema": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "number",
          "description": "Maximum number of albums to return (max 100)",
          "maximum": 100
        }
      }
    }
  },
  "img_album_reorder": {
    "schema": {
      "type": "object",
      "properties": {
        "album_handle": {
          "type": "string",
          "description": "Album handle"
        },
        "image_ids": {
          "type": "array",
          "description": "Image IDs in desired order",
          "items": {
            "type": "string",
            "description": "Image ID in the array"
          }
        }
      },
      "required": ["album_handle", "image_ids"]
    }
  },
  "img_album_update": {
    "schema": {
      "type": "object",
      "properties": {
        "album_handle": {
          "type": "string",
          "description": "Handle of the album to update"
        },
        "name": {
          "type": "string",
          "description": "New name for the album"
        },
        "description": {
          "type": "string",
          "description": "New description for the album"
        },
        "privacy": {
          "type": "string",
          "description": "New privacy setting: PRIVATE, UNLISTED, or PUBLIC",
          "enum": ["PRIVATE", "UNLISTED", "PUBLIC"]
        },
        "cover_image_id": {
          "type": "string",
          "description": "Image ID to use as the album cover"
        },
        "pipeline_id": {
          "type": "string",
          "description": "Pipeline ID to apply to this album"
        },
        "default_tier": {
          "type": "string",
          "description": "Default enhancement tier for images in this album",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        }
      },
      "required": ["album_handle"]
    }
  },
  "img_album": {
    "schema": {
      "type": "object",
      "properties": {
        "album_handle": {
          "type": "string",
          "description": "Handle of the album to retrieve"
        },
        "include_images": {
          "type": "boolean",
          "description": "If true, include all images in the album"
        }
      },
      "required": ["album_handle"]
    }
  },
  "img_analyze": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "ID of the image to analyze"
        },
        "detail_level": {
          "type": "string",
          "description": "Level of detail: brief, detailed, or alt_text",
          "enum": ["brief", "detailed", "alt_text"]
        },
        "include_palette": {
          "type": "boolean",
          "description": "If true, extract dominant color palette"
        }
      },
      "required": ["image_id"]
    }
  },
  "img_auto_tag": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "Image ID to auto-tag"
        },
        "overwrite": {
          "type": "boolean",
          "description": "If true, replace existing tags/description. If false (default), merge with existing"
        }
      },
      "required": ["image_id"]
    }
  },
  "img_avatar": {
    "schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Description of the desired avatar"
        },
        "style": {
          "type": "string",
          "description": "Avatar style: photo, cartoon, abstract, or pixel",
          "enum": ["photo", "cartoon", "abstract", "pixel"]
        },
        "tier": {
          "type": "string",
          "description": "Enhancement tier for generation quality",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        }
      },
      "required": ["prompt"]
    }
  },
  "img_banner": {
    "schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Description of the desired banner"
        },
        "preset": {
          "type": "string",
          "description": "Platform preset: github_readme, twitter_header, youtube_thumbnail, linkedin_cover, og, or custom",
          "enum": [
            "github_readme",
            "twitter_header",
            "youtube_thumbnail",
            "linkedin_cover",
            "og",
            "custom"
          ]
        },
        "custom_aspect_ratio": {
          "type": "string",
          "description": "Custom aspect ratio (only used with preset=custom)"
        },
        "tier": {
          "type": "string",
          "description": "Enhancement tier for generation quality",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        },
        "title": {
          "type": "string",
          "description": "Title text to overlay on the banner"
        },
        "subtitle": {
          "type": "string",
          "description": "Subtitle text to overlay on the banner"
        }
      },
      "required": ["prompt", "preset"]
    }
  },
  "img_blend": {
    "schema": {
      "type": "object",
      "properties": {
        "source_image_id": {
          "type": "string",
          "description": "Base image ID"
        },
        "target_image_id": {
          "type": "string",
          "description": "Image ID to blend on top"
        },
        "blend_mode": {
          "type": "string",
          "description": "Blend mode: overlay, multiply, screen, or dissolve",

  "img_delete": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "ID of the image to delete"
        },
        "confirm": {
          "type": "boolean",
          "description": "Must be true to confirm permanent deletion"
        }
      },

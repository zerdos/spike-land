          "description": "Maximum number of subjects to return. Defaults to 20",
          "maximum": 100
        }
      }
    }
  },
  "img_subject_save": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "Source image ID containing the subject"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for the subject (e.g. 'my cat')"
        },
        "type": {
          "type": "string",
          "description": "Subject type: character or object",
          "enum": ["character", "object"]
        },
        "description": {
          "type": "string",
          "description": "Optional description for more accurate references"
        }
      },
      "required": ["image_id", "label"]
    }
  },
  "img_update": {
    "schema": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "string",
          "description": "ID of the image to update"
        },
        "name": {
          "type": "string",
          "description": "New name for the image"
        },
        "description": {
          "type": "string",
          "description": "New description for the image"
        },
        "tags": {
          "type": "array",
          "description": "New tags array for the image",
          "items": {
            "type": "string",
            "description": "Tag item"
          }
        }
      },
      "required": ["image_id"]
    }
  },
  "img_upload": {
    "schema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name for the image in the library"
        },
        "description": {
          "type": "string",
          "description": "Description for the uploaded image"
        },
        "tags": {
          "type": "array",

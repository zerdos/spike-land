        },
        "blend_strength": {
          "type": "number",
          "description": "Blend strength from 0-100. Defaults to 50"
        },
        "tier": {
          "type": "string",
          "description": "Enhancement tier for output quality",
          "enum": ["FREE", "TIER_0_5K", "TIER_1K", "TIER_2K", "TIER_4K"]
        }
      },
      "required": ["source_image_id", "target_image_id"]
    }
  },
  "img_bulk_delete": {
    "schema": {
      "type": "object",
      "properties": {
        "image_ids": {
          "type": "array",
          "description": "IDs of images to delete",
          "items": {
            "type": "string",
            "description": "Image ID"
          }
        },
        "confirm": {
          "type": "boolean",
          "description": "Must be true to confirm permanent deletion"
        }
      },
      "required": ["image_ids", "confirm"]
    }
  },
  "img_compare": {
    "schema": {
      "type": "object",
      "properties": {
        "image1_id": {
          "type": "string",
          "description": "First image ID (from library)"
        },
        "image2_id": {
          "type": "string",
          "description": "Second image ID (from library)"
        },
        "image1_url": {
          "type": "string",
          "description": "First image URL (external)"
        },
        "image2_url": {
          "type": "string",
          "description": "Second image URL (external)"
        }
      }
    }
  },
  "img_credits": {
    "schema": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "monaco-editor": ["../../monaco-editor/src/index.ts"],
      "monaco-editor/*": ["../../monaco-editor/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", "../../global-typings.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-vite",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}

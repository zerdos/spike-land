{
  "name": "@compass/privacy",
  "version": "0.1.0",
  "description": "E2E encryption, consent management, audit logging, and data deletion for COMPASS sensitive data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./core-logic/encryption": {
      "types": "./dist/core-logic/encryption.d.ts",
      "import": "./dist/core-logic/encryption.js"
    },
    "./core-logic/consent-manager": {
      "types": "./dist/core-logic/consent-manager.d.ts",
      "import": "./dist/core-logic/consent-manager.js"
    },
    "./core-logic/audit-log": {
      "types": "./dist/core-logic/audit-log.d.ts",
      "import": "./dist/core-logic/audit-log.js"
    },
    "./core-logic/data-deletion": {
      "types": "./dist/core-logic/data-deletion.d.ts",
      "import": "./dist/core-logic/data-deletion.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}

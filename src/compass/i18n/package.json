{
  "name": "@compass/i18n",
  "version": "0.1.0",
  "description": "COMPASS Localization Framework — radically patient in 50+ languages",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./core-logic/translator": {
      "import": "./dist/core-logic/translator.js",
      "types": "./dist/core-logic/translator.d.ts"
    },
    "./core-logic/locale-registry": {
      "import": "./dist/core-logic/locale-registry.js",
      "types": "./dist/core-logic/locale-registry.d.ts"
    },
    "./core-logic/cultural-adapter": {
      "import": "./dist/core-logic/cultural-adapter.js",
      "types": "./dist/core-logic/cultural-adapter.d.ts"
    },
    "./locales/en": {
      "import": "./dist/locales/en.js",
      "types": "./dist/locales/en.d.ts"
    },
    "./locales/de": {
      "import": "./dist/locales/de.js",
      "types": "./dist/locales/de.d.ts"
    },
    "./locales/hi": {
      "import": "./dist/locales/hi.js",
      "types": "./dist/locales/hi.d.ts"
    },
    "./locales/sw": {
      "import": "./dist/locales/sw.js",
      "types": "./dist/locales/sw.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}

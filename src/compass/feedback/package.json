{
  "name": "@compass/feedback",
  "version": "0.1.0",
  "description": "Differential-privacy feedback analytics for systemic intelligence — anonymized outcome tracking with zero individual data exposure",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./core-logic/outcome-tracker": {
      "types": "./dist/core-logic/outcome-tracker.d.ts",
      "import": "./dist/core-logic/outcome-tracker.js"
    },
    "./core-logic/differential-privacy": {
      "types": "./dist/core-logic/differential-privacy.d.ts",
      "import": "./dist/core-logic/differential-privacy.js"
    },
    "./core-logic/systemic-intelligence": {
      "types": "./dist/core-logic/systemic-intelligence.d.ts",
      "import": "./dist/core-logic/systemic-intelligence.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}

{
  "name": "@compass/eligibility-engine",
  "version": "0.1.0",
  "description": "Deterministic rules engine that matches user profiles to government programs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./core-logic/rules-engine": {
      "types": "./dist/core-logic/rules-engine.d.ts",
      "import": "./dist/core-logic/rules-engine.js"
    },
    "./core-logic/profile-builder": {
      "types": "./dist/core-logic/profile-builder.d.ts",
      "import": "./dist/core-logic/profile-builder.js"
    },
    "./core-logic/ranking": {
      "types": "./dist/core-logic/ranking.d.ts",
      "import": "./dist/core-logic/ranking.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}

{
  "name": "@compass/data-seeds",
  "version": "0.1.0",
  "description": "Realistic seed data for COMPASS flagship countries: Germany, India, United States, Kenya",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./core-logic/seed-loader": {
      "types": "./dist/core-logic/seed-loader.d.ts",
      "import": "./dist/core-logic/seed-loader.js"
    },
    "./seeds/germany": {
      "types": "./dist/seeds/germany.d.ts",
      "import": "./dist/seeds/germany.js"
    },
    "./seeds/india": {
      "types": "./dist/seeds/india.d.ts",
      "import": "./dist/seeds/india.js"
    },
    "./seeds/united-states": {
      "types": "./dist/seeds/united-states.d.ts",
      "import": "./dist/seeds/united-states.js"
    },
    "./seeds/kenya": {
      "types": "./dist/seeds/kenya.d.ts",
      "import": "./dist/seeds/kenya.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}

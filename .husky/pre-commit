#!/bin/sh
# Secret detection — block if gitleaks is missing or finds secrets
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --verbose
else
  echo "ERROR: gitleaks not installed — install with: brew install gitleaks"
  echo "Falling back to built-in secret scanner..."
  bash scripts/scan-secrets.sh --staged
fi

# Format staged files with Biome
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.json')
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs npx biome format --write 2>/dev/null
  echo "$STAGED" | xargs git add
fi

# Typecheck staged TS files
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx')
if [ -n "$STAGED_TS" ]; then
  npx tsc --noEmit --incremental
fi

# Reorganize lint — check for category violations in src/
if [ -n "$STAGED_TS" ]; then
  npx tsx scripts/reorganize.ts --lint --src src --incremental
fi

    "@remotion/player": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "@remotion/studio": "^4.0.448",
    "@remotion/studio-server": "^4.0.448",
    "@remotion/studio-shared": "^4.0.448",
    "dotenv": "^17.4.2",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2",
    "remotion": "4.0.435"
  },
  "peerDependencies": {
    "react": ">=16.8.0",

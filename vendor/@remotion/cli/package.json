        "dist/config/index.d.ts"
      ]
    }
  },
  "author": "Jonny Burger <jonny@remotion.dev>",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@remotion/bundler": "^4.0.448",

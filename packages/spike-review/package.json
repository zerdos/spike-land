{
  "name": "@spike-land-ai/spike-review",
  "version": "0.1.1",
  "description": "Spike Review — branded AI code review bot with BAZDMEG quality gates",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "start": "node dist/cli.js",
    "deploy": "npx wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@octokit/rest": "22.0.1",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "source": "./index.ts"
}

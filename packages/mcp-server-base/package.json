{
  "name": "@spike-land-ai/mcp-server-base",
  "version": "0.1.0",
  "description": "Shared base utilities for @spike-land-ai MCP server packages",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/spike-land-ai.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean",
    "dev": "tsup index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet ."
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "spike-land",
    "base",
    "utilities"
  ],
  "license": "MIT",
  "source": "./index.ts"
}

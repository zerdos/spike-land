{
  "name": "@spike-land-ai/mcp-server-base",
  "version": "0.1.0",
  "description": "Shared base utilities for @spike-land-ai MCP server packages",
  "type": "module",
  "main": "./dist/packages/mcp-server-base/index.js",
  "module": "./dist/packages/mcp-server-base/index.js",
  "types": "./dist/packages/mcp-server-base/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/mcp-server-base/index.d.ts",
      "import": "./dist/packages/mcp-server-base/index.js",
      "default": "./dist/packages/mcp-server-base/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/spike-land-ai.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet ."
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "zod": "4.3.6"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "spike-land",
    "base",
    "utilities"
  ],
  "license": "MIT",
  "source": "./index.ts"
}

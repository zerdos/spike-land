{
  "name": "spike-land",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "content:sync": "[ -L docs ] || cp -r ../../docs ./docs 2>/dev/null; [ -L content ] || cp -r ../../content ./content 2>/dev/null; true",
    "predev": "yarn content:sync && tsx src/lib/docs/generate-docs-data.ts",
    "dev": "next dev",
    "build": "yarn db:generate && yarn content:sync && yarn docs:generate && next build",
    "docs:generate": "tsx src/lib/docs/generate-docs-data.ts && cp -r src/lib/docs/generated/ public/docs-data/",
    "start": "next start",
    "start:standalone": "cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && node -r dotenv/config .next/standalone/server.js dotenv_config_path=.env.local",
    "lint": "eslint --cache --cache-location .eslintcache",
    "typecheck-disabled": "tsc --noEmit",
    "typecheck:prod": "tsc --project tsconfig.build.json --noEmit",
    "test-disabled": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest run --changed $(yarn find-last-passing-ci test)",
    "test:run": "vitest run",
    "test:cached": "VITEST_COVERAGE=true CI=true vitest run --coverage",
    "test:cache:check": "tsx scripts/test-cache-manager.ts should-skip-all",
    "test:cache:stats": "tsx scripts/test-cache-manager.ts stats",
    "test:cache:list": "tsx scripts/test-cache-manager.ts list-tests-to-run",
    "review": "./scripts/get-review-url.sh",
    "postinstall": "prisma generate --no-hints",
    "prisma": "prisma",
    "db:generate": "yarn prisma generate --no-hints",
    "promote:prod": "gh workflow run deploy.yml -f target_environment=production",
    "db:migrate": "yarn prisma migrate dev",
    "db:migrate:ci": "tsx scripts/db-migrate-ci.ts",
    "db:migrate:deploy": "yarn prisma migrate deploy",
    "db:migrate:reset": "yarn prisma migrate reset",
    "db:push": "yarn prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "yarn prisma studio",
    "env:check": "tsx scripts/env-check.ts",
    "generate:apple-secret": "tsx scripts/generate-apple-secret.ts",
    "agent:poll": "tsx scripts/agent-poll.ts",
    "agent:poll:prod": "tsx scripts/agent-poll.ts --prod",
    "agent:poll:once": "tsx scripts/agent-poll.ts --once",
    "agent:poll:once:prod": "tsx scripts/agent-poll.ts --once --prod",
    "agent:poll:stats": "tsx scripts/agent-poll.ts --stats",
    "agent:poll:debug": "tsx scripts/agent-poll.ts --debug",
    "agent:poll:debug:prod": "tsx scripts/agent-poll.ts --prod --debug",
    "agent:test-auth": "tsx scripts/test-agent-auth.ts",
    "agent:test-auth:prod": "tsx scripts/test-agent-auth.ts --prod",
    "db:validate": "yarn prisma validate",
    "db:format": "yarn prisma format",
    "prepare": "husky",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "check:skips": "bash scripts/check-undocumented-skips.sh",
    "dead-code": "knip",
    "dead-code:files": "knip --include files",
    "dead-code:exports": "knip --include exports",
    "dead-code:deps": "knip --include dependencies",
    "find-last-passing-ci": "./scripts/find-last-passing-ci.sh",
    "reset:db": "tsx scripts/reset-staging-db.ts",
    "reset:db:confirm": "tsx scripts/reset-staging-db.ts --confirm",
    "backup": "tsx --tsconfig scripts/backup/tsconfig.json scripts/backup/backup.ts",
    "depot:ci": "depot build . --target=ci --progress=plain",
    "docker:ci": "docker compose --profile ci up --build",
    "depot:build": "depot build . --target=build --progress=plain",
    "docker:build": "docker compose --profile full-stack up --build",
    "depot:lint": "depot build . --target=lint --progress=plain",
    "depot:tests": "depot build . --target=unit-tests --progress=plain",
    "docker:tests": "docker build . --target=unit-tests --progress=plain",
    "start:dev": "node scripts/start-dev.mjs",
    "dev:logs": "cat .dev-logs/dev-server.log 2>/dev/null || echo 'No dev logs found. Start with: yarn start:dev'",
    "dev:logs:tail": "tail -f .dev-logs/dev-server.log",
    "dev:logs:clear": "rm -rf .dev-logs && echo 'Dev logs cleared'",
    "start:dev:guard": "FILE_GUARD=1 node scripts/start-dev.mjs",
    "smoke:local": "bash scripts/smoke-test-local.sh"
  },

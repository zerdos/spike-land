# Git
.git
.gitignore

# Build artifacts (will be created fresh)
.next
node_modules
coverage
dist
.cache
.docker-cache

# Yarn cache — use Docker BuildKit cache mount instead of sending 1.2G in context
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
.yarn/build-state.yml
.pnp.*

# Environment files
# Allow .env.local for dev container, exclude others
.env
.env.production
.env.development
.env.test
!.env.local
!.env.example

# IDE and OS
.DS_Store
.idea
.vscode
*.swp
*.swo

# TypeScript build info
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test artifacts
*.lcov
.nyc_output

# Playwright/E2E artifacts
playwright-report
test-results
e2e/reports

# Other
.vercel
.turbo
.nx
.bare
packages/*/node_modules
packages/*/.next
packages/*/dist
packages/*/out
packages/*/dist-vite
packages/*/dts
packages/*/coverage
tmp

# Claude/AI
.claude/plans/
.claude/teams/
.claude/tasks/

.well-known
.dev-logs
.claude
.eslintcache
.husky

# Development tool caches
.playwright-mcp
.opencode
.agent
.agents
.codex
.copilot
.swc

# Directories unused by main Dockerfile (reduces build context ~10MB)
workers/
.github/
terraform/

# Large binary assets not needed in Docker build/CI (~78MB)
public/audio/
public/test-image.png
public/mockups/
public/blog/**/*.jpg
public/blog/**/*.png
content/*.m4a
packages/video/public/

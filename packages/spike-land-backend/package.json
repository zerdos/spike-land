{
  "name": "@spike-land-ai/spike-land-backend",
  "description": "Main backend for spike.land, providing real-time collaboration, API services, AI integrations, and static asset hosting via Cloudflare Workers.",
  "version": "0.9.57",
  "type": "module",
  "module": "dist/index.js",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "build:worker": "echo 'No build required - using direct deployment'",
    "w:deploy:dev": "wrangler deploy --env testing --minify",
    "w:deploy:prod": "wrangler deploy --minify",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:api": "npm run typecheck && npm run lint && npm run test",
    "lint": "eslint --quiet .",
    "deploy": "wrangler deploy --minify",
    "deploy:dev": "wrangler deploy --env testing --minify",
    "__STATIC_CONTENT_MANIFEST": "./src/staticContent.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@cloudflare/vitest-pool-workers": "0.14.1",
    "@cloudflare/workers-types": "4.20260405.1",
    "@types/node": "25.4.0",
    "@vitest/coverage-istanbul": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wrangler": "4.72.0"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "0.4.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sentry/cloudflare": "^10.47.0",
    "@spike-land-ai/code": "^0.9.58",
    "hono": "^4.12.7",
    "replicate": "1.4.0",
    "zod": "4.3.6"
  },
  "source": "./index.ts"
}

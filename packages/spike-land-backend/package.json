{
  "name": "@spike-land-ai/spike-land-backend",
  "description": "Main backend for spike.land, providing real-time collaboration, API services, AI integrations, and static asset hosting via Cloudflare Workers.",
  "version": "0.9.57",
  "type": "module",
  "module": "dist/index.js",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "build:worker": "echo 'No build required - using direct deployment'",
    "w:deploy:dev": "wrangler deploy --env testing --minify",
    "w:deploy:prod": "wrangler deploy --minify",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:api": "npm run typecheck && npm run lint && npm run test",
    "lint": "eslint --quiet .",
    "deploy": "wrangler deploy --minify",
    "deploy:dev": "wrangler deploy --env testing --minify",
    "__STATIC_CONTENT_MANIFEST": "./src/staticContent.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260503.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.85.0"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.5.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sentry/cloudflare": "^10.51.0",
    "@spike-land-ai/code": "^0.9.58",
    "@spike-land-ai/shared": "workspace:*",
    "hono": "^4.12.16",
    "replicate": "^1.4.0",
    "zod": "4.4.2"
  },
  "source": "./index.ts"
}

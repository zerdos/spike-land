{
  "name": "@spike-land-ai/image-studio-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Image Studio — Cloudflare Worker with React frontend",
  "type": "module",
  "main": "index.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "npm run build:frontend && wrangler dev",
    "dev:all": "npm run build:frontend & wrangler dev",
    "build": "npm run build:frontend && echo 'Worker uses [assets] directive — frontend/dist is ready'",
    "build:frontend": "cd frontend && npm install --no-audit --no-fund && npm run build",
    "db:migrate": "wrangler d1 migrations apply IMAGE_DB --remote",
    "deploy": "bash deploy.sh",
    "deploy:force": "FORCE_DEPLOY=1 bash deploy.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint --quiet ."
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@spike-land-ai/mcp-image-studio": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "source": "./index.ts"
}

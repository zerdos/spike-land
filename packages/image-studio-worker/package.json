{
  "name": "@spike-land-ai/image-studio-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Image Studio — Cloudflare Worker with React frontend",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "npm run build:frontend && wrangler dev",
    "dev:all": "npm run build:frontend & wrangler dev",
    "build": "npm run build:frontend && echo 'Worker uses [assets] directive — frontend/dist is ready'",
    "build:frontend": "cd frontend && npm install --no-audit --no-fund && npm run build",
    "db:migrate": "wrangler d1 migrations apply IMAGE_DB --remote",
    "deploy": "bash deploy.sh",
    "deploy:force": "FORCE_DEPLOY=1 bash deploy.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint --quiet ."
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@spike-land-ai/mcp-image-studio": "*",
    "@spike-land-ai/shared": "*",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260307.1",
    "@google/genai": "^1.44.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  },
  "source": "./index.ts"
}

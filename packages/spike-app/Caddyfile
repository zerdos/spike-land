{
	auto_https off
	servers {
		protocols h1 h2 h3
	}
}

https://local.spike.land:5173 {
	tls ../../.dev-certs/local.spike.land.pem ../../.dev-certs/local.spike.land-key.pem

	# API/MCP/OAuth proxy to production edge
	reverse_proxy /api/* https://api.spike.land {
		header_up Host api.spike.land
	}
	reverse_proxy /mcp/* https://spike.land {
		header_up Host spike.land
	}
	reverse_proxy /oauth/* https://spike.land {
		header_up Host spike.land
	}

	# Serve built SPA from dist/
	root * dist
	encode gzip zstd
	file_server {
		precompressed gzip zstd
	}

	# SPA fallback: serve index.html for all non-file routes
	try_files {path} /index.html
}

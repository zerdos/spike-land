{
  "name": "@spike-land-ai/video",
  "version": "1.0.1",
  "private": true,
  "description": "The Vibe Coding Paradox — Veritasium-style educational video",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/video.git"
  },
  "exports": {
    "./compositions/*": "./src/compositions/*",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*"
  },
  "scripts": {
    "dev": "remotion studio",
    "render:vcp": "remotion render VibeCodingParadox out/vibe-coding-paradox.mp4 --codec h264 --crf 18",
    "render:n404": "remotion render NoMore404s out/no-more-404s.mp4 --codec h264 --crf 18",
    "generate-audio:n404": "tsx scripts/generate-audio-n404.ts",
    "render:scene": "remotion render",
    "upgrade": "remotion upgrade",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet src/"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.433",
    "@remotion/cli": "4.0.433",
    "@remotion/transitions": "4.0.433",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.433",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@remotion/eslint-config": "4.0.433",
    "@remotion/tailwind": "4.0.433",
    "@spike-land-ai/eslint-config": "workspace:^",
    "@spike-land-ai/tsconfig": "workspace:^",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "10.4.27",
    "jsdom": "28.1.0",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "source": "./index.ts"
}

{
  "name": "@spike-land-ai/qa-studio",
  "version": "0.1.0",
  "description": "QA Studio browser automation utilities for spike.land",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "qa-studio-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet src/",
    "mcp": "node dist/mcp-server.js",
    "mcp:visible": "node dist/mcp-server.js --visible",
    "mcp:http": "node dist/mcp-server.js --http --port 3100"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^0.0.15",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@spike-land-ai/mcp-server-base": "*",
    "hono": "^4.7.10",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.20.0"
  },
  "peerDependencies": {
    "playwright": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": { "optional": true }
  },
  "keywords": [
    "qa",
    "browser-automation",
    "playwright",
    "puppeteer",
    "cloudflare-workers",
    "accessibility",
    "mcp",
    "screen-reader",
    "spike-land"
  ],
  "license": "MIT",
  "source": "./index.ts"
}

{
  "name": "@spike-land-ai/qa-studio",
  "version": "0.1.0",
  "description": "QA Studio browser automation utilities for spike.land",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@spike-land-ai/tsconfig": "workspace:*",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "playwright": ">=1.0.0"
  },
  "keywords": [
    "qa",
    "browser-automation",
    "playwright",
    "accessibility",
    "spike-land"
  ],
  "license": "MIT"
}

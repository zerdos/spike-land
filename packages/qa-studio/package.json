{
  "name": "@spike-land-ai/qa-studio",
  "version": "1.0.0",
  "description": "QA Studio browser automation MCP server for spike.land",
  "type": "module",
  "bin": "./dist/mcp-server.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "tsup",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "qa",
    "browser-automation",
    "playwright",
    "mcp",
    "spike-land"
  ],
  "license": "MIT",
  "source": "./index.ts"
}

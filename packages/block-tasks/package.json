{
  "name": "@spike-land-ai/block-tasks",
  "version": "0.1.0",
  "description": "Proof-of-concept full-stack block — task queue with CRUD, claim workflow, and React UI",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./index.ts",
    "./worker": "./worker.ts",
    "./browser": "./browser.ts"
  },
  "dependencies": {
    "@spike-land-ai/block-sdk": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint --quiet .",
    "typecheck": "tsc --noEmit"
  },
  "source": "./index.ts"
}

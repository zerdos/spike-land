{
  "name": "@spike-land-ai/openclaw-mcp",
  "version": "0.1.1",
  "description": "Standalone MCP bridge for OpenClaw gateway",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/packages/openclaw-mcp/index.js",
  "types": "./dist/packages/openclaw-mcp/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/openclaw-mcp/index.d.ts",
      "import": "./dist/packages/openclaw-mcp/index.js",
      "default": "./dist/packages/openclaw-mcp/index.js"
    }
  },
  "bin": "./dist/packages/openclaw-mcp/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "start": "node dist/packages/openclaw-mcp/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/openclaw-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@spike-land-ai/mcp-server-base": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "25.4.0",
    "eslint": "10.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "source": "./index.ts"
}

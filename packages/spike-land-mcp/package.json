{
  "name": "@spike-land-ai/spike-land-mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "deploy:staging": "wrangler deploy --minify --env staging",
    "build": "echo 'CF Worker — no build step required'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "db:generate": "drizzle-kit generate",
    "db:reconcile:local": "node --import tsx ../../scripts/d1-local-baseline.ts spike-land-mcp",
    "db:migrate:local": "node --import tsx ../../scripts/d1-local-baseline.ts spike-land-mcp --apply-pending",
    "db:migrate:remote": "wrangler d1 migrations apply spike-land-mcp --remote"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/cloudflare": "^10.51.0",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.85.0"
  },
  "source": "./index.ts"
}

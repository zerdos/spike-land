{
  "name": "@spike-land-ai/spike-land-mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "deploy:staging": "wrangler deploy --minify --env staging",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply spike-land-mcp --local",
    "db:migrate:remote": "wrangler d1 migrations apply spike-land-mcp --remote"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1",
    "@spike-land-ai/shared": "*",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.7.11",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@spike-land-ai/tsconfig": "*",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.21.0"
  }
}

{
  "name": "@spike-land-ai/transpile",
  "description": "Cloudflare Worker providing on-demand JavaScript/TypeScript transpilation services using esbuild for the spike.land collaborative code editor.",
  "version": "0.9.57",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "build:worker": "esbuild index.ts --bundle --outfile=dist/index.js --platform=node --format=esm --target=es2020 --external:esbuild-wasm --external:@spike-land-ai/code --loader:.wasm=file",
    "deploy": "wrangler deploy --minify",
    "w:deploy:prod": "wrangler deploy index.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint --quiet .",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@cloudflare/vitest-pool-workers": "0.14.1",
    "@cloudflare/workers-types": "4.20260405.1",
    "@vitest/coverage-v8": "4.1.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wrangler": "4.72.0"
  },
  "dependencies": {
    "@spike-land-ai/code": "^0.9.58",
    "esbuild-wasm": "*"
  },
  "source": "./index.ts"
}

{
  "name": "@spike-land-ai/vibe-dev",
  "version": "0.1.1",
  "description": "Lightweight Docker-based development workflow for vibe-coded apps",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean",
    "dev": "tsup index.ts --format esm --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet ."
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chokidar": "5.0.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "25.4.0",
    "eslint": "10.0.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/vibe-dev.git"
  },
  "source": "./index.ts"
}

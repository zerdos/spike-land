{
  "name": "@spike-land-ai/mcp-auth",
  "version": "1.0.0",
  "description": "Auth MCP server for spike.land",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'CF Worker — no build step required'",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --quiet ."
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.5.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/cloudflare": "^10.47.0",
    "better-auth": "1.5.6",
    "drizzle-orm": "^0.45.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260405.1",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.72.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "source": "./index.ts"
}

{
  "name": "@spike-land-ai/chess-engine",
  "version": "0.1.0",
  "description": "Chess engine with ELO, game/player/challenge managers for spike.land",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@spike-land-ai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "chess.js": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "chess.js": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "source": "./index.ts"
}

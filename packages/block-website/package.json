{
  "name": "@spike-land-ai/block-website",
  "version": "1.0.0",
  "description": "Isomorphic Hyper-Block for spike.land marketing and blog",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.2",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.474.0",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "gray-matter": "^4.0.3",
    "react": "^19.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.0.0",

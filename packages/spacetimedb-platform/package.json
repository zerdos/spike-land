{
  "name": "@spike-land-ai/spacetimedb-platform",
  "version": "0.1.0",
  "description": "SpacetimeDB module for spike.land platform — users, tools, apps, agents, content, messaging, monitoring",
  "type": "module",
  "bin": "dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/module_bindings/index": "./src/module_bindings/index.ts",
    "./src/module_bindings/index.js": "./src/module_bindings/index.ts",
    "./dist/module_bindings/index.js": "./dist/module_bindings/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/spacetimedb-platform.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "spacetimedb": "patch:spacetimedb@npm%3A2.0.2#~/.yarn/patches/spacetimedb-npm-2.0.2-9d60528158.patch",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@spike-land-ai/eslint-config": "*",
    "@spike-land-ai/tsconfig": "*",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "keywords": [
    "mcp",
    "spacetimedb",
    "platform",
    "real-time",
    "websocket"
  ],
  "license": "MIT"
}

{
  "name": "@spike-land-ai/google-analytics-mcp",
  "version": "0.1.0",
  "description": "MCP server for Google Analytics 4 read access",
  "type": "module",
  "bin": "dist/src/mcp-tools/google-analytics/mcp/server.js",
  "main": "./dist/packages/google-analytics-mcp/index.js",
  "types": "./dist/packages/google-analytics-mcp/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/google-analytics-mcp/index.d.ts",
      "import": "./dist/packages/google-analytics-mcp/index.js",
      "default": "./dist/packages/google-analytics-mcp/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-land-ai/spike-land-ai.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --config ../../.tests/vitest.config.ts --project google-analytics-mcp",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "start": "node dist/src/mcp-tools/google-analytics/mcp/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "license": "MIT",
  "source": "./index.ts"
}

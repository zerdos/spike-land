---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title = 'Article - spike.land',
  description = 'Read on spike.land',
  ogImage = '/android-chrome-512x512.png',
  canonicalUrl,
  noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? Astro.url.href;
const resolvedOgImage = new URL(ogImage, Astro.site ?? Astro.url.origin).href;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="spike.land" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@spike_land" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Fonts: Rubik -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX for LaTeX math rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" integrity="sha384-zh0CIslj+VczCZtlzBcjt5ppRcsAmDnRem7ESsYwWwg3m/OaJ2l4x7YBZl9Kxxib" crossorigin="anonymous" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <slot name="head" />
    <script is:inline define:vars={{ isDev: import.meta.env.DEV }}>
      (function () {
        try {
          const stored = localStorage.getItem('theme-preference');
          const def = isDev ? 'dark' : 'light';
          document.documentElement.classList.toggle('dark', (stored ?? def) === 'dark');
        } catch {}
      })();
    </script>
  </head>
  <body class="article-body font-sans article-base">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">Skip to content</a>
    <slot name="nav" />
    <main id="main-content" class="container mx-auto max-w-screen-md px-5 pt-8 pb-16">
      <slot />
    </main>
    <slot name="footer" />
    <style>
      .article-body {
        background: var(--bg);
        color: var(--fg);
        transition: background var(--duration-normal) var(--ease),
                    color var(--duration-normal) var(--ease);
      }
    </style>
  </body>
</html>

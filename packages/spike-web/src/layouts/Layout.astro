---
import '../styles/global.css';
import ErrorReporter from '../components/ErrorReporter.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title = 'spike.land - AI App Store',
  description = 'Open AI app store built on MCP runtime. Scaffold, test, and deploy multi-agent systems in seconds.',
  ogImage = '/android-chrome-512x512.png',
  ogType = 'website',
  canonicalUrl,
  noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? Astro.url.href;
const resolvedOgImage = new URL(ogImage, Astro.site ?? Astro.url.origin).href;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="spike.land" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@spike_land" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- No-index for utility pages -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {ogType === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            name: "spike.land",
            url: "https://spike.land",
            logo: "https://spike.land/android-chrome-512x512.png",
            sameAs: ["https://github.com/spike-land-ai", "https://x.com/spike_land"],
          },
          {
            "@type": "WebSite",
            name: "spike.land",
            url: "https://spike.land",
            potentialAction: {
              "@type": "SearchAction",
              target: "https://spike.land/apps?q={search_term_string}",
              "query-input": "required name=search_term_string",
            },
          },
        ],
      })} />
    )}

    <!-- Additional head content (analytics, page-specific scripts, etc.) -->
    <slot name="head" />
    <!-- Global error reporting -->
    <ErrorReporter />
    <script>
      import { initBrowserSentry } from '../lib/sentry';

      initBrowserSentry();
    </script>
    <script is:inline define:vars={{ isDev: import.meta.env.DEV }}>
      (function () {
        const stored = localStorage.getItem('theme-preference');
        const def = isDev ? 'dark' : 'light';
        document.documentElement.classList.toggle('dark', (stored ?? def) === 'dark');
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">Skip to content</a>
    <slot />
  </body>
</html>

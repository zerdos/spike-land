---
import { SpikeChatDemo } from "./SpikeChatDemo";

interface Props {
  name: string;
  description: string;
  accent: string;
  accentBg: string;
}

const { name, description, accent, accentBg } = Astro.props;

const runtimeSignals = [
  { label: "Pipeline", value: "4 stages" },
  { label: "Memory", value: "Bayesian" },
  { label: "Tooling", value: "80+ MCP tools" },
  { label: "Context", value: "bounded" },
];

const stages = [
  {
    name: "Classify",
    detail: "Routes intent, urgency, and domain before the model starts improvising.",
  },
  {
    name: "Plan",
    detail: "Builds a narrow response strategy and decides whether tool work is necessary.",
  },
  {
    name: "Execute",
    detail: "Streams the answer, runs tools, and emits compact artifacts instead of transcript sludge.",
  },
  {
    name: "Extract",
    detail: "Promotes useful notes, demotes noise, and updates long-term memory after the turn.",
  },
];

const notes = [
  { confidence: "0.92", text: "Route /apps/spike-chat should resolve to a dedicated product page." },
  { confidence: "0.81", text: "Full transcript replay is wasteful when stage artifacts already exist." },
  { confidence: "0.74", text: "Deployment regressions are easier to isolate when route metadata is explicit." },
];

const toolEvents = [
  { name: "inspect_spa_assets", status: "done" },
  { name: "trace_app_route", status: "done" },
  { name: "render_prerendered_page", status: "active" },
];
---

<section
  class="chat-page"
  style={`--page-accent: ${accent}; --page-accent-bg: ${accentBg};`}
>
  <div class="rubik-container chat-page-inner">
    <section class="hero-shell">
      <div class="hero-copy">
        <div class="hero-meta">
          <span class="rubik-chip">
            <span class="status-dot"></span>
            live
          </span>
          <span class="hero-kicker">Aether memory runtime</span>
        </div>

        <h1 class="hero-title">
          {name} keeps context sharp by refusing to carry the whole transcript.
        </h1>
        <p class="rubik-lede hero-lede">{description}</p>

        <div class="hero-actions">
          <a href="/blog/why-spike-chat-stays-sharp" class="cta-primary">
            Read the architecture
          </a>
          <a href="/apps" class="cta-secondary">Browse apps</a>
        </div>

        <div class="signal-strip">
          {runtimeSignals.map((signal) => (
            <div class="signal-card">
              <span class="signal-label">{signal.label}</span>
              <span class="signal-value">{signal.value}</span>
            </div>
          ))}
        </div>
      </div>

      <SpikeChatDemo client:only="react" />
    </section>

    <section class="proof-grid">
      <article class="rubik-panel pipeline-card">
        <div class="section-head">
          <p class="rubik-eyebrow">Execution model</p>
          <h2>Transcript-first is the bug. Staged artifacts are the fix.</h2>
        </div>

        <ol class="stage-list">
          {stages.map((stage, index) => (
            <li class="stage-row">
              <span class="stage-index">0{index + 1}</span>
              <div>
                <h3>{stage.name}</h3>
                <p>{stage.detail}</p>
              </div>
            </li>
          ))}
        </ol>
      </article>

      <article class="rubik-panel side-card">
        <div class="section-head">
          <p class="rubik-eyebrow">Memory policy</p>
          <h2>Notes compete for context.</h2>
        </div>
        <p class="side-copy">
          Spike Chat scores notes instead of replaying every past turn. Helpful evidence survives.
          Noise decays.
        </p>
        <div class="memory-stack">
          {notes.map((note) => (
            <div class="memory-row">
              <span class="memory-score">{note.confidence}</span>
              <span>{note.text}</span>
            </div>
          ))}
        </div>
      </article>

      <article class="rubik-panel side-card">
        <div class="section-head">
          <p class="rubik-eyebrow">Tooling surface</p>
          <h2>Bounded tools, visible state.</h2>
        </div>
        <p class="side-copy">
          Tool work stays legible through compact event traces, not giant hidden transcripts. The
          model gets enough evidence to act without drowning in history.
        </p>
        <div class="terminal-card">
          <div class="terminal-line">$ classify --channel app-spike-chat</div>
          <div class="terminal-line">$ plan --intent deploy-regression</div>
          <div class="terminal-line">$ execute --tool trace_app_route</div>
          <div class="terminal-line muted">artifact emitted: prerender catalog missing spike-chat</div>
        </div>
      </article>
    </section>
  </div>
</section>

<style is:global>
  .chat-page {
    position: relative;
    padding-block: clamp(2rem, 5vw, 4.5rem);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--page-accent) 14%, transparent), transparent 42%),
      linear-gradient(180deg, color-mix(in srgb, var(--bg) 92%, var(--page-accent-bg)), var(--bg) 30%);
  }

  .chat-page-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.5rem) 0;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--page-accent);
    box-shadow: 0 0 0 0.25rem color-mix(in srgb, var(--page-accent) 18%, transparent);
  }

  .hero-kicker {
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-fg);
    font-weight: 700;
  }

  .hero-title {
    max-width: 12ch;
    font-size: clamp(2.5rem, 5vw, 5.5rem);
  }

  .hero-lede {
    max-width: 54ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem;
    padding: 0.75rem 1.1rem;
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    transition: transform var(--duration-fast) var(--ease), opacity var(--duration-fast) var(--ease), border-color var(--duration-fast) var(--ease), background var(--duration-fast) var(--ease);
  }

  .cta-primary {
    color: white;
    background: var(--page-accent);
    box-shadow: var(--shadow-md);
  }

  .cta-primary:hover,
  .cta-secondary:hover {
    transform: translateY(-1px);
  }

  .cta-secondary {
    color: var(--fg);
    background: color-mix(in srgb, var(--card-bg) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--page-accent) 18%, var(--border-color));
  }

  .signal-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .signal-card {
    padding: 0.875rem 1rem;
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--card-bg) 90%, transparent);
    border: 1px solid color-mix(in srgb, var(--page-accent) 12%, var(--border-color));
  }

  .signal-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-fg);
    font-weight: 700;
  }

  .signal-value {
    display: block;
    margin-top: 0.2rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
  }

  .workspace {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
    padding: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 96%, transparent), var(--card-bg)),
      linear-gradient(135deg, color-mix(in srgb, var(--page-accent) 10%, transparent), transparent 65%);
  }

  .workspace-topbar,
  .workspace-body,
  .composer {
    border: 1px solid color-mix(in srgb, var(--page-accent) 12%, var(--border-color));
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--card-bg) 94%, transparent);
  }

  .workspace-topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
  }

  .workspace-label {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-fg);
    font-weight: 700;
  }

  .workspace-name {
    margin: 0.15rem 0 0;
    font-size: 1rem;
  }

  .workspace-state {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .stage-badge,
  .memory-badge {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .stage-badge {
    background: color-mix(in srgb, var(--page-accent) 14%, transparent);
    color: var(--page-accent);
  }

  .memory-badge {
    background: var(--muted-bg);
    color: var(--fg);
  }

  .workspace-body {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(15rem, 0.9fr);
    gap: 0.9rem;
    padding: 0.9rem;
  }

  .conversation {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bubble {
    max-width: 85%;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .bubble-assistant {
    background: color-mix(in srgb, var(--card-bg) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--page-accent) 10%, var(--border-color));
    border-top-left-radius: 0.3rem;
  }

  .bubble-user {
    margin-left: auto;
    background: var(--page-accent);
    color: white;
    border-top-right-radius: 0.3rem;
  }

  .bubble-role {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.8;
  }

  .bubble p,
  .side-copy {
    margin: 0;
  }

  .bubble code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.05rem 0.3rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, white 18%, transparent);
  }

  .workspace-rail {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .rail-card {
    padding: 0.85rem;
    border-radius: var(--radius-lg);
    background: var(--muted-bg);
  }

  .rail-label {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--muted-fg);
  }

  .note-list,
  .tool-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .note-item,
  .tool-item,
  .memory-row,
  .stage-row {
    display: grid;
    gap: 0.75rem;
    align-items: start;
  }

  .note-item,
  .memory-row {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .note-score,
  .memory-score,
  .stage-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    min-height: 2rem;
    padding-inline: 0.55rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--page-accent) 12%, transparent);
    color: var(--page-accent);
  }

  .tool-item {
    grid-template-columns: minmax(0, 1fr) auto;
    font-family: var(--font-mono);
    font-size: 0.84rem;
  }

  .tool-status {
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    text-transform: lowercase;
    background: color-mix(in srgb, var(--page-accent) 12%, transparent);
    color: var(--page-accent);
  }

  .tool-status.done {
    background: color-mix(in srgb, var(--color-status-live) 12%, transparent);
    color: color-mix(in srgb, var(--color-status-live) 80%, var(--fg));
  }

  .tool-status.active {
    background: color-mix(in srgb, var(--page-accent) 16%, transparent);
    color: var(--page-accent);
  }

  .composer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
  }

  .composer-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--fg);
    font-family: inherit;
    font-size: 0.9rem;
    outline: none;
    min-width: 0;
  }

  .composer-input::placeholder {
    color: var(--muted-fg);
  }

  .composer-send {
    padding: 0.28rem 0.55rem;
    border-radius: 0.45rem;
    background: color-mix(in srgb, var(--page-accent) 12%, transparent);
    color: var(--page-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
  }

  .composer-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) repeat(2, minmax(0, 0.85fr));
    gap: 1rem;
  }

  .pipeline-card,
  .side-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .section-head h2 {
    max-width: 20ch;
    margin: 0;
    font-size: clamp(1.55rem, 2.2vw, 2.35rem);
  }

  .stage-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
  }

  .stage-row {
    grid-template-columns: auto minmax(0, 1fr);
    padding: 0.9rem 0;
    border-top: 1px solid var(--border-color);
  }

  .stage-row:first-child {
    border-top: none;
    padding-top: 0;
  }

  .stage-row h3,
  .stage-row p {
    margin: 0;
  }

  .stage-row p {
    margin-top: 0.3rem;
    color: var(--muted-fg);
  }

  .memory-stack {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .terminal-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: var(--terminal-bg);
    color: var(--terminal-fg);
    font-family: var(--font-mono);
    font-size: 0.83rem;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--terminal-fg) 4%, transparent);
  }

  .terminal-line.muted {
    color: var(--terminal-accent);
  }

  @media (max-width: 1100px) {
    .hero-shell,
    .proof-grid,
    .workspace-body {
      grid-template-columns: 1fr;
    }

    .hero-title {
      max-width: 15ch;
    }
  }

  @media (max-width: 720px) {
    .chat-page {
      padding-block: 1.5rem 2.5rem;
    }

    .hero-title {
      max-width: none;
      font-size: clamp(2.2rem, 9vw, 3.5rem);
    }

    .signal-strip {
      grid-template-columns: 1fr;
    }

    .workspace {
      padding: 0.8rem;
    }

    .workspace-topbar,
    .composer {
      align-items: flex-start;
      flex-direction: column;
    }

    .workspace-state {
      justify-content: flex-start;
    }

    .bubble {
      max-width: 100%;
    }
  }
</style>

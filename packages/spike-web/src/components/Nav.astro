---
import ThemeToggle from './react/ThemeToggle';

interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const links = [
  { href: '/apps', label: 'Store' },
  { href: '/arena', label: 'Arena' },
  { href: '/blog', label: 'Blog' },
  { href: '/pricing', label: 'Pricing' },
];
---

<header class="nav-header">
  <div class="rubik-container">
    <nav class="nav-inner" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="spike.land home">
        <span class="nav-logo-text">spike.land</span>
      </a>

      <!-- Nav links -->
      <ul class="nav-links" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${activePath === link.href ? 'nav-link--active' : ''}`}
              aria-current={activePath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side -->
      <div class="nav-actions">
        <a href="https://github.com/spike-land-ai/spike-land" class="nav-icon-link" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 4.238 9.617 9.634 10.828.576.106.788-.25.788-.556 0-.273-.01-1.185-.015-2.171-4.037.876-4.889-1.731-4.889-1.731-.66-1.676-1.61-2.122-1.61-2.122-1.318-.9.1-.882.1-.882 1.457.102 2.224 1.496 2.224 1.496 1.296 2.218 3.39 1.577 4.216 1.206.13-.938.533-1.577.976-1.94-3.221-.366-6.608-1.61-6.608-7.17 0-1.583.565-2.877 1.492-3.892-.15-.366-.647-1.84.142-3.838 0 0 1.217-.422 3.992 1.486 1.157-.322 2.397-.483 3.633-.488 1.235.005 2.476.166 3.635.488 2.772-1.908 3.987-1.486 3.987-1.486.791 1.998.294 3.472.144 3.838.929 1.015 1.49 2.309 1.49 3.892 0 5.574-3.393 6.801-6.624 7.16.524.452.991 1.344.991 2.709 0 1.957-.014 3.532-.014 4.012 0 .31.209.669.799.554 5.393-1.213 9.629-5.526 9.629-10.828 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <ThemeToggle client:load />
        <a href="/login" class="nav-sign-in">Sign In</a>
        <a href="/login" class="nav-cta">
          Start Building
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: oklch(from var(--bg) l c h / 0.82);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid oklch(from var(--border-color) l c h / 0.6);
    transition: background var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3.75rem;
  }

  .nav-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--fg);
    background: linear-gradient(135deg, var(--fg) 0%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .nav-logo:hover .nav-logo-text {
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    margin-left: 1rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .nav-link:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-link--active {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
  }

  .nav-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-fg);
    padding: 0.375rem;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .nav-icon-link:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-sign-in {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease);
  }

  .nav-sign-in:hover {
    color: var(--fg);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: transform var(--duration-fast) var(--ease),
                box-shadow var(--duration-fast) var(--ease),
                filter var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-sm);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    filter: brightness(1.08);
  }

  .nav-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
    .nav-sign-in {
      display: none;
    }
  }
</style>

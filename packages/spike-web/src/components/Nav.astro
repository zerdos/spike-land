---
import ThemeToggle from './react/ThemeToggle';

interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const links = [
  { href: '/apps', label: 'Store' },
  { href: '/arena', label: 'Arena' },
  { href: '/blog', label: 'Blog' },
  { href: '/pricing', label: 'Pricing' },
];
---

<header class="nav-header">
  <div class="rubik-container">
    <nav class="nav-inner" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="spike.land home">
        <span class="nav-logo-text">spike.land</span>
      </a>

      <!-- Nav links -->
      <ul class="nav-links" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${activePath === link.href ? 'nav-link--active' : ''}`}
              aria-current={activePath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side -->
      <div class="nav-actions">
        <ThemeToggle client:load />
        <a href="/login" class="nav-sign-in">Sign In</a>
        <a href="/login" class="nav-cta">
          Start Building
        </a>
        <button
          id="nav-menu-toggle"
          class="nav-menu-toggle"
          type="button"
          aria-label="Open menu"
          aria-controls="nav-mobile-menu"
          aria-expanded="false"
        >
          <svg class="nav-menu-icon nav-menu-icon--open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="nav-menu-icon nav-menu-icon--close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile menu drawer — sibling of header so backdrop-filter on
     .nav-header doesn't trap `position: fixed` in a 3.75rem containing block -->
<div id="nav-mobile-menu" class="nav-mobile" hidden>
  <div class="rubik-container nav-mobile-inner">
    <ul class="nav-mobile-links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-mobile-link ${activePath === link.href ? 'nav-mobile-link--active' : ''}`}
            aria-current={activePath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li><a href="/login" class="nav-mobile-link">Sign In</a></li>
      <li>
        <a href="/login" class="nav-mobile-cta">
          Start Building
        </a>
      </li>
    </ul>
  </div>
</div>

<script is:inline>
(function () {
  var toggle = document.getElementById('nav-menu-toggle');
  var menu = document.getElementById('nav-mobile-menu');
  var header = document.querySelector('.nav-header');
  if (!toggle || !menu || !header) return;

  function setOpen(open) {
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    if (open) {
      menu.hidden = false;
      // Next frame so the transition can play
      requestAnimationFrame(function () {
        menu.classList.add('nav-mobile--open');
      });
      header.classList.add('nav-header--menu-open');
      document.body.style.overflow = 'hidden';
    } else {
      menu.classList.remove('nav-mobile--open');
      header.classList.remove('nav-header--menu-open');
      document.body.style.overflow = '';
      setTimeout(function () {
        if (toggle.getAttribute('aria-expanded') === 'false') menu.hidden = true;
      }, 220);
    }
  }

  toggle.addEventListener('click', function () {
    var isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  // Close on link click (so anchor nav inside the panel feels right)
  menu.addEventListener('click', function (e) {
    var target = e.target;
    while (target && target !== menu) {
      if (target.tagName === 'A') {
        setOpen(false);
        break;
      }
      target = target.parentNode;
    }
  });

  // Close on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });

  // Close if viewport grows past the mobile breakpoint
  var mql = window.matchMedia('(min-width: 641px)');
  function onChange(e) { if (e.matches) setOpen(false); }
  if (mql.addEventListener) mql.addEventListener('change', onChange);
  else if (mql.addListener) mql.addListener(onChange);
})();
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: oklch(from var(--bg) l c h / 0.82);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid oklch(from var(--border-color) l c h / 0.6);
    transition: background var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3.75rem;
  }

  .nav-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--fg);
    background: linear-gradient(135deg, var(--fg) 0%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .nav-logo:hover .nav-logo-text {
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    margin-left: 1rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .nav-link:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-link--active {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .nav-menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    color: var(--fg);
    border: 1px solid oklch(from var(--border-color) l c h / 0.8);
    border-radius: var(--radius-md);
    cursor: pointer;
    padding: 0;
    transition: background var(--duration-fast) var(--ease),
                border-color var(--duration-fast) var(--ease);
  }

  .nav-menu-toggle:hover {
    background: var(--muted-bg);
  }

  .nav-menu-toggle:focus-visible {
    outline: 2px solid var(--primary-color);
    outline-offset: 2px;
  }

  .nav-menu-icon--close {
    display: none;
  }

  .nav-menu-toggle[aria-expanded="true"] .nav-menu-icon--open {
    display: none;
  }

  .nav-menu-toggle[aria-expanded="true"] .nav-menu-icon--close {
    display: block;
  }

  .nav-mobile {
    position: fixed;
    top: 3.75rem;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 49;
    background: oklch(from var(--bg) l c h / 0.98);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-top: 1px solid oklch(from var(--border-color) l c h / 0.6);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity var(--duration-normal) var(--ease),
                transform var(--duration-normal) var(--ease);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .nav-mobile--open {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-mobile-inner {
    padding: 1.25rem 1rem 2rem;
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.875rem 0.75rem;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background var(--duration-fast) var(--ease);
  }

  .nav-mobile-link:hover,
  .nav-mobile-link:focus-visible {
    background: var(--muted-bg);
    outline: none;
  }

  .nav-mobile-link--active {
    color: var(--primary-color);
    background: var(--muted-bg);
  }

  .nav-mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    box-shadow: var(--shadow-sm);
  }

  .nav-mobile-cta:hover {
    filter: brightness(1.08);
  }

  .nav-sign-in {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease);
  }

  .nav-sign-in:hover {
    color: var(--fg);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: transform var(--duration-fast) var(--ease),
                box-shadow var(--duration-fast) var(--ease),
                filter var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-sm);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    filter: brightness(1.08);
  }

  .nav-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
    .nav-sign-in {
      display: none;
    }
    .nav-cta {
      display: none;
    }
    .nav-menu-toggle {
      display: inline-flex;
    }
  }

  @media (min-width: 641px) {
    .nav-mobile {
      display: none !important;
    }
  }
</style>

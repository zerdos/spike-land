---
import ThemeToggle from './react/ThemeToggle';

interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const links = [
  { href: '/ai', label: 'AI' },
  { href: '/apps', label: 'Apps' },
  { href: '/blog', label: 'Blog' },
  { href: '/pricing', label: 'Pricing' },
];
---

<header class="nav-header">
  <div class="rubik-container">
    <nav class="nav-inner" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="spike.land home">
        <span class="nav-logo-text">spike.land</span>
      </a>

      <!-- Nav links -->
      <ul class="nav-links" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${activePath === link.href ? 'nav-link--active' : ''}`}
              aria-current={activePath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: theme toggle + CTA -->
      <div class="nav-actions">
        <ThemeToggle client:load />
        <a href="/login" class="nav-cta">
          Get Started
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: oklch(from var(--bg) l c h / 0.82);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid oklch(from var(--border-color) l c h / 0.6);
    transition: background var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3.75rem;
  }

  .nav-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--fg);
    background: linear-gradient(135deg, var(--fg) 0%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .nav-logo:hover .nav-logo-text {
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    margin-left: 1rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .nav-link:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-link--active {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: transform var(--duration-fast) var(--ease),
                box-shadow var(--duration-fast) var(--ease),
                filter var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-sm);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    filter: brightness(1.08);
  }

  .nav-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>

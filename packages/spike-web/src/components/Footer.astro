---
import Whisper from './typography/Whisper.astro';

const year = new Date().getFullYear();

const productLinks = [
  { href: '/ai', label: 'AI Personas' },
  { href: '/apps', label: 'App Store' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/chat', label: 'Chat' },
];

const resourceLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/learn', label: 'Learn' },
  { href: 'https://github.com/spike-land-ai/spike-land', label: 'GitHub' },
  { href: 'https://status.spike.land', label: 'Status' },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy' },
  { href: 'mailto:hello@spike.land', label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="rubik-container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">spike.land</a>
        <p class="footer-tagline">
          <Whisper text="The open AI app store." />
        </p>
      </div>

      <div class="footer-columns">
        <div class="footer-column">
          <h4 class="footer-column-title">Product</h4>
          <nav class="footer-col-links" aria-label="Product navigation">
            {productLinks.map(link => (
              <a href={link.href} class="footer-link">{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4 class="footer-column-title">Resources</h4>
          <nav class="footer-col-links" aria-label="Resources navigation">
            {resourceLinks.map(link => (
              <a href={link.href} class="footer-link" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4 class="footer-column-title">Legal</h4>
          <nav class="footer-col-links" aria-label="Legal navigation">
            {legalLinks.map(link => (
              <a href={link.href} class="footer-link">{link.label}</a>
            ))}
          </nav>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; {year} spike.land. All rights reserved.</span>
      <span class="footer-copy">Open source &middot; MIT License</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border-color);
    background: var(--bg);
    transition: background var(--duration-normal) var(--ease);
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
    padding-top: 3.5rem;
    padding-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    max-width: 18rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--fg);
    text-decoration: none;
    background: linear-gradient(135deg, var(--fg) 30%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--muted-fg);
    margin: 0;
  }

  .footer-columns {
    display: flex;
    gap: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    min-width: 8rem;
  }

  .footer-column-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg);
    margin: 0;
  }

  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .footer-link:hover {
    color: var(--fg);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-block: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--muted-fg);
  }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

---
const year = new Date().getFullYear();

const developerLinks = [
  { href: '/apps', label: 'App Store' },
  { href: '/arena', label: 'Arena' },
  { href: '/learn', label: 'Documentation' },
  { href: 'https://github.com/spike-land-ai/spike-land', label: 'GitHub' },
  { href: '/status', label: 'Status' },
];

const companyLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: 'mailto:hello@spike.land', label: 'Contact' },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---

<footer class="site-footer">
  <div class="rubik-container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">spike.land</a>
        <p class="footer-tagline">
          Open-source AI development platform. 80+ MCP tools, 26 personas, built for developers.
        </p>
      </div>

      <div class="footer-columns">
        <div class="footer-column">
          <h4 class="footer-column-title">Developers</h4>
          <nav class="footer-col-links" aria-label="Developer navigation">
            {developerLinks.map(link => (
              <a href={link.href} class="footer-link" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4 class="footer-column-title">Company</h4>
          <nav class="footer-col-links" aria-label="Company navigation">
            {companyLinks.map(link => (
              <a href={link.href} class="footer-link">{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4 class="footer-column-title">Legal</h4>
          <nav class="footer-col-links" aria-label="Legal navigation">
            {legalLinks.map(link => (
              <a href={link.href} class="footer-link">{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column footer-subscribe">
          <h4 class="footer-column-title">Stay updated</h4>
          <p class="footer-subscribe-text">Get developer updates, new tools, and platform news.</p>
          <form class="footer-subscribe-form" action="/api/subscribe" method="POST" data-subscribe-form>
            <input
              type="email"
              name="email"
              placeholder="you@example.com"
              required
              class="footer-subscribe-input"
              aria-label="Email address"
            />
            <button type="submit" class="footer-subscribe-btn">Subscribe</button>
          </form>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; {year} spike.land. All rights reserved.</span>
      <span class="footer-copy">Open source &middot; MIT License</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border-color);
    background: var(--bg);
    transition: background var(--duration-normal) var(--ease);
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
    padding-top: 3.5rem;
    padding-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 20rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--fg);
    text-decoration: none;
    background: linear-gradient(135deg, var(--fg) 30%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--muted-fg);
    margin: 0;
    line-height: 1.6;
  }

  .footer-columns {
    display: flex;
    gap: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    min-width: 8rem;
  }

  .footer-subscribe {
    min-width: 14rem;
    max-width: 18rem;
  }

  .footer-column-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg);
    margin: 0;
  }

  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .footer-link:hover {
    color: var(--fg);
  }

  .footer-subscribe-text {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    margin: 0;
    line-height: 1.5;
  }

  .footer-subscribe-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .footer-subscribe-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--fg);
    font-size: 0.8125rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease);
  }

  .footer-subscribe-input::placeholder {
    color: var(--muted-fg);
  }

  .footer-subscribe-input:focus {
    border-color: var(--primary-color);
  }

  .footer-subscribe-btn {
    padding: 0.5rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border: none;
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: filter var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .footer-subscribe-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-block: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--muted-fg);
  }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-subscribe { max-width: 100%; }
  }
</style>

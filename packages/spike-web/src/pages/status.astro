---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
---

<Layout
  title="Status — spike.land"
  description="Live service health dashboard for the spike.land platform."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav />

    <main id="main-content" class="status-main">
      <div class="rubik-container">
        <header class="status-header">
          <p class="rubik-eyebrow">Platform Health</p>
          <h1 class="status-title">spike.land Status</h1>
          <p class="rubik-lede">Real-time service health checks. Auto-refreshes every 60 seconds.</p>
        </header>

        <div class="reliability-banner" id="reliability-banner">
          <span class="reliability-label">RELIABILITY</span>
          <span class="reliability-value" id="reliability-value">--</span>
        </div>

        <div class="status-grid" id="status-grid">
          <!-- Populated by client-side JS -->
        </div>

        <p class="status-meta" id="status-meta">Checking...</p>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script is:inline>
  (function () {
    const ENDPOINTS = [
      { name: 'Health', url: '/health', description: 'Core platform health' },
      { name: 'API Health', url: '/api/health', description: 'Edge API service' },
      { name: 'Store Apps', url: '/api/apps', description: 'App store catalogue' },
      { name: 'LearnIt API', url: '/api/learnit', description: 'Learning platform API' },
      { name: 'Transpiler', url: 'https://esbuild.spikeland.workers.dev', description: 'esbuild-wasm compilation service', external: true },
    ];

    var grid = document.getElementById('status-grid');
    var banner = document.getElementById('reliability-value');
    var meta = document.getElementById('status-meta');
    var reliabilityBanner = document.getElementById('reliability-banner');

    function createCard(endpoint) {
      var card = document.createElement('div');
      card.className = 'status-card';
      card.id = 'card-' + endpoint.name.replace(/\s+/g, '-').toLowerCase();
      card.innerHTML =
        '<div class="status-indicator checking"></div>' +
        '<div class="status-info">' +
          '<h2 class="status-name">' + endpoint.name + '</h2>' +
          '<p class="status-desc">' + endpoint.description + '</p>' +
          '<p class="status-url">' + endpoint.url + '</p>' +
          '<p class="status-detail">Checking...</p>' +
        '</div>';
      return card;
    }

    // Build initial cards
    ENDPOINTS.forEach(function (ep) {
      grid.appendChild(createCard(ep));
    });

    async function checkEndpoint(endpoint) {
      var cardId = 'card-' + endpoint.name.replace(/\s+/g, '-').toLowerCase();
      var card = document.getElementById(cardId);
      var indicator = card.querySelector('.status-indicator');
      var detail = card.querySelector('.status-detail');

      indicator.className = 'status-indicator checking';
      detail.textContent = 'Checking...';

      var start = Date.now();
      try {
        var controller = new AbortController();
        var timeout = setTimeout(function () { controller.abort(); }, 10000);

        var opts = { method: 'GET', signal: controller.signal };
        if (endpoint.external) {
          opts.mode = 'no-cors';
        }

        var response = await fetch(endpoint.url, opts);
        clearTimeout(timeout);

        var elapsed = Date.now() - start;

        if (endpoint.external) {
          // no-cors returns opaque response; type 'opaque' means it reached the server
          indicator.className = 'status-indicator up';
          detail.textContent = 'Reachable (' + elapsed + 'ms)';
          return true;
        }

        if (response.ok) {
          indicator.className = 'status-indicator up';
          detail.textContent = 'HTTP ' + response.status + ' (' + elapsed + 'ms)';
          return true;
        } else {
          indicator.className = 'status-indicator down';
          detail.textContent = 'HTTP ' + response.status + ' (' + elapsed + 'ms)';
          return false;
        }
      } catch (err) {
        var elapsed2 = Date.now() - start;
        if (endpoint.external) {
          // no-cors fetch may throw on some browsers but still be reachable
          indicator.className = 'status-indicator unknown';
          detail.textContent = 'Could not verify (' + elapsed2 + 'ms)';
          return false;
        }
        indicator.className = 'status-indicator down';
        detail.textContent = err.name === 'AbortError' ? 'Timeout' : 'Connection failed';
        return false;
      }
    }

    async function runChecks() {
      meta.textContent = 'Checking...';
      var results = await Promise.all(ENDPOINTS.map(checkEndpoint));
      var passing = results.filter(Boolean).length;
      var total = results.length;

      banner.textContent = passing + ' / ' + total;
      reliabilityBanner.className = 'reliability-banner ' + (passing === total ? 'all-good' : 'has-issues');

      var now = new Date();
      meta.textContent = 'Last checked: ' + now.toLocaleTimeString() + ' — Next check in 60s';
    }

    runChecks();
    setInterval(runChecks, 60000);
  })();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .status-main {
    flex: 1;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .status-header {
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .status-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0;
  }

  .reliability-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
  }

  .reliability-banner.all-good {
    border-color: #22c55e40;
    background: #22c55e08;
  }

  .reliability-banner.has-issues {
    border-color: #ef444440;
    background: #ef444408;
  }

  .reliability-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-fg);
  }

  .reliability-value {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: var(--font-display);
    color: var(--fg);
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .status-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.375rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    background: var(--card-bg);
  }

  .status-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .status-indicator.up { background: #22c55e; box-shadow: 0 0 6px #22c55e80; }
  .status-indicator.down { background: #ef4444; box-shadow: 0 0 6px #ef444480; }
  .status-indicator.checking { background: #a3a3a3; animation: pulse 1s infinite; }
  .status-indicator.unknown { background: #f59e0b; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-info { flex: 1; min-width: 0; }

  .status-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0;
  }

  .status-desc {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    margin: 0.25rem 0 0;
  }

  .status-url {
    font-size: 0.7rem;
    color: var(--muted-fg);
    font-family: monospace;
    margin: 0.375rem 0 0;
    opacity: 0.7;
  }

  .status-detail {
    font-size: 0.75rem;
    color: var(--muted-fg);
    margin: 0.375rem 0 0;
    font-weight: 600;
  }

  .status-meta {
    font-size: 0.75rem;
    color: var(--muted-fg);
    text-align: center;
  }
</style>

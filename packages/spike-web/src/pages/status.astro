---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
---

<Layout
  title="Status — spike.land"
  description="Live service health dashboard for the spike.land platform."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav />

    <main id="main-content" class="status-main">
      <div class="rubik-container">
        <header class="status-header">
          <p class="rubik-eyebrow">Platform Health</p>
          <h1 class="status-title">spike.land Status</h1>
          <p class="rubik-lede">Real-time service health checks. Auto-refreshes every 60 seconds.</p>
        </header>

        <div class="reliability-banner" id="reliability-banner">
          <span class="reliability-label">RELIABILITY</span>
          <span class="reliability-value" id="reliability-value">--</span>
        </div>

        <!-- 90-day uptime timeline -->
        <div class="timeline-section">
          <div class="timeline-header">
            <span class="timeline-uptime" id="timeline-uptime">--% uptime</span>
            <span class="timeline-range">90 days</span>
          </div>
          <div class="timeline-bar" id="timeline-bar">
            <!-- Populated by JS -->
          </div>
          <div class="timeline-labels">
            <span>90 days ago</span>
            <span>Today</span>
          </div>
        </div>

        <div class="status-grid" id="status-grid">
          <!-- Populated by client-side JS -->
        </div>

        <p class="status-meta" id="status-meta">Checking...</p>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script is:inline>
  (function () {
    const ENDPOINTS = [
      { name: 'Health', url: '/health', description: 'Core platform health' },
      { name: 'API Health', url: '/api/health', description: 'Edge API service' },
      { name: 'Store Apps', url: '/api/apps', description: 'App store catalogue' },
      { name: 'LearnIt API', url: '/api/learnit', description: 'Learning platform API' },
      { name: 'Transpiler', url: 'https://esbuild.spikeland.workers.dev', description: 'esbuild-wasm compilation service', external: true },
    ];

    var grid = document.getElementById('status-grid');
    var banner = document.getElementById('reliability-value');
    var meta = document.getElementById('status-meta');
    var reliabilityBanner = document.getElementById('reliability-banner');

    function createCard(endpoint) {
      var card = document.createElement('div');
      card.className = 'status-card';
      card.id = 'card-' + endpoint.name.replace(/\s+/g, '-').toLowerCase();
      card.innerHTML =
        '<div class="status-indicator checking"></div>' +
        '<div class="status-info">' +
          '<h2 class="status-name">' + endpoint.name + '</h2>' +
          '<p class="status-desc">' + endpoint.description + '</p>' +
          '<p class="status-url">' + endpoint.url + '</p>' +
          '<p class="status-detail">Checking...</p>' +
        '</div>';
      return card;
    }

    // Build initial cards
    ENDPOINTS.forEach(function (ep) {
      grid.appendChild(createCard(ep));
    });

    async function checkEndpoint(endpoint) {
      var cardId = 'card-' + endpoint.name.replace(/\s+/g, '-').toLowerCase();
      var card = document.getElementById(cardId);
      var indicator = card.querySelector('.status-indicator');
      var detail = card.querySelector('.status-detail');

      indicator.className = 'status-indicator checking';
      detail.textContent = 'Checking...';

      var start = Date.now();
      try {
        var controller = new AbortController();
        var timeout = setTimeout(function () { controller.abort(); }, 10000);

        var opts = { method: 'GET', signal: controller.signal };
        if (endpoint.external) {
          opts.mode = 'no-cors';
        }

        var response = await fetch(endpoint.url, opts);
        clearTimeout(timeout);

        var elapsed = Date.now() - start;

        if (endpoint.external) {
          // no-cors returns opaque response; type 'opaque' means it reached the server
          indicator.className = 'status-indicator up';
          detail.textContent = 'Reachable (' + elapsed + 'ms)';
          return true;
        }

        if (response.ok) {
          indicator.className = 'status-indicator up';
          detail.textContent = 'HTTP ' + response.status + ' (' + elapsed + 'ms)';
          return true;
        } else {
          indicator.className = 'status-indicator down';
          detail.textContent = 'HTTP ' + response.status + ' (' + elapsed + 'ms)';
          return false;
        }
      } catch (err) {
        var elapsed2 = Date.now() - start;
        if (endpoint.external) {
          // no-cors fetch may throw on some browsers but still be reachable
          indicator.className = 'status-indicator unknown';
          detail.textContent = 'Could not verify (' + elapsed2 + 'ms)';
          return false;
        }
        indicator.className = 'status-indicator down';
        detail.textContent = err.name === 'AbortError' ? 'Timeout' : 'Connection failed';
        return false;
      }
    }

    async function runChecks() {
      meta.textContent = 'Checking...';
      var results = await Promise.all(ENDPOINTS.map(checkEndpoint));
      var passing = results.filter(Boolean).length;
      var total = results.length;

      banner.textContent = passing + ' / ' + total;
      reliabilityBanner.className = 'reliability-banner ' + (passing === total ? 'all-good' : 'has-issues');

      var now = new Date();
      meta.textContent = 'Last checked: ' + now.toLocaleTimeString() + ' — Next check in 60s';
    }

    // ─── 90-day timeline ───────────────────────────────────────────────
    var TIMELINE_KEY = 'spike_status_history';
    var timelineBar = document.getElementById('timeline-bar');
    var timelineUptime = document.getElementById('timeline-uptime');

    function getDateKey(daysAgo) {
      var d = new Date();
      d.setDate(d.getDate() - daysAgo);
      return d.toISOString().slice(0, 10);
    }

    function loadHistory() {
      try {
        var raw = localStorage.getItem(TIMELINE_KEY);
        return raw ? JSON.parse(raw) : {};
      } catch { return {}; }
    }

    function saveHistory(history) {
      try {
        // Keep only last 95 days to prevent unbounded growth
        var cutoff = getDateKey(95);
        var cleaned = {};
        for (var key in history) {
          if (key >= cutoff) cleaned[key] = history[key];
        }
        localStorage.setItem(TIMELINE_KEY, JSON.stringify(cleaned));
      } catch {}
    }

    function recordToday(allUp) {
      var history = loadHistory();
      var today = getDateKey(0);
      // If already recorded as 'down', keep it (worst-case wins)
      if (history[today] === 'down') return;
      history[today] = allUp ? 'up' : 'down';
      saveHistory(history);
    }

    function renderTimeline() {
      var history = loadHistory();
      timelineBar.innerHTML = '';
      var upDays = 0;
      var totalKnown = 0;

      for (var i = 89; i >= 0; i--) {
        var dateKey = getDateKey(i);
        var status = history[dateKey] || 'unknown';
        var day = document.createElement('div');
        day.className = 'timeline-day ' + status;

        var tooltip = document.createElement('span');
        tooltip.className = 'timeline-tooltip';
        var label = status === 'up' ? 'All systems operational' : status === 'down' ? 'Issues detected' : 'No data';
        tooltip.textContent = dateKey + ' — ' + label;
        day.appendChild(tooltip);

        timelineBar.appendChild(day);

        if (status !== 'unknown') {
          totalKnown++;
          if (status === 'up') upDays++;
        }
      }

      var pct = totalKnown > 0 ? ((upDays / totalKnown) * 100).toFixed(1) : '--';
      timelineUptime.textContent = pct + '% uptime';
    }

    // Hook into the existing runChecks to record results
    var _origRunChecks = runChecks;
    runChecks = async function() {
      await _origRunChecks();
      // Read results from the DOM
      var indicators = document.querySelectorAll('.status-indicator');
      var allUp = true;
      indicators.forEach(function(ind) {
        if (ind.classList.contains('down')) allUp = false;
      });
      recordToday(allUp);
      renderTimeline();
    };

    renderTimeline();

    runChecks();
    setInterval(runChecks, 60000);
  })();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .status-main {
    flex: 1;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .status-header {
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .status-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0;
  }

  .reliability-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
  }

  .reliability-banner.all-good {
    border-color: #22c55e40;
    background: #22c55e08;
  }

  .reliability-banner.has-issues {
    border-color: #ef444440;
    background: #ef444408;
  }

  .reliability-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-fg);
  }

  .reliability-value {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: var(--font-display);
    color: var(--fg);
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .status-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.375rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    background: var(--card-bg);
  }

  .status-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .status-indicator.up { background: #22c55e; box-shadow: 0 0 6px #22c55e80; }
  .status-indicator.down { background: #ef4444; box-shadow: 0 0 6px #ef444480; }
  .status-indicator.checking { background: #a3a3a3; animation: pulse 1s infinite; }
  .status-indicator.unknown { background: #f59e0b; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-info { flex: 1; min-width: 0; }

  .status-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0;
  }

  .status-desc {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    margin: 0.25rem 0 0;
  }

  .status-url {
    font-size: 0.7rem;
    color: var(--muted-fg);
    font-family: monospace;
    margin: 0.375rem 0 0;
    opacity: 0.7;
  }

  .status-detail {
    font-size: 0.75rem;
    color: var(--muted-fg);
    margin: 0.375rem 0 0;
    font-weight: 600;
  }

  .status-meta {
    font-size: 0.75rem;
    color: var(--muted-fg);
    text-align: center;
  }

  /* 90-day timeline */
  .timeline-section {
    margin-bottom: 1.5rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    background: var(--card-bg);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .timeline-uptime {
    font-size: 1.125rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--fg);
  }

  .timeline-range {
    font-size: 0.75rem;
    color: var(--muted-fg);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-bar {
    display: flex;
    gap: 2px;
    height: 32px;
    align-items: stretch;
  }

  .timeline-day {
    flex: 1;
    min-width: 0;
    border-radius: 2px;
    cursor: pointer;
    position: relative;
    transition: opacity 0.15s;
  }

  .timeline-day:hover { opacity: 0.8; }
  .timeline-day.up { background: #22c55e; }
  .timeline-day.down { background: #ef4444; }
  .timeline-day.partial { background: #f59e0b; }
  .timeline-day.unknown { background: color-mix(in srgb, var(--muted-fg) 20%, transparent); }

  .timeline-day .timeline-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--fg);
    color: var(--bg);
    font-size: 0.6875rem;
    padding: 0.375rem 0.625rem;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .timeline-day:hover .timeline-tooltip { display: block; }

  .timeline-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.375rem;
    font-size: 0.6875rem;
    color: var(--muted-fg);
  }

  @media (max-width: 640px) {
    .timeline-day:nth-child(-n+60) { display: none; }
  }
</style>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter(post => !post.data.draft && !post.data.unlisted)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = [...new Set(publishedPosts.map(p => p.data.category).filter(Boolean))];
const featuredPost = publishedPosts[0];
const remainingPosts = publishedPosts.slice(1);
---

<Layout
  title="AI Engineering Blog - spike.land"
  description="Articles and deep dives on AI agents, MCP tools, edge computing, and modern software engineering from the spike.land team."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/blog" />

    <main class="blog-main">
      <!-- Header -->
      <section class="blog-header">
        <div class="rubik-container blog-header-inner">
          <p class="rubik-eyebrow">Journal</p>
          <h1 class="blog-title">AI Engineering Blog</h1>
          <p class="rubik-lede">Thoughts on AI agents, modern engineering, and building spike.land.</p>

          {categories.length > 0 && (
            <div class="category-chips">
              <a href="/blog" class="rubik-chip chip-active">All</a>
              {categories.map(cat => (
                <a href={`/blog?category=${cat}`} class="rubik-chip">{cat}</a>
              ))}
            </div>
          )}
        </div>
      </section>

      <div class="rubik-container posts-container">
        <!-- Featured post -->
        {featuredPost && (
          <a href={`/blog/${featuredPost.id}`} class="featured-post rubik-panel">
            {featuredPost.data.heroImage && (
              <div class="featured-image-wrap">
                <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="featured-image" loading="eager" />
              </div>
            )}
            <div class="featured-content">
              <div class="post-meta">
                <time datetime={featuredPost.data.date.toISOString()} class="post-date">
                  {featuredPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {featuredPost.data.category && (
                  <span class="rubik-chip">{featuredPost.data.category}</span>
                )}
                <span class="featured-badge">Featured</span>
              </div>
              <h2 class="featured-title">{featuredPost.data.title}</h2>
              {featuredPost.data.description && (
                <p class="featured-desc">{featuredPost.data.description}</p>
              )}
              <span class="read-more">
                Read article
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        )}

        <!-- Post grid -->
        {remainingPosts.length > 0 && (
          <div class="posts-grid">
            {remainingPosts.map(post => (
              <a href={`/blog/${post.id}`} class="post-card rubik-panel">
                {post.data.heroImage && (
                  <div class="card-image-wrap">
                    <img src={post.data.heroImage} alt={post.data.title} class="card-image" loading="lazy" />
                  </div>
                )}
                <div class="card-content">
                  <div class="post-meta">
                    <time datetime={post.data.date.toISOString()} class="post-date">
                      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    {post.data.category && (
                      <span class="rubik-chip">{post.data.category}</span>
                    )}
                  </div>
                  <h2 class="card-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="card-desc">{post.data.description}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .blog-main { flex: 1; }

  .blog-header {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border-color);
    background:
      radial-gradient(ellipse 60% 50% at 20% 0%, oklch(from var(--primary-color) l c h / 0.06), transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 20%, oklch(from var(--accent-violet) l c h / 0.04), transparent 70%),
      var(--bg);
  }

  .blog-header-inner {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .blog-title { max-width: 20ch; }

  .category-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .chip-active {
    background: color-mix(in srgb, var(--primary-color) 20%, transparent);
    border-color: color-mix(in srgb, var(--primary-color) 40%, transparent);
  }

  .posts-container {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Featured post */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    padding: 0;
  }

  @media (max-width: 768px) {
    .featured-post { grid-template-columns: 1fr; }
  }

  .featured-image-wrap {
    overflow: hidden;
    aspect-ratio: 16/10;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease);
  }

  .featured-post:hover .featured-image { transform: scale(1.04); }
  .featured-post:hover { transform: translateY(-3px); box-shadow: var(--shadow-xl); }

  .featured-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--muted-fg);
  }

  .featured-badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary-color);
    background: color-mix(in srgb, var(--primary-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary-color) 20%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }

  .featured-title {
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
    transition: color var(--duration-fast) var(--ease);
  }

  .featured-post:hover .featured-title { color: var(--primary-color); }

  .featured-desc {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-top: 0.5rem;
    transition: gap var(--duration-fast) var(--ease);
  }

  .featured-post:hover .read-more { gap: 0.625rem; }

  /* Post grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.25rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    padding: 0;
    transition: box-shadow var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--primary-color) 30%, transparent);
  }

  .card-image-wrap {
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease);
  }

  .post-card:hover .card-image { transform: scale(1.04); }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0;
    color: var(--fg);
    transition: color var(--duration-fast) var(--ease);
  }

  .post-card:hover .card-title { color: var(--primary-color); }

  .card-desc {
    font-size: 0.9rem;
    color: var(--muted-fg);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

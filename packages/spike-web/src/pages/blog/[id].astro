---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import Whisper from '../../components/typography/Whisper.astro';
import Crescendo from '../../components/typography/Crescendo.astro';
import ScrollWeight from '../../components/typography/ScrollWeight.astro';
import GlitchText from '../../components/typography/GlitchText.astro';

// Auto-imported MDX Components
import AgentCoordinationDemo from '../../components/mdx/AgentCoordinationDemo.astro';
import AgentLoopDemo from '../../components/mdx/AgentLoopDemo.astro';
import AttentionSpotlightDemo from '../../components/mdx/AttentionSpotlightDemo.astro';
import AudioPlayer from '../../components/mdx/AudioPlayer.astro';
import BayesianConfidenceDemo from '../../components/mdx/BayesianConfidenceDemo.astro';
import BlogPoll from '../../components/mdx/BlogPoll.astro';
import CacheAwareBuildGraphDemo from '../../components/mdx/CacheAwareBuildGraphDemo.astro';
import Callout from '../../components/mdx/Callout.astro';
import CodeCategorizerQuiz from '../../components/mdx/CodeCategorizerQuiz.astro';
import ContextWindowDesignDemo from '../../components/mdx/ContextWindowDesignDemo.astro';
import ConvergenceDemo from '../../components/mdx/ConvergenceDemo.astro';
import CTAButton from '../../components/mdx/CTAButton.astro';
import DarwinianTreeDemo from '../../components/mdx/DarwinianTreeDemo.astro';
import DependencyCascadeDemo from '../../components/mdx/DependencyCascadeDemo.astro';
import FiveLayerStackDemo from '../../components/mdx/FiveLayerStackDemo.astro';
import FocusedContextDemo from '../../components/mdx/FocusedContextDemo.astro';
import HourglassModelDemo from '../../components/mdx/HourglassModelDemo.astro';
import LiveCategorizer from '../../components/mdx/LiveCategorizer.astro';
import MCPFlowDiagram from '../../components/mdx/MCPFlowDiagram.astro';
import ModelCascadeDemo from '../../components/mdx/ModelCascadeDemo.astro';
import MonolithAntiPatternDemo from '../../components/mdx/MonolithAntiPatternDemo.astro';
import MultiStageBuildDemo from '../../components/mdx/MultiStageBuildDemo.astro';
import ParadigmGuiltTimeline from '../../components/mdx/ParadigmGuiltTimeline.astro';
import PersonaLandingPreview from '../../components/mdx/PersonaLandingPreview.astro';
import PersonalizedSupportBoxAstro from '../../components/mdx/PersonalizedSupportBox.astro';
import { PersonalizedSupportBox as PersonalizedSupportBoxReact } from '../../../../../src/core/block-website/ui/PersonalizedSupportBox';
import PersonaSwitcher from '../../components/mdx/PersonaSwitcher.astro';
import PerspectiveCarousel from '../../components/mdx/PerspectiveCarousel.astro';
import PollAnalyticsDashboard from '../../components/mdx/PollAnalyticsDashboard.astro';
import PracticalRulesDemo from '../../components/mdx/PracticalRulesDemo.astro';
import PrefixInvalidationDemo from '../../components/mdx/PrefixInvalidationDemo.astro';
import PyramidReshapeDemo from '../../components/mdx/PyramidReshapeDemo.astro';
import RecursiveZoomDemo from '../../components/mdx/RecursiveZoomDemo.astro';
import RentStoryToggle from '../../components/mdx/RentStoryToggle.astro';
import ScrollStoryCard from '../../components/mdx/ScrollStoryCard.astro';
import SharedOptimizationProblemDemo from '../../components/mdx/SharedOptimizationProblemDemo.astro';
import SpikeChatEmbed from '../../components/mdx/SpikeChatEmbed.astro';
import SpikeCliDemo from '../../components/mdx/SpikeCliDemo.astro';
import SplitScreenDemo from '../../components/mdx/SplitScreenDemo.astro';
import StackCollapseDemo from '../../components/mdx/StackCollapseDemo.astro';
import TestCodeNameVenn from '../../components/mdx/TestCodeNameVenn.astro';
import Tldr from '../../components/mdx/Tldr.astro';
import ToolCount from '../../components/mdx/ToolCount.astro';
import ToolsByCategoryGrid from '../../components/mdx/ToolsByCategoryGrid.astro';
import OpenAIEndpointDemo from '../../components/mdx/OpenAIEndpointDemo.astro';

const MDX_COMPONENTS = {
    whisper: Whisper,
    crescendo: Crescendo,
    scrollweight: ScrollWeight,
    glitchtext: GlitchText,
    AgentCoordinationDemo,
    AgentLoopDemo,
    AttentionSpotlightDemo,
    AudioPlayer,
    BayesianConfidenceDemo,
    BlogPoll,
    CacheAwareBuildGraphDemo,
    Callout,
    CodeCategorizerQuiz,
    ContextWindowDesignDemo,
    ConvergenceDemo,
    CTAButton,
    DarwinianTreeDemo,
    DependencyCascadeDemo,
    FiveLayerStackDemo,
    FocusedContextDemo,
    HourglassModelDemo,
    LiveCategorizer,
    MCPFlowDiagram,
    ModelCascadeDemo,
    MonolithAntiPatternDemo,
    MultiStageBuildDemo,
    ParadigmGuiltTimeline,
    PersonaLandingPreview,
    PersonalizedSupportBox: PersonalizedSupportBoxAstro,
    PersonaSwitcher,
    PerspectiveCarousel,
    PollAnalyticsDashboard,
    PracticalRulesDemo,
    PrefixInvalidationDemo,
    PyramidReshapeDemo,
    RecursiveZoomDemo,
    RentStoryToggle,
    ScrollStoryCard,
    SharedOptimizationProblemDemo,
    SpikeChatEmbed,
    SpikeCliDemo,
    SplitScreenDemo,
    StackCollapseDemo,
    TestCodeNameVenn,
    Tldr,
    ToolCount,
    ToolsByCategoryGrid,
    OpenAIEndpointDemo
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ArticleLayout
  title={`${post.data.title} - spike.land`}
  description={post.data.description ?? 'Read this article on spike.land.'}
  ogImage={post.data.heroImage ?? '/android-chrome-512x512.png'}
  noindex={post.data.unlisted}
>
  <Analytics slot="head" />
  {post.data.heroImage && <link slot="head" rel="preload" as="image" href={post.data.heroImage} fetchpriority="high" />}
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description ?? "",
    image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site ?? Astro.url.origin).href : undefined,
    datePublished: post.data.date.toISOString(),
    author: { "@type": "Person", name: post.data.author ?? "spike.land" },
    publisher: { "@type": "Organization", name: "spike.land", url: "https://spike.land" },
    url: Astro.url.href,
    ...(post.data.tags ? { keywords: post.data.tags.join(", ") } : {}),
  })} />
  <meta slot="head" property="article:published_time" content={post.data.date.toISOString()} />
  {post.data.author && <meta slot="head" property="article:author" content={post.data.author} />}
  {post.data.tags?.map(tag => <meta slot="head" property="article:tag" content={tag} />)}

  <Nav activePath="/blog" />

  <!-- Hero header -->
  <header class="space-y-5 my-8">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All articles
    </a>

    <div class="flex items-center gap-2.5 flex-wrap text-sm text-muted-foreground">
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.author && <span class="small-caps">· {post.data.author}</span>}
      {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
    </div>

    <h1 class="font-black tracking-tight leading-tight max-w-[22ch]" style="font-size: clamp(1.75rem, 4vw, 3rem);">{post.data.title}</h1>

    {post.data.description && (
      <p class="text-muted-foreground max-w-[56ch]" style="font-size: clamp(1rem, 1.5vw + 0.5rem, 1.25rem); line-height: 1.65;">{post.data.description}</p>
    )}
  </header>

  {post.data.heroImage && (
    <div class="my-6">
      <div class="rounded-xl overflow-hidden border border-border shadow-lg">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          width="1200"
          height="630"
          class="w-full h-auto block max-h-[28rem] object-cover"
          loading="eager"
        />
      </div>
    </div>
  )}

  <!-- Article content -->
  <div class="space-y-4 my-8">
    <article class="prose prose-p:font-sans prose-headings:font-display prose-headings:font-bold prose-p:leading-loose max-w-none">
      <Content components={MDX_COMPONENTS} />
    </article>

  </div>

  <!-- Support CTA — fistbump + donate + social sharing -->
  <div class="not-prose my-12">
    <PersonalizedSupportBoxReact client:visible />
  </div>

  <Footer />
  <CookieConsent />
</ArticleLayout>

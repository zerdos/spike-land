---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
import Whisper from '../../components/typography/Whisper.astro';
import Crescendo from '../../components/typography/Crescendo.astro';
import ScrollWeight from '../../components/typography/ScrollWeight.astro';
import GlitchText from '../../components/typography/GlitchText.astro';

// Auto-imported MDX Components
import AgentCoordinationDemo from '../../components/mdx/AgentCoordinationDemo.astro';
import AgentLoopDemo from '../../components/mdx/AgentLoopDemo.astro';
import AttentionSpotlightDemo from '../../components/mdx/AttentionSpotlightDemo.astro';
import AudioPlayer from '../../components/mdx/AudioPlayer.astro';
import BayesianConfidenceDemo from '../../components/mdx/BayesianConfidenceDemo.astro';
import BlogPoll from '../../components/mdx/BlogPoll.astro';
import CacheAwareBuildGraphDemo from '../../components/mdx/CacheAwareBuildGraphDemo.astro';
import Callout from '../../components/mdx/Callout.astro';
import CodeCategorizerQuiz from '../../components/mdx/CodeCategorizerQuiz.astro';
import ContextWindowDesignDemo from '../../components/mdx/ContextWindowDesignDemo.astro';
import ConvergenceDemo from '../../components/mdx/ConvergenceDemo.astro';
import CTAButton from '../../components/mdx/CTAButton.astro';
import DarwinianTreeDemo from '../../components/mdx/DarwinianTreeDemo.astro';
import DependencyCascadeDemo from '../../components/mdx/DependencyCascadeDemo.astro';
import FiveLayerStackDemo from '../../components/mdx/FiveLayerStackDemo.astro';
import FocusedContextDemo from '../../components/mdx/FocusedContextDemo.astro';
import HourglassModelDemo from '../../components/mdx/HourglassModelDemo.astro';
import LiveCategorizer from '../../components/mdx/LiveCategorizer.astro';
import MCPFlowDiagram from '../../components/mdx/MCPFlowDiagram.astro';
import ModelCascadeDemo from '../../components/mdx/ModelCascadeDemo.astro';
import MonolithAntiPatternDemo from '../../components/mdx/MonolithAntiPatternDemo.astro';
import MultiStageBuildDemo from '../../components/mdx/MultiStageBuildDemo.astro';
import ParadigmGuiltTimeline from '../../components/mdx/ParadigmGuiltTimeline.astro';
import PersonaLandingPreview from '../../components/mdx/PersonaLandingPreview.astro';
import PersonalizedSupportBoxAstro from '../../components/mdx/PersonalizedSupportBox.astro';
import { PersonalizedSupportBox as PersonalizedSupportBoxReact } from '../../../../../src/core/block-website/ui/PersonalizedSupportBox';
import PersonaSwitcher from '../../components/mdx/PersonaSwitcher.astro';
import PerspectiveCarousel from '../../components/mdx/PerspectiveCarousel.astro';
import PollAnalyticsDashboard from '../../components/mdx/PollAnalyticsDashboard.astro';
import PracticalRulesDemo from '../../components/mdx/PracticalRulesDemo.astro';
import PrefixInvalidationDemo from '../../components/mdx/PrefixInvalidationDemo.astro';
import PyramidReshapeDemo from '../../components/mdx/PyramidReshapeDemo.astro';
import RecursiveZoomDemo from '../../components/mdx/RecursiveZoomDemo.astro';
import RentStoryToggle from '../../components/mdx/RentStoryToggle.astro';
import ScrollStoryCard from '../../components/mdx/ScrollStoryCard.astro';
import SharedOptimizationProblemDemo from '../../components/mdx/SharedOptimizationProblemDemo.astro';
import SpikeChatEmbed from '../../components/mdx/SpikeChatEmbed.astro';
import SpikeCliDemo from '../../components/mdx/SpikeCliDemo.astro';
import SplitScreenDemo from '../../components/mdx/SplitScreenDemo.astro';
import StackCollapseDemo from '../../components/mdx/StackCollapseDemo.astro';
import TestCodeNameVenn from '../../components/mdx/TestCodeNameVenn.astro';
import Tldr from '../../components/mdx/Tldr.astro';
import ToolCount from '../../components/mdx/ToolCount.astro';
import ToolsByCategoryGrid from '../../components/mdx/ToolsByCategoryGrid.astro';
import OpenAIEndpointDemo from '../../components/mdx/OpenAIEndpointDemo.astro';

const MDX_COMPONENTS = {
    whisper: Whisper,
    crescendo: Crescendo,
    scrollweight: ScrollWeight,
    glitchtext: GlitchText,
    AgentCoordinationDemo,
    AgentLoopDemo,
    AttentionSpotlightDemo,
    AudioPlayer,
    BayesianConfidenceDemo,
    BlogPoll,
    CacheAwareBuildGraphDemo,
    Callout,
    CodeCategorizerQuiz,
    ContextWindowDesignDemo,
    ConvergenceDemo,
    CTAButton,
    DarwinianTreeDemo,
    DependencyCascadeDemo,
    FiveLayerStackDemo,
    FocusedContextDemo,
    HourglassModelDemo,
    LiveCategorizer,
    MCPFlowDiagram,
    ModelCascadeDemo,
    MonolithAntiPatternDemo,
    MultiStageBuildDemo,
    ParadigmGuiltTimeline,
    PersonaLandingPreview,
    PersonalizedSupportBox: PersonalizedSupportBoxAstro,
    PersonaSwitcher,
    PerspectiveCarousel,
    PollAnalyticsDashboard,
    PracticalRulesDemo,
    PrefixInvalidationDemo,
    PyramidReshapeDemo,
    RecursiveZoomDemo,
    RentStoryToggle,
    ScrollStoryCard,
    SharedOptimizationProblemDemo,
    SpikeChatEmbed,
    SpikeCliDemo,
    SplitScreenDemo,
    StackCollapseDemo,
    TestCodeNameVenn,
    Tldr,
    ToolCount,
    ToolsByCategoryGrid,
    OpenAIEndpointDemo
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ArticleLayout
  title={`${post.data.title} - spike.land`}
  description={post.data.description ?? 'Read this article on spike.land.'}
  ogImage={post.data.heroImage ?? '/android-chrome-512x512.png'}
  noindex={post.data.unlisted}
>
  <Analytics slot="head" />
  {post.data.heroImage && <link slot="head" rel="preload" as="image" href={post.data.heroImage} fetchpriority="high" />}
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description ?? "",
    image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site ?? Astro.url.origin).href : undefined,
    datePublished: post.data.date.toISOString(),
    author: { "@type": "Person", name: post.data.author ?? "spike.land" },
    publisher: { "@type": "Organization", name: "spike.land", url: "https://spike.land" },
    url: Astro.url.href,
    ...(post.data.tags ? { keywords: post.data.tags.join(", ") } : {}),
  })} />
  <meta slot="head" property="article:published_time" content={post.data.date.toISOString()} />
  {post.data.author && <meta slot="head" property="article:author" content={post.data.author} />}
  {post.data.tags?.map(tag => <meta slot="head" property="article:tag" content={tag} />)}

  <Nav slot="nav" activePath="/blog" />

  <!-- Hero header -->
  <header class="article-header">
    <a href="/blog" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All articles
    </a>

    <div class="article-meta">
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.author && <span class="small-caps">· {post.data.author}</span>}
      {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
    </div>

    <h1 class="article-title">{post.data.title}</h1>

    {post.data.description && (
      <p class="article-description">{post.data.description}</p>
    )}
  </header>

  {post.data.heroImage && (
    <div class="article-hero-wrap">
      <div class="article-hero-frame">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          width="1200"
          height="630"
          class="article-hero-img"
          loading="eager"
        />
      </div>
    </div>
  )}

  <!-- Article content -->
  <div class="article-content">
    <article class="prose prose-p:font-sans prose-headings:font-display prose-headings:font-bold prose-p:leading-loose max-w-none">
      <Content components={MDX_COMPONENTS} />
    </article>
  </div>

  <!-- Support CTA -->
  <div class="not-prose" style="margin-block: 4rem 2rem;">
    <PersonalizedSupportBoxReact client:only="react" />
  </div>

  <Footer slot="footer" />

  <!-- Auto-translation loader: detects browser language, fetches translation from API -->
  <script define:vars={{ slug: post.id }}>
    (function() {
      const SUPPORTED = ['hu','de','ru','it','es','zh','fr','ja'];
      const LANG_NAMES = {hu:'Magyar',de:'Deutsch',ru:'Русский',it:'Italiano',es:'Español',zh:'中文',fr:'Français',ja:'日本語'};

      // Check URL param first, then browser language
      const params = new URLSearchParams(location.search);
      const urlLang = params.get('lang');
      const browserLang = (navigator.language || '').split('-')[0].toLowerCase();
      const lang = SUPPORTED.includes(urlLang) ? urlLang : SUPPORTED.includes(browserLang) ? browserLang : null;
      if (!lang) return;

      const article = document.querySelector('.article-content article');
      const titleEl = document.querySelector('.article-title');
      const descEl = document.querySelector('.article-description');
      if (!article) return;

      // Create language bar (hidden until translation loads)
      const bar = document.createElement('div');
      bar.className = 'lang-bar';
      bar.style.cssText = 'display:none;padding:0.75rem 1rem;background:var(--surface-2,#f5f5f5);border-radius:var(--radius-lg,0.75rem);margin-bottom:1.5rem;font-size:0.875rem;color:var(--muted-fg,#666);display:flex;align-items:center;justify-content:space-between;gap:0.5rem';
      const header = document.querySelector('.article-header');
      if (header) header.after(bar);

      fetch('/api/blog/' + slug + '?lang=' + lang)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data || data.lang === 'en' || !data.content) return;

          // Show language bar
          bar.style.display = 'flex';
          bar.innerHTML = '<span>' + (LANG_NAMES[lang] || lang) + ' fordítás</span><a href="?lang=en" style="color:var(--accent,#0066cc);text-decoration:none;font-weight:500">English &rarr;</a>';

          // Replace title if translated
          if (data.title && titleEl) titleEl.textContent = data.title;
          if (data.description && descEl) descEl.textContent = data.description;

          // Convert markdown content to HTML and replace
          const html = markdownToHtml(data.content);
          article.innerHTML = html;
        })
        .catch(() => {});

      function markdownToHtml(md) {
        let html = md.replace(/^---[\s\S]*?---\s*/, '');
        // Code blocks
        html = html.replace(/```[\w]*\n([\s\S]*?)```/g, '<pre><code>$1</code></pre>');
        // Headings
        html = html.replace(/^######\s+(.*)$/gm, '<h6>$1</h6>');
        html = html.replace(/^#####\s+(.*)$/gm, '<h5>$1</h5>');
        html = html.replace(/^####\s+(.*)$/gm, '<h4>$1</h4>');
        html = html.replace(/^###\s+(.*)$/gm, '<h3>$1</h3>');
        html = html.replace(/^##\s+(.*)$/gm, '<h2>$1</h2>');
        html = html.replace(/^#\s+(.*)$/gm, '<h1>$1</h1>');
        // HR
        html = html.replace(/^---+$/gm, '<hr>');
        // Bold & italic
        html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
        // Links
        html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        // Images
        html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img alt="$1" src="$2" />');
        // Inline code
        html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
        // Math blocks
        html = html.replace(/\$\$([^$]+)\$\$/g, '<p class="math-block">$$$$1$$</p>');
        // Inline math
        html = html.replace(/\$([^$]+)\$/g, '<span class="math-inline">$$$1$</span>');
        // Lists
        html = html.replace(/^\d+\.\s+(.*)$/gm, '<li>$1</li>');
        html = html.replace(/^[-*]\s+(.*)$/gm, '<li>$1</li>');
        // Wrap consecutive <li> in <ul>
        html = html.replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>');
        // Paragraphs for remaining lines
        html = html.replace(/^(?!<[hupol]|<li|<hr|<pre|<img|<ul|<div)(.+)$/gm, '<p>$1</p>');
        return html;
      }
    })();
  </script>

  <style>
    .article-header {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-block: 2.5rem 2rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.875rem;
      color: var(--muted-fg);
      text-decoration: none;
      transition: color var(--duration-fast) var(--ease),
                  gap var(--duration-fast) var(--ease);
    }
    .back-link:hover { color: var(--fg); gap: 0.5rem; }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      flex-wrap: wrap;
      font-size: 0.875rem;
      color: var(--muted-fg);
    }

    .article-title {
      font-size: clamp(1.875rem, 4.5vw, 3.25rem);
      font-weight: 900;
      letter-spacing: -0.035em;
      line-height: 1.08;
      max-width: 20ch;
    }

    .article-description {
      font-size: clamp(1.0625rem, 1.5vw + 0.5rem, 1.3125rem);
      line-height: 1.65;
      color: var(--muted-fg);
      max-width: 56ch;
      text-wrap: pretty;
      margin: 0;
    }

    .article-hero-wrap {
      margin-block: 1.5rem 2.5rem;
    }

    .article-hero-frame {
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-lg);
    }

    .article-hero-img {
      width: 100%;
      height: auto;
      display: block;
      max-height: 28rem;
      object-fit: cover;
    }

    .article-content {
      margin-block: 2rem 3rem;
    }

    .article-content .prose {
      --tw-prose-body: var(--fg);
      --tw-prose-headings: var(--fg);
    }

    .article-content .prose > * + * {
      margin-top: 1.25em;
    }

    .article-content .prose h2 {
      margin-top: 2.5em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border-color);
    }

    .article-content .prose h3 {
      margin-top: 2em;
    }

  </style>
</ArticleLayout>

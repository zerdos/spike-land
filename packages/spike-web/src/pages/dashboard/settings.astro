---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
---

<Layout
  title="Settings — spike.land"
  description="Manage your spike.land account settings, profile, and preferences."
  noindex={true}
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav />

    <main id="main-content" class="dash-main">
      <div class="rubik-container">
        <header class="dash-header">
          <h1 class="dash-title">Settings</h1>
          <p class="dash-sub" id="user-email">Loading…</p>
        </header>

        <div class="dash-layout">
          <aside class="dash-sidebar">
            <nav class="dash-nav" aria-label="Dashboard navigation">
              <a href="/dashboard" class="dash-nav-link">Overview</a>
              <a href="/settings" class="dash-nav-link dash-nav-link--active">Settings</a>
              <a href="/settings?tab=billing" class="dash-nav-link">Billing</a>
            </nav>
          </aside>

          <section class="dash-content">
            <!-- Auth gate (shown when not logged in) -->
            <div class="auth-gate" id="auth-gate" hidden>
              <p>Sign in to manage your settings.</p>
              <a href="/login?redirect=/dashboard/settings" class="auth-cta">Sign In</a>
            </div>

            <!-- Settings form (shown when logged in) -->
            <div id="settings-form" hidden>
              <div class="settings-section">
                <h2 class="section-title">Profile</h2>
                <div class="form-group">
                  <label class="form-label" for="display-name">Display Name</label>
                  <input type="text" id="display-name" class="form-input" placeholder="Your name" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">Email</label>
                  <input type="email" id="email" class="form-input" disabled />
                  <p class="form-hint">Email is managed through your OAuth provider.</p>
                </div>
              </div>

              <div class="settings-section">
                <h2 class="section-title">Preferences</h2>
                <div class="form-group">
                  <label class="form-label">Theme</label>
                  <div class="toggle-group">
                    <button class="toggle-btn" id="theme-light" data-theme="light">Light</button>
                    <button class="toggle-btn" id="theme-dark" data-theme="dark">Dark</button>
                    <button class="toggle-btn" id="theme-system" data-theme="system">System</button>
                  </div>
                </div>
              </div>

              <div class="settings-section">
                <h2 class="section-title">Plan</h2>
                <div class="plan-card">
                  <div class="plan-info">
                    <span class="plan-name" id="plan-name">Free</span>
                    <span class="plan-price" id="plan-price">$0/forever</span>
                  </div>
                  <a href="/pricing" class="plan-upgrade">View Plans</a>
                </div>
              </div>

              <div class="settings-section settings-danger">
                <h2 class="section-title">Danger Zone</h2>
                <p class="form-hint">Careful — these actions are permanent.</p>
                <button class="danger-btn" id="delete-account-btn" disabled>Delete Account</button>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script is:inline>
(function () {
  'use strict';

  var authGate = document.getElementById('auth-gate');
  var settingsForm = document.getElementById('settings-form');
  var emailEl = document.getElementById('user-email');
  var emailInput = document.getElementById('email');
  var nameInput = document.getElementById('display-name');

  // Check auth
  fetch('/api/auth/get-session', { credentials: 'include' })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (data && data.user) {
        emailEl.textContent = data.user.email || '';
        emailInput.value = data.user.email || '';
        nameInput.value = data.user.name || '';
        settingsForm.hidden = false;
      } else {
        emailEl.textContent = 'Not signed in';
        authGate.hidden = false;
      }
    })
    .catch(function () {
      emailEl.textContent = 'Not signed in';
      authGate.hidden = false;
    });

  // Theme toggle
  var toggleBtns = document.querySelectorAll('.toggle-btn');
  var currentTheme = localStorage.getItem('theme-preference') || 'system';

  function setActiveTheme(theme) {
    toggleBtns.forEach(function (btn) {
      btn.classList.toggle('toggle-btn--active', btn.getAttribute('data-theme') === theme);
    });
    localStorage.setItem('theme-preference', theme);
    if (theme === 'system') {
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', prefersDark);
    } else {
      document.documentElement.classList.toggle('dark', theme === 'dark');
    }
  }

  setActiveTheme(currentTheme);

  toggleBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setActiveTheme(btn.getAttribute('data-theme'));
    });
  });
})();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .dash-main {
    flex: 1;
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  .dash-header { margin-bottom: 2rem; }

  .dash-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0;
  }

  .dash-sub {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    margin: 0.25rem 0 0;
  }

  .dash-layout {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 2rem;
  }

  .dash-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    position: sticky;
    top: 5rem;
  }

  .dash-nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color 0.15s, background 0.15s;
  }

  .dash-nav-link:hover { color: var(--fg); background: var(--muted-bg); }
  .dash-nav-link--active { color: var(--fg); background: var(--muted-bg); font-weight: 600; }

  .settings-section {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .settings-danger {
    border-color: rgba(239, 68, 68, 0.25);
  }

  .section-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group:last-child { margin-bottom: 0; }

  .form-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.375rem;
  }

  .form-input {
    width: 100%;
    max-width: 24rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--fg);
    font-family: var(--font-sans);
    transition: border-color 0.15s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--ring-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ring-color) 20%, transparent);
  }

  .form-input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-hint {
    font-size: 0.75rem;
    color: var(--muted-fg);
    margin: 0.375rem 0 0;
  }

  .toggle-group {
    display: flex;
    gap: 0.25rem;
    background: var(--bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.2rem;
    width: fit-content;
  }

  .toggle-btn {
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted-fg);
    background: none;
    border: none;
    border-radius: var(--radius-sm, 0.25rem);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    font-family: var(--font-sans);
  }

  .toggle-btn:hover { color: var(--fg); }

  .toggle-btn--active {
    color: var(--fg);
    background: var(--card-bg);
    font-weight: 600;
    box-shadow: var(--shadow-sm);
  }

  .plan-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .plan-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .plan-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--fg);
  }

  .plan-price {
    font-size: 0.8125rem;
    color: var(--muted-fg);
  }

  .plan-upgrade {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .plan-upgrade:hover {
    border-color: color-mix(in srgb, var(--primary-color) 40%, transparent);
  }

  .danger-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #ef4444;
    background: none;
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius-md);
    cursor: not-allowed;
    opacity: 0.6;
    font-family: var(--font-sans);
  }

  .auth-gate {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
  }

  .auth-gate p {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    margin: 0 0 1rem;
  }

  .auth-cta {
    display: inline-flex;
    padding: 0.625rem 1.5rem;
    background: var(--fg);
    color: var(--bg);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .auth-cta:hover { opacity: 0.88; }

  @media (max-width: 640px) {
    .dash-layout {
      grid-template-columns: 1fr;
    }
    .dash-nav {
      flex-direction: row;
      overflow-x: auto;
      position: static;
    }
  }
</style>

---
import TrackPageView from '../components/TrackPageView.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Zoltan Erdos — spike.land</title>
    <meta name="description" content="Founder of spike.land. Mathematician, engineer, builder." />
    <link rel="icon" href="/favicon.ico" />
    <style>
      *{box-sizing:border-box;margin:0;padding:0}
      body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#fafafa;color:#1a1a1a;line-height:1.6}
      main{max-width:40rem;margin:0 auto;padding:4rem 1.5rem}
      h1{font-size:2rem;font-weight:700;margin-bottom:0.25rem}
      .subtitle{color:#666;font-size:1.1rem;margin-bottom:2.5rem}
      section{margin-bottom:2rem}
      h2{font-size:1.25rem;font-weight:600;margin-bottom:0.75rem;color:#333}
      p{margin-bottom:0.75rem;color:#444}
      a{color:#d97706;text-decoration:none}
      a:hover{text-decoration:underline}
      .links{display:flex;gap:1.5rem;flex-wrap:wrap;margin-top:2rem}
      .links a{padding:0.5rem 1rem;border:1px solid #ddd;border-radius:0.5rem;font-size:0.875rem;color:#333;transition:border-color 0.2s}
      .links a:hover{border-color:#d97706;text-decoration:none}
    </style>
    <TrackPageView />
  </head>
  <body>
    <main>
      <h1>Zoltan Erdos</h1>
      <p class="subtitle">Founder, spike.land</p>

      <section>
        <p>Mathematician and software engineer. ELTE Budapest (programtervező matematikus). Based in Brighton, UK.</p>
        <p>Built spike.land — an open AI app store on the MCP runtime. 80+ composable tools. Zero config. Free tier for everyone.</p>
      </section>

      <section>
        <h2>The thesis</h2>
        <p>Domain experts should ship software without becoming developers. If your requirement is clear, the platform does the rest. Mathematics, chemistry, music — whatever your domain.</p>
      </section>

      <section>
        <h2>Connect</h2>
        <div class="links">
          <a href="https://github.com/spike-land-ai">GitHub</a>
          <a href="/erdos">Talk to Erdos</a>
          <a href="/">spike.land</a>
        </div>
      </section>
    </main>
  </body>
</html>

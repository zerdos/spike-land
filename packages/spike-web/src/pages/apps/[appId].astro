---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import QaStudioPage from '../../components/react/qa-studio/QaStudioApp.tsx';
import SpikeChatPage from '../../components/apps/SpikeChatPage.astro';
import Analytics from '../../components/Analytics.astro';
import { appCatalog, getAppById } from '../../data/apps';

export function getStaticPaths() {
  return appCatalog.map((app) => ({
    params: { appId: app.id },
  }));
}

const { appId } = Astro.params;
const app = getAppById(appId);

if (!app) {
  throw new Error(`Unknown app: ${appId}`);
}

const appName = app.name;
---

<Layout
  title={`${appName} — spike.land`}
  description={app.description}
>
  <Analytics slot="head" />
  <div class="page-shell">
    {appId === 'qa-studio' ? (
        <main class="flex-1 w-full h-screen overflow-hidden">
            <QaStudioPage client:only="react" />
        </main>
    ) : appId === 'spike-chat' ? (
      <>
        <Nav activePath="/apps" />
        <main class="spike-chat-main">
          <SpikeChatPage
            name={app.name}
            description={app.description}
            accent={app.accent}
            accentBg={app.accentBg}
          />
        </main>
        <Footer />
      </>
    ) : (
      <>
        <Nav activePath="/apps" />
        <main class="app-overview-page">
          <div class="rubik-container app-overview-inner">
            <a href="/apps" class="back-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              Back to Apps
            </a>

            <div class="app-overview-header">
              <h1 class="app-overview-title">{app.name}</h1>
              <span class={`status-badge status-${app.status.toLowerCase()}`}>
                <span class="status-dot"></span> {app.status}
              </span>
            </div>

            <p class="app-overview-desc">{app.description}</p>

            <div class="app-connect-card rubik-panel">
              <h2 class="connect-title">Connect via MCP</h2>
              <p class="connect-desc">
                This app is available as an MCP tool. Connect it to your AI agent with one command:
              </p>
              <pre class="connect-command"><code>claude mcp add spike-land --transport http https://spike.land/mcp</code></pre>
              <p class="connect-note">
                Once connected, your AI agent can use all spike.land tools including {app.name}.
              </p>
            </div>

            <a href="/apps" class="back-link back-link--bottom">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              Browse all apps
            </a>
          </div>
        </main>
        <Footer />
      </>
    )}
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .spike-chat-main {
    flex: 1;
  }

  /* App overview page */
  .app-overview-page {
    flex: 1;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .app-overview-inner {
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .back-link:hover { color: var(--fg); }

  .back-link--bottom {
    margin-top: 1rem;
  }

  .app-overview-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .app-overview-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
  }

  .status-live {
    background: color-mix(in srgb, var(--color-status-live) 12%, transparent);
    color: var(--color-status-live);
    border: 1px solid color-mix(in srgb, var(--color-status-live) 20%, transparent);
  }

  .status-beta {
    background: color-mix(in srgb, var(--color-status-beta) 12%, transparent);
    color: var(--color-status-beta);
    border: 1px solid color-mix(in srgb, var(--color-status-beta) 20%, transparent);
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .app-overview-desc {
    font-size: 1.0625rem;
    color: var(--muted-fg);
    line-height: 1.65;
    margin: 0;
  }

  .app-connect-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .connect-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .connect-desc {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    line-height: 1.6;
    margin: 0;
  }

  .connect-command {
    background: var(--code-bg, rgba(0, 0, 0, 0.4));
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
    margin: 0;
    color: #e2e8f0;
    font-family: var(--font-mono, 'SF Mono', 'Fira Code', monospace);
  }

  .connect-note {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    line-height: 1.55;
    margin: 0;
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
import { appCatalog as apps } from '../../data/apps';
---

<Layout
  title="Apps - spike.land"
  description="Browse and launch AI-powered applications on spike.land."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/apps" />

    <main>
      <!-- Header -->
      <section class="apps-header">
        <div class="rubik-container apps-header-inner">
          <p class="rubik-eyebrow">App Store</p>
          <h1 class="apps-title">AI-powered apps,<br />ready to run</h1>
          <p class="rubik-lede">
            Every app is a bundle of composable MCP tools. Install, extend, and compose them together.
          </p>

          <div class="search-bar">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="search" placeholder="Search apps…" class="search-input" aria-label="Search apps" />
          </div>
        </div>
      </section>

      <!-- Grid -->
      <section class="apps-grid-section">
        <div class="rubik-container">
          <p class="apps-empty" id="apps-empty" hidden>No apps match your search.</p>
          <div class="apps-grid" id="apps-grid">
            {apps.map(app => (
              <a
                href={`/apps/${app.id}`}
                class="app-card rubik-panel"
                style={`--app-accent: ${app.accent}; --app-accent-bg: ${app.accentBg};`}
              >
                <div class="card-top">
                  <div class="app-icon-wrap">
                    <svg class="app-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.iconPath}></path>
                    </svg>
                  </div>
                  <div class="card-badges">
                    <span class={`status-badge status-${app.status.toLowerCase()}`}>{app.status}</span>
                    <span class="category-badge">{app.category}</span>
                  </div>
                </div>

                <h2 class="app-name">{app.name}</h2>
                <p class="app-desc">{app.description}</p>

                <span class="app-link">
                  Open app
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .apps-header {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border-color);
    background: radial-gradient(ellipse 70% 50% at 50% 0%, color-mix(in srgb, var(--primary-color) 8%, transparent), transparent);
  }

  .apps-header-inner {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .apps-title { max-width: 20ch; }

  .search-bar {
    position: relative;
    max-width: 28rem;
    margin-top: 0.5rem;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted-fg);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.6875rem 1rem 0.6875rem 2.625rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    color: var(--fg);
    transition: border-color var(--duration-fast) var(--ease),
                box-shadow var(--duration-fast) var(--ease);
    font-family: var(--font-sans);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--ring-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ring-color) 20%, transparent);
  }

  .search-input::placeholder { color: var(--muted-fg); }

  .apps-grid-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .apps-empty {
    color: var(--muted-fg);
    font-size: 0.9375rem;
    text-align: center;
    padding: 3rem 1rem;
    margin: 0 0 1rem;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.25rem;
  }

  .app-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .app-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--app-accent) 40%, transparent);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .app-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--app-accent-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--app-accent);
    flex-shrink: 0;
  }

  .app-icon { width: 1.375rem; height: 1.375rem; }

  .card-badges {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
  }

  .status-live {
    --_status-color: var(--status-live-color, oklch(52% 0.17 145));
    background: color-mix(in srgb, var(--_status-color) 12%, transparent);
    color: var(--_status-color);
    border: 1px solid color-mix(in srgb, var(--_status-color) 20%, transparent);
  }

  .status-beta {
    --_status-color: var(--status-beta-color, oklch(60% 0.19 41));
    background: color-mix(in srgb, var(--_status-color) 12%, transparent);
    color: var(--_status-color);
    border: 1px solid color-mix(in srgb, var(--_status-color) 20%, transparent);
  }

  .category-badge {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--muted-bg);
    color: var(--muted-fg);
    border: 1px solid var(--border-color);
  }

  .app-name {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0;
  }

  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted-fg);
    flex: 1;
    margin: 0;
  }

  .app-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--app-accent);
    margin-top: 0.25rem;
    transition: gap var(--duration-fast) var(--ease);
  }

  .app-card:hover .app-link { gap: 0.625rem; }
</style>

<script>
  const searchInput = document.querySelector<HTMLInputElement>('.search-input');
  const appCards = Array.from(document.querySelectorAll<HTMLElement>('.app-card'));
  const emptyEl = document.getElementById('apps-empty');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let visible = 0;
      appCards.forEach(card => {
        const text = card.textContent?.toLowerCase() || '';
        const show = query === '' || text.includes(query);
        card.style.display = show ? '' : 'none';
        if (show) visible += 1;
      });
      if (emptyEl) emptyEl.hidden = visible !== 0;
    });
  }
</script>

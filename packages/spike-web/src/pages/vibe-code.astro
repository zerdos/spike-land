---
import TrackPageView from '../components/TrackPageView.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Vibe Code — spike.land</title>
    <meta name="description" content="Browser-based code editor with live preview. Write TypeScript, JSX, and see results instantly." />
    <meta name="theme-color" content="#2563eb" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; overflow: hidden; -webkit-text-size-adjust: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #0a0a0a;
        color: #e5e5e5;
      }
    </style>
    <TrackPageView />
  </head>
  <body>
    <div class="editor-shell">
      <!-- Toolbar -->
      <header class="toolbar">
        <a href="/" class="logo">spike.land</a>
        <span class="toolbar-title">Vibe Code</span>
        <div class="toolbar-actions">
          <select id="lang-select" class="lang-select">
            <option value="tsx">TSX</option>
            <option value="typescript">TypeScript</option>
            <option value="javascript">JavaScript</option>
            <option value="css">CSS</option>
            <option value="html">HTML</option>
          </select>
          <button id="run-btn" class="run-btn">Run</button>
          <button id="layout-btn" class="layout-btn" title="Toggle layout">⟺</button>
        </div>
      </header>

      <!-- Split pane -->
      <div class="split" id="split">
        <div class="pane pane-editor" id="pane-editor">
          <textarea id="code-editor" class="code-textarea" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"></textarea>
        </div>
        <div class="divider" id="divider"></div>
        <div class="pane pane-preview" id="pane-preview">
          <iframe id="preview-frame" class="preview-frame" sandbox="allow-scripts" title="Live preview"></iframe>
          <div id="error-overlay" class="error-overlay" hidden></div>
        </div>
      </div>
    </div>

    <script is:inline>
    (function () {
      'use strict';

      var editor = document.getElementById('code-editor');
      var frame = document.getElementById('preview-frame');
      var errorOverlay = document.getElementById('error-overlay');
      var runBtn = document.getElementById('run-btn');
      var layoutBtn = document.getElementById('layout-btn');
      var split = document.getElementById('split');
      var debounceTimer = null;
      var TRANSPILE_URL = 'https://esbuild.spikeland.workers.dev';
      var STORAGE_KEY = 'spike-vibe-editor';
      var DEFAULT_CODE = 'import { useState } from "react";\n\nexport default function App() {\n  const [count, setCount] = useState(0);\n\n  return (\n    <div className="flex flex-col items-center justify-center min-h-screen gap-6 p-8">\n      <h1 className="text-4xl font-bold tracking-tight">Vibe Code</h1>\n      <p className="text-gray-500 text-lg">\n        Edit this code and see changes live.\n      </p>\n      <p className="text-6xl font-bold">{count}</p>\n      <button\n        className="px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold text-lg hover:bg-blue-700 transition-colors"\n        onClick={() => setCount((c) => c + 1)}\n      >\n        Count++\n      </button>\n    </div>\n  );\n}';

      // Restore saved code or use default
      try {
        var saved = localStorage.getItem(STORAGE_KEY);
        editor.value = saved || DEFAULT_CODE;
      } catch (e) {
        editor.value = DEFAULT_CODE;
      }

      function saveCode() {
        try { localStorage.setItem(STORAGE_KEY, editor.value); } catch (e) {}
      }

      function showError(msg) {
        errorOverlay.textContent = msg;
        errorOverlay.hidden = false;
      }

      function clearError() {
        errorOverlay.hidden = true;
        errorOverlay.textContent = '';
      }

      function transpileAndRun() {
        clearError();
        saveCode();
        var code = editor.value;

        fetch(TRANSPILE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain', 'TR_ORIGIN': window.location.origin },
          body: code,
        })
          .then(function (r) {
            if (!r.ok) return r.text().then(function(t) { throw new Error(t); });
            return r.text();
          })
          .then(function (transpiled) {
            // Safety check: if transpiler returns HTML (e.g. error page), don't run it as JS
            if (transpiled.trim().startsWith('<')) {
              throw new Error('Invalid transpilation output');
            }
            frame.srcdoc = buildHtml(transpiled);
          })
          .catch(function (err) {
            showError(err.message || 'Transpile failed');
            // Clear frame on error to avoid showing stale/broken content
            frame.srcdoc = '<!DOCTYPE html><html><body style="background:#0a0a0a;color:#ef4444;display:flex;align-items:center;justify-content:center;height:100vh;font-family:system-ui"><div>Transpilation Error</div></body></html>';
          });
      }

      function buildHtml(code) {
        // Strip export default and extract the component reference
        var prepared = code;
        var appRef = 'App';
        var namedFn = prepared.match(/export\s+default\s+function\s+(\w+)/);
        if (namedFn) {
          appRef = namedFn[1];
          prepared = prepared.replace(/export\s+default\s+function\s+/, 'function ');
        } else if (/export\s+default\s+/.test(prepared)) {
          prepared = prepared.replace(/export\s+default\s+/, 'const App = ');
          appRef = 'App';
        }
        // Remove remaining export statements
        prepared = prepared.replace(/^export\s+\{[^}]*\}\s*;?\s*$/gm, '');
        prepared = prepared.replace(/^export\s+/gm, '');

        return '<!DOCTYPE html><html><head><meta charset="utf-8">' +
          '<script type="importmap">{"imports":{' +
            '"react":"https://esm.sh/react@19.2.4?bundle",' +
            '"react/jsx-runtime":"https://esm.sh/react@19.2.4/jsx-runtime?bundle",' +
            '"react/jsx-dev-runtime":"https://esm.sh/react@19.2.4/jsx-dev-runtime?bundle",' +
            '"@emotion/react/jsx-runtime":"https://esm.sh/@emotion/react@11/jsx-runtime?bundle&external=react",' +
            '"@emotion/react/jsx-dev-runtime":"https://esm.sh/@emotion/react@11/jsx-dev-runtime?bundle&external=react",' +
            '"react-dom":"https://esm.sh/react-dom@19.2.4?bundle&external=react",' +
            '"react-dom/client":"https://esm.sh/react-dom@19.2.4/client?bundle&external=react"' +
          '}}<\/script>' +
          '<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4/dist/cdn.min.js"><\/script>' +
          '<style>*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif}</style>' +
          '</head><body><div id="root"></div>' +
          '<div id="error-display" style="display:none;padding:1rem;color:#ef4444;font-family:monospace;font-size:13px;white-space:pre-wrap;background:#1a0000;margin:1rem;border-radius:8px;border:1px solid #7f1d1d"></div>' +
          '<script>globalThis.process={env:{NODE_ENV:"development"}};globalThis.global=globalThis;<\/script>' +
          '<script type="module">' +
          'window.addEventListener("error",function(e){var el=document.getElementById("error-display");if(el){el.style.display="block";el.textContent=e.message;}});' +
          prepared.replace(/<\/script>/g, '<\\/script>') +
          '\ntry{' +
            'var createRoot=(await import("react-dom/client")).createRoot;' +
            'var createElement=(await import("react")).createElement;' +
            'var _Comp=typeof ' + appRef + '!=="undefined"?' + appRef + ':null;' +
            'if(_Comp){createRoot(document.getElementById("root")).render(createElement(_Comp));}' +
            'else{document.getElementById("root").innerHTML="<p style=\\"padding:2rem;text-align:center;color:#666\\">No component found. Export a default function.</p>";}' +
          '}catch(err){' +
            'var el=document.getElementById("error-display");if(el){el.style.display="block";el.textContent=err.message;}' +
          '}' +
          '<\/script></body></html>';
      }

      function scheduleRun() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(transpileAndRun, 500);
      }

      editor.addEventListener('input', scheduleRun);
      editor.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 's') {
          e.preventDefault();
          transpileAndRun();
        }
        // Tab inserts 2 spaces
        if (e.key === 'Tab') {
          e.preventDefault();
          var start = editor.selectionStart;
          var end = editor.selectionEnd;
          editor.value = editor.value.substring(0, start) + '  ' + editor.value.substring(end);
          editor.selectionStart = editor.selectionEnd = start + 2;
        }
      });

      runBtn.addEventListener('click', transpileAndRun);

      // Layout toggle
      var layouts = ['split', 'editor-only', 'preview-only'];
      var layoutIdx = 0;
      layoutBtn.addEventListener('click', function () {
        layoutIdx = (layoutIdx + 1) % layouts.length;
        split.className = 'split layout-' + layouts[layoutIdx];
      });

      // Initial run
      transpileAndRun();
    })();
    </script>

    <style>
      .editor-shell {
        display: flex;
        flex-direction: column;
        height: 100vh;
      }

      .toolbar {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0 1rem;
        height: 3rem;
        background: #111;
        border-bottom: 1px solid #222;
        flex-shrink: 0;
      }

      .logo {
        font-weight: 800;
        font-size: 0.9375rem;
        color: #fafafa;
        text-decoration: none;
        letter-spacing: -0.03em;
      }

      .toolbar-title {
        font-size: 0.8125rem;
        color: #525252;
        font-weight: 600;
      }

      .toolbar-actions {
        margin-left: auto;
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }

      .lang-select {
        background: #1a1a1a;
        border: 1px solid #333;
        color: #a3a3a3;
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }

      .run-btn {
        background: #2563eb;
        color: white;
        border: none;
        padding: 0.3rem 1rem;
        border-radius: 0.25rem;
        font-size: 0.8125rem;
        font-weight: 600;
        cursor: pointer;
      }

      .run-btn:hover { background: #1d4ed8; }

      .layout-btn {
        background: none;
        border: 1px solid #333;
        color: #a3a3a3;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        cursor: pointer;
        font-size: 0.875rem;
      }

      .layout-btn:hover { border-color: #555; color: #fafafa; }

      .split {
        display: flex;
        flex: 1;
        overflow: hidden;
      }

      .pane { overflow: hidden; }

      .pane-editor {
        flex: 1;
        display: flex;
      }

      .code-textarea {
        width: 100%;
        height: 100%;
        background: #0d0d0d;
        color: #d4d4d8;
        border: none;
        padding: 1rem;
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', Menlo, Consolas, monospace;
        font-size: 0.875rem;
        line-height: 1.6;
        resize: none;
        outline: none;
        tab-size: 2;
      }

      .divider {
        width: 4px;
        background: #222;
        cursor: col-resize;
        flex-shrink: 0;
      }

      .divider:hover { background: #2563eb; }

      .pane-preview {
        flex: 1;
        position: relative;
        background: white;
      }

      .preview-frame {
        width: 100%;
        height: 100%;
        border: none;
      }

      .error-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(220, 38, 38, 0.95);
        color: white;
        font-family: monospace;
        font-size: 0.8125rem;
        padding: 0.75rem 1rem;
        white-space: pre-wrap;
        max-height: 40%;
        overflow-y: auto;
      }

      .layout-editor-only .pane-preview,
      .layout-editor-only .divider { display: none; }
      .layout-editor-only .pane-editor { flex: 1; }

      .layout-preview-only .pane-editor,
      .layout-preview-only .divider { display: none; }
      .layout-preview-only .pane-preview { flex: 1; }

      @media (max-width: 640px) {
        .split { flex-direction: column; }
        .divider { width: 100%; height: 4px; cursor: row-resize; }
        .pane-editor { min-height: 40%; }
        .pane-preview { min-height: 40%; }
      }
    </style>
  </body>
</html>

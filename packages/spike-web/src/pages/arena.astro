---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';

const personas = [
  { slug: 'zoltan', name: 'Zolt\u00e1n', role: 'The Arena', accent: '#d97706', pitch: 'Music. Math. Code. Human After All.', initial: 'Z', category: 'builders' },
  { slug: 'erdos', name: 'Erd\u0151s', role: 'Mathematician', accent: '#4f46e5', pitch: 'My brain is open. Is yours?', initial: 'E', category: 'scientists' },
  { slug: 'einstein', name: 'Einstein', role: 'Physicist', accent: '#78716c', pitch: 'Imagination is more important than knowledge.', initial: 'A', category: 'scientists' },
  { slug: 'socrates', name: 'Socrates', role: 'Philosopher', accent: '#a16207', pitch: 'The unexamined life is not worth living.', initial: 'S', category: 'philosophers' },
  { slug: 'buddha', name: 'Buddha', role: 'Teacher', accent: '#ca8a04', pitch: 'Peace comes from within. Do not seek it without.', initial: 'B', category: 'philosophers' },
  { slug: 'camus', name: 'Camus', role: 'Absurdist', accent: '#dc2626', pitch: 'One must imagine Sisyphus happy.', initial: 'C', category: 'philosophers' },
  { slug: 'arnold', name: 'Arnold', role: 'UX Provocateur', accent: '#e11d48', pitch: "Show me what you've got. I'll tell you what it's missing.", initial: 'A', category: 'provocateurs' },
  { slug: 'peti', name: 'Peti', role: 'QA Engineer', accent: '#22c55e', pitch: 'Does it work on mobile Safari? Test there first.', initial: 'P', category: 'builders' },
  { slug: 'diogenes', name: 'Diogenes', role: 'Cynic', accent: '#854d0e', pitch: 'I am looking for an honest man.', initial: 'D', category: 'provocateurs' },
  { slug: 'arendt', name: 'Arendt', role: 'Political Thinker', accent: '#57534e', pitch: 'The sad truth is that most evil is done by people who never make up their minds.', initial: 'H', category: 'philosophers' },
  { slug: 'nietzsche', name: 'Nietzsche', role: 'Philosopher', accent: '#9f1239', pitch: 'He who has a why to live can bear almost any how.', initial: 'N', category: 'philosophers' },
  { slug: 'confucius', name: 'Confucius', role: 'Sage', accent: '#b91c1c', pitch: 'It does not matter how slowly you go as long as you do not stop.', initial: 'K', category: 'philosophers' },
  { slug: 'spinoza', name: 'Spinoza', role: 'Rationalist', accent: '#6366f1', pitch: 'All things excellent are as difficult as they are rare.', initial: 'S', category: 'philosophers' },
  { slug: 'kant', name: 'Kant', role: 'Idealist', accent: '#475569', pitch: 'Dare to know! Have courage to use your own reason!', initial: 'I', category: 'philosophers' },
  { slug: 'plato', name: 'Plato', role: 'Idealist', accent: '#7c3aed', pitch: 'Be kind, for everyone you meet is fighting a hard battle.', initial: 'P', category: 'philosophers' },
  { slug: 'musk', name: 'Musk', role: 'Technologist', accent: '#0ea5e9', pitch: 'When something is important enough, you do it even if the odds are not in your favor.', initial: 'E', category: 'builders' },
  { slug: 'trump', name: 'Trump', role: 'Dealmaker', accent: '#ef4444', pitch: "Think big and kick ass. That's the way to get it done.", initial: 'D', category: 'provocateurs' },
  { slug: 'gates', name: 'Gates', role: 'Philanthropist', accent: '#0284c7', pitch: 'Your most unhappy customers are your greatest source of learning.', initial: 'B', category: 'builders' },
  { slug: 'wittgenstein', name: 'Wittgenstein', role: 'Logician', accent: '#64748b', pitch: 'Whereof one cannot speak, thereof one must be silent.', initial: 'L', category: 'philosophers' },
  { slug: 'feynman', name: 'Feynman', role: 'Physicist', accent: '#f97316', pitch: "What I cannot create, I do not understand.", initial: 'R', category: 'scientists' },
  { slug: 'turing', name: 'Turing', role: 'Computer Scientist', accent: '#14b8a6', pitch: 'We can only see a short distance ahead, but we can see plenty there that needs to be done.', initial: 'A', category: 'scientists' },
  { slug: 'ada', name: 'Ada', role: 'Pioneer', accent: '#d946ef', pitch: 'The Analytical Engine weaves algebraic patterns just as the Jacquard loom weaves flowers.', initial: 'A', category: 'scientists' },
  { slug: 'chomsky', name: 'Chomsky', role: 'Linguist', accent: '#84cc16', pitch: 'If we do not believe in freedom of speech for those we despise we do not believe in it at all.', initial: 'N', category: 'provocateurs' },
  { slug: 'marx', name: 'Marx', role: 'Economist', accent: '#dc2626', pitch: 'The philosophers have only interpreted the world; the point is to change it.', initial: 'K', category: 'provocateurs' },
  { slug: 'aristotle', name: 'Aristotle', role: 'Polymath', accent: '#059669', pitch: 'We are what we repeatedly do. Excellence is not an act, but a habit.', initial: 'A', category: 'philosophers' },
  { slug: 'descartes', name: 'Descartes', role: 'Rationalist', accent: '#8b5cf6', pitch: 'I think, therefore I am.', initial: 'R', category: 'philosophers' },
];

const categories = [
  { key: 'all', label: 'All' },
  { key: 'philosophers', label: 'Philosophers' },
  { key: 'scientists', label: 'Scientists' },
  { key: 'builders', label: 'Builders' },
  { key: 'provocateurs', label: 'Provocateurs' },
];
---

<Layout
  title="The Arena — spike.land"
  description="26 AI personas to think with. Mathematicians, philosophers, engineers. Pick a mind, start talking."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/arena" />

    <main id="main-content">

      <!-- ── Hero ──────────────────────────────────────────────────────── -->
      <section class="arena-hero gradient-mesh">
        <div class="rubik-container arena-hero-inner stagger-in">
          <p class="rubik-eyebrow arena-eyebrow">The Arena</p>
          <h1 class="arena-title">Pick a mind. Start talking.</h1>
          <p class="rubik-lede arena-lede">
            26 AI personas — mathematicians, philosophers, engineers, provocateurs.
            Each with their own worldview, knowledge, and conversational style.
          </p>
        </div>
      </section>

      <!-- ── Filter tabs ────────────────────────────────────────────────── -->
      <section class="filter-section">
        <div class="rubik-container">
          <div class="filter-tabs" role="tablist" aria-label="Filter personas by category">
            {categories.map((cat, i) => (
              <button
                class={`filter-tab ${i === 0 ? 'filter-tab--active' : ''}`}
                data-filter={cat.key}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls="persona-grid"
              >
                {cat.label}
              </button>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Persona grid ───────────────────────────────────────────────── -->
      <section class="grid-section">
        <div class="rubik-container">
          <div class="persona-grid" id="persona-grid" data-filter="all">
            {personas.map(p => (
              <a
                href={`/${p.slug}`}
                class="persona-card rubik-panel"
                style={`--p-accent: ${p.accent}`}
                data-category={p.category}
                aria-label={`Talk to ${p.name}, ${p.role}`}
              >
                <div class="persona-avatar" aria-hidden="true">
                  {p.initial}
                </div>
                <div class="persona-body">
                  <div class="persona-meta">
                    <span class="persona-name">{p.name}</span>
                    <span class="persona-role">{p.role}</span>
                  </div>
                  <p class="persona-pitch">"{p.pitch}"</p>
                </div>
              </a>
            ))}
          </div>

          <p class="no-results" id="no-results" hidden>
            No personas match this filter.
          </p>
        </div>
      </section>

      <!-- ── Bottom CTA ─────────────────────────────────────────────────── -->
      <section class="arena-cta scroll-reveal">
        <div class="rubik-container arena-cta-inner">
          <p class="arena-cta-text">Can't decide? Start with Zolt&aacute;n.</p>
          <a href="/zoltan" class="cta-primary">
            Open the Arena
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>

    </main>

    <Footer />
  </div>
</Layout>

<style>
  /* ── Page shell ───────────────────────────────────────────────────────── */
  .page-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .arena-hero {
    padding-block: clamp(4rem, 10vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .arena-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .arena-eyebrow {
    margin: 0;
  }

  .arena-title {
    margin: 0;
    color: var(--fg);
  }

  .arena-lede {
    margin: 0;
    text-align: center;
    max-width: 52ch;
  }

  /* ── Filter tabs ──────────────────────────────────────────────────────── */
  .filter-section {
    padding-block: 2rem 0;
    position: sticky;
    top: 3.75rem;
    z-index: 40;
    background: oklch(from var(--bg) l c h / 0.9);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }

  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .filter-tab {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted-fg);
    background: transparent;
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease),
      background var(--duration-fast) var(--ease),
      border-color var(--duration-fast) var(--ease),
      box-shadow var(--duration-fast) var(--ease);
    line-height: 1;
    font-family: var(--font-sans);
  }

  .filter-tab:hover {
    color: var(--fg);
    background: var(--muted-bg);
    border-color: var(--muted-fg);
  }

  .filter-tab--active {
    color: var(--primary-fg);
    background: var(--primary-color);
    border-color: var(--primary-color);
    box-shadow: var(--shadow-sm);
  }

  .filter-tab--active:hover {
    filter: brightness(1.08);
    color: var(--primary-fg);
    background: var(--primary-color);
    border-color: var(--primary-color);
  }

  /* ── Grid ─────────────────────────────────────────────────────────────── */
  .grid-section {
    padding-block: 2.5rem clamp(3rem, 6vw, 5rem);
    flex: 1;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
  }

  /* Hidden cards via filter — set by JS on the grid's data-filter attribute */
  .persona-grid[data-filter="philosophers"] .persona-card:not([data-category="philosophers"]),
  .persona-grid[data-filter="scientists"]  .persona-card:not([data-category="scientists"]),
  .persona-grid[data-filter="builders"]    .persona-card:not([data-category="builders"]),
  .persona-grid[data-filter="provocateurs"] .persona-card:not([data-category="provocateurs"]) {
    display: none;
  }

  /* ── Persona card ─────────────────────────────────────────────────────── */
  .persona-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--fg);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--duration-normal) var(--ease),
      box-shadow var(--duration-normal) var(--ease),
      border-color var(--duration-normal) var(--ease);
    /* Override the generic rubik-panel hover so we can apply accent glow */
  }

  .persona-card:hover {
    transform: translateY(-3px);
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px var(--p-accent),
      0 0 16px -4px color-mix(in srgb, var(--p-accent) 35%, transparent);
    border-color: var(--p-accent);
  }

  .persona-card:active {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Avatar ───────────────────────────────────────────────────────────── */
  .persona-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-lg);
    background: var(--p-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 800;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-spring);
  }

  .persona-card:hover .persona-avatar {
    transform: scale(1.1);
  }

  /* ── Card body ────────────────────────────────────────────────────────── */
  .persona-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .persona-meta {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .persona-name {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1.2;
  }

  .persona-role {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--p-accent);
    line-height: 1.3;
  }

  .persona-pitch {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--muted-fg);
    margin: 0;
    font-style: italic;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  /* ── Empty state ──────────────────────────────────────────────────────── */
  .no-results {
    text-align: center;
    color: var(--muted-fg);
    font-size: 0.9375rem;
    padding-block: 4rem;
    margin: 0;
  }

  /* ── Bottom CTA ───────────────────────────────────────────────────────── */
  .arena-cta {
    border-top: 1px solid var(--border-color);
    padding-block: clamp(3rem, 6vw, 5rem);
    background: var(--muted-bg);
  }

  .arena-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .arena-cta-text {
    font-size: clamp(1.125rem, 2vw + 0.5rem, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0;
  }

  /* ── cta-primary (matches global pattern used on homepage) ───────────── */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6875rem 1.5rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition:
      transform var(--duration-fast) var(--ease),
      box-shadow var(--duration-fast) var(--ease),
      filter var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-sm);
  }

  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    filter: brightness(1.08);
  }

  .cta-primary:active {
    transform: translateY(0);
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .persona-grid {
      grid-template-columns: 1fr;
    }

    .filter-tabs {
      gap: 0.375rem;
    }

    .filter-tab {
      font-size: 0.75rem;
      padding: 0.3125rem 0.6875rem;
    }
  }
</style>

<script>
  (function () {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
    const grid = document.getElementById('persona-grid') as HTMLElement | null;
    const noResults = document.getElementById('no-results') as HTMLElement | null;

    if (!grid) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const filter = tab.dataset.filter ?? 'all';

        // Update active tab state
        tabs.forEach(function (t) {
          t.classList.remove('filter-tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('filter-tab--active');
        tab.setAttribute('aria-selected', 'true');

        // Apply filter to grid via data attribute (CSS handles visibility)
        grid.dataset.filter = filter;

        // Show/hide empty state
        if (noResults) {
          const visible = grid.querySelectorAll<HTMLElement>(
            filter === 'all'
              ? '.persona-card'
              : `.persona-card[data-category="${filter}"]`
          );
          noResults.hidden = visible.length > 0;
        }
      });
    });
  })();
</script>

---
import RadixChat from '../components/react/radix-chat/RadixChat.tsx';
import TrackPageView from '../components/TrackPageView.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Daft Punk — spike.land</title>
    <meta name="description" content="Music. Synthesis. Groove. Human After All." />
    <meta name="theme-color" content="#7c3aed" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; overflow: hidden; -webkit-text-size-adjust: 100%; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    </style>
    <TrackPageView />
  </head>
  <body>
    <RadixChat client:only="react" persona="daftpunk" />
  </body>
</html>

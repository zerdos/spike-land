---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';

const metrics = [
  { value: '80+', label: 'Tools in the registry' },
  { value: '26', label: 'Personas in the Arena' },
  { value: 'MIT', label: 'Every line, every repo' },
  { value: '$0', label: 'First spike is free' },
];

const pillars = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
    title: 'Compose a tool',
    description: 'Write one Zod schema. Get an MCP tool, a REST endpoint, and a storefront card. 80+ tools already live in the public registry.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>',
    title: 'Ship a storefront',
    description: 'Discovery metadata, OAuth, categories, install flows — all generated from the same schema. No CMS. No duplicated copy.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Think with 26 minds',
    description: 'Mathematicians, philosophers, engineers. Pick a persona, pair on an idea, and keep the transcript. The Arena is the second keyboard.',
  },
];

const appShowcase = [
  { name: 'Code Review', desc: 'AI-powered code review with GitHub integration', icon: 'CR' },
  { name: 'Image Studio', desc: 'Generate, enhance, and compose images with AI', icon: 'IS' },
  { name: 'Chess Arena', desc: 'Play chess against AI with ELO rating system', icon: 'CA' },
  { name: 'Quiz Builder', desc: 'Create interactive quizzes and assessments', icon: 'QB' },
  { name: 'Blog Engine', desc: 'Write and publish MDX blog posts with AI', icon: 'BE' },
  { name: 'Vibe Code', desc: 'Docker-based development workflows', icon: 'VC' },
  { name: 'Sandbox', desc: 'Safe code execution and evaluation', icon: 'SB' },
  { name: 'TTS Studio', desc: 'Text-to-speech with ElevenLabs integration', icon: 'TS' },
  { name: 'BugBook', desc: 'Bug tracking and feedback collection', icon: 'BB' },
];

const toolCategories = [
  { name: 'Database', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>' },
  { name: 'AI / ML', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.57-3.25 3.93"/><path d="M12 2a4 4 0 0 0-4 4c0 1.95 1.4 3.57 3.25 3.93"/><path d="M12 18v4"/><path d="M8 22h8"/><circle cx="12" cy="14" r="4"/></svg>' },
  { name: 'File System', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>' },
  { name: 'Web & HTTP', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
  { name: 'Git & VCS', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M6 9v12"/></svg>' },
  { name: 'Testing', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>' },
  { name: 'Analytics', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  { name: 'Auth & Security', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' },
];

const personas = [
  { slug: 'zoltan', name: 'Zolt\u00e1n', role: 'The Arena', accent: '#d97706', pitch: 'Music. Math. Code. Human After All.', initial: 'Z' },
  { slug: 'erdos', name: 'Erd\u0151s', role: 'Mathematician', accent: '#4f46e5', pitch: 'My brain is open. Is yours?', initial: 'E' },
  { slug: 'einstein', name: 'Einstein', role: 'Physicist', accent: '#78716c', pitch: 'Imagination is more important than knowledge.', initial: 'A' },
  { slug: 'socrates', name: 'Socrates', role: 'Philosopher', accent: '#a16207', pitch: 'The unexamined life is not worth living.', initial: 'S' },
  { slug: 'buddha', name: 'Buddha', role: 'Teacher', accent: '#ca8a04', pitch: 'Peace comes from within. Do not seek it without.', initial: 'B' },
  { slug: 'camus', name: 'Camus', role: 'Absurdist', accent: '#dc2626', pitch: 'One must imagine Sisyphus happy.', initial: 'C' },
  { slug: 'arnold', name: 'Arnold', role: 'UX Provocateur', accent: '#e11d48', pitch: 'Show me what you\'ve got. I\'ll tell you what it\'s missing.', initial: 'A' },
  { slug: 'peti', name: 'Peti', role: 'QA Engineer', accent: '#22c55e', pitch: 'Does it work on mobile Safari? Test there first.', initial: 'P' },
  { slug: 'diogenes', name: 'Diogenes', role: 'Cynic', accent: '#854d0e', pitch: 'I am looking for an honest man.', initial: 'D' },
  { slug: 'feynman', name: 'Feynman', role: 'Physicist', accent: '#f97316', pitch: 'What I cannot create, I do not understand.', initial: 'R' },
  { slug: 'turing', name: 'Turing', role: 'Computer Scientist', accent: '#14b8a6', pitch: 'We can only see a short distance ahead, but plenty needs to be done.', initial: 'A' },
  { slug: 'aristotle', name: 'Aristotle', role: 'Polymath', accent: '#059669', pitch: 'We are what we repeatedly do. Excellence is a habit.', initial: 'A' },
];

// Fetch latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.draft && !post.data.unlisted)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const featuredPost = latestPosts[0];
const morePosts = latestPosts.slice(1, 4);
---

<Layout
  title="spike.land — Ship the app, not the setup"
  description="An open AI app store built on MCP. Compose tools, publish a storefront, keep your data portable. 80+ tools, 26 personas, MIT-licensed, free to start."
>
  <Analytics slot="head" />
  <link slot="head" rel="manifest" href="/site.webmanifest" />
  <meta slot="head" name="apple-mobile-web-app-capable" content="yes" />
  <meta slot="head" name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta slot="head" name="mobile-web-app-capable" content="yes" />

  <div class="page-shell">
    <Nav activePath="/" />

    <main id="main-content">
      <!-- Hero -->
      <section class="hero-section gradient-mesh">
        <div class="rubik-container hero-inner stagger-in">
          <div class="hero-eyebrow">
            <span class="rubik-chip chip-live">
              <span class="live-dot"></span>
              Open-source AI platform
            </span>
          </div>

          <h1 class="hero-title">
            Ship the app,<br class="sm-break" /> not the setup.
          </h1>

          <p class="rubik-lede hero-lede">
            An open AI app store built on MCP. Compose tools, publish a
            storefront, keep your data portable. No scaffolding week. No lock-in.
          </p>

          <div class="hero-ctas">
            <a href="/login" class="cta-primary">
              Start building
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/apps" class="cta-secondary">
              See what others shipped
            </a>
          </div>
        </div>
      </section>

      <!-- Metrics strip -->
      <section class="metrics-strip">
        <div class="rubik-container metrics-inner">
          {metrics.map(m => (
            <div class="metric-item">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Three Pillars -->
      <section class="pillars-section scroll-reveal">
        <div class="rubik-container">
          <div class="pillars-grid">
            {pillars.map(p => (
              <div class="pillar-card rubik-panel">
                <div class="pillar-icon" set:html={p.icon} />
                <h3 class="pillar-title">{p.title}</h3>
                <p class="pillar-desc">{p.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- App Showcase -->
      <section class="showcase-section scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">App Store</p>
            <h2 class="section-title">Built on spike.land</h2>
          </div>
          <div class="showcase-grid">
            {appShowcase.map(app => (
              <a href="/apps" class="showcase-card rubik-panel">
                <div class="showcase-icon">{app.icon}</div>
                <h3 class="showcase-name">{app.name}</h3>
                <p class="showcase-desc">{app.desc}</p>
              </a>
            ))}
          </div>
          <div class="showcase-cta">
            <a href="/apps" class="cta-secondary">
              Browse all apps
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- MCP Protocol -->
      <section class="mcp-section scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">MCP Protocol</p>
            <h2 class="section-title">One line to connect.</h2>
          </div>

          <div class="mcp-content">
            <div class="connect-terminal rubik-panel" data-copy={`"mcpServers": {\n  "spike-land": {\n    "transport": "streamable-http",\n    "url": "https://spike.land/mcp"\n  }\n}`}>
              <div class="terminal-dots">
                <span></span><span></span><span></span>
                <button type="button" class="terminal-copy" aria-label="Copy to clipboard">Copy</button>
              </div>
              <pre class="terminal-code"><code><span class="code-comment">// Connect any MCP client in seconds</span>
<span class="code-key">"mcpServers"</span>: &#123;
  <span class="code-key">"spike-land"</span>: &#123;
    <span class="code-key">"transport"</span>: <span class="code-str">"streamable-http"</span>,
    <span class="code-key">"url"</span>: <span class="code-str">"https://spike.land/mcp"</span>
  &#125;
&#125;</code></pre>
            </div>

            <div class="tool-categories">
              {toolCategories.map(cat => (
                <div class="tool-cat">
                  <span class="tool-cat-icon" set:html={cat.icon} />
                  <span class="tool-cat-name">{cat.name}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Blog -->
      <section class="blog-section scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">Blog</p>
            <h2 class="section-title">From the Arena</h2>
          </div>

          {featuredPost && (
            <a href={`/blog/${featuredPost.id}`} class="featured-post rubik-panel">
              {featuredPost.data.heroImage && (
                <div class="fp-image-wrap">
                  <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="fp-image" loading="lazy" />
                </div>
              )}
              <div class="fp-content">
                <div class="fp-meta">
                  <time datetime={featuredPost.data.date.toISOString()}>
                    {featuredPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </time>
                  {featuredPost.data.category && <span class="rubik-chip">{featuredPost.data.category}</span>}
                </div>
                <h3 class="fp-title">{featuredPost.data.title}</h3>
                {featuredPost.data.primer && <p class="fp-primer">{featuredPost.data.primer}</p>}
                {featuredPost.data.description && <p class="fp-desc">{featuredPost.data.description}</p>}
                <span class="read-link">Read article <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </a>
          )}

          <div class="blog-grid">
            {morePosts.map(post => (
              <a href={`/blog/${post.id}`} class="blog-card rubik-panel">
                {post.data.heroImage && (
                  <div class="bc-image-wrap">
                    <img src={post.data.heroImage} alt={post.data.title} class="bc-image" loading="lazy" />
                  </div>
                )}
                <div class="bc-content">
                  <div class="fp-meta">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                    {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
                  </div>
                  <h3 class="bc-title">{post.data.title}</h3>
                  {post.data.primer && <p class="bc-primer">{post.data.primer}</p>}
                </div>
              </a>
            ))}
          </div>

          <div class="blog-cta">
            <a href="/blog" class="cta-secondary">
              View all articles
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Personas -->
      <section class="hook-section hook-personas scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">The Arena</p>
            <h2 class="section-title">Pick a mind. Start talking.</h2>
          </div>
          <p class="hook-sub" style="text-align:center; margin-bottom: 2rem;">
            Mathematicians, philosophers, engineers. Each with a worldview
            of their own. Curiosity is additive, never a substitute.
          </p>
          <div class="persona-grid stagger-in">
            {personas.map(p => (
              <a href={`/${p.slug}`} class="persona-card rubik-panel" style={`--p-accent: ${p.accent}`}>
                <div class="persona-avatar" style={`background: ${p.accent}`}>{p.initial}</div>
                <h3 class="persona-name">{p.name}</h3>
                <p class="persona-role">{p.role}</p>
                <p class="persona-pitch">"{p.pitch}"</p>
              </a>
            ))}
          </div>
          <div style="text-align: center; margin-top: 2rem;">
            <a href="/arena" class="cta-secondary">
              See all 26 personas
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- For developers -->
      <section class="hook-section hook-opensource">
        <div class="rubik-container hook-inner">
          <div class="hook-badge">For developers</div>
          <h2 class="hook-title">30 packages. MIT license. Zero vendor locks.</h2>
          <p class="hook-sub">
            Read every line. Fork the whole thing. When you leave, block-sdk
            hands your data back — same schema on D1, IndexedDB, or memory.
          </p>
          <div class="connect-terminal rubik-panel" style="max-width: 44rem; width: 100%;" data-copy="claude mcp add spike-land --transport http https://spike.land/mcp">
            <div class="terminal-dots">
              <span></span><span></span><span></span>
              <button type="button" class="terminal-copy" aria-label="Copy to clipboard">Copy</button>
            </div>
            <code class="terminal-cmd">
              <span class="terminal-prompt">$</span>
              claude mcp add spike-land --transport http https://spike.land/mcp
            </code>
          </div>
          <div class="hero-ctas" style="justify-content: center;">
            <a href="https://github.com/spike-land-ai/spike-land" class="cta-secondary" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 4.238 9.617 9.634 10.828.576.106.788-.25.788-.556 0-.273-.01-1.185-.015-2.171-4.037.876-4.889-1.731-4.889-1.731-.66-1.676-1.61-2.122-1.61-2.122-1.318-.9.1-.882.1-.882 1.457.102 2.224 1.496 2.224 1.496 1.296 2.218 3.39 1.577 4.216 1.206.13-.938.533-1.577.976-1.94-3.221-.366-6.608-1.61-6.608-7.17 0-1.583.565-2.877 1.492-3.892-.15-.366-.647-1.84.142-3.838 0 0 1.217-.422 3.992 1.486 1.157-.322 2.397-.483 3.633-.488 1.235.005 2.476.166 3.635.488 2.772-1.908 3.987-1.486 3.987-1.486.791 1.998.294 3.472.144 3.838.929 1.015 1.49 2.309 1.49 3.892 0 5.574-3.393 6.801-6.624 7.16.524.452.991 1.344.991 2.709 0 1.957-.014 3.532-.014 4.012 0 .31.209.669.799.554 5.393-1.213 9.629-5.526 9.629-10.828 0-6.627-5.373-12-12-12z"/></svg>
              View on GitHub
            </a>
            <a href="/status" class="cta-secondary">
              <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="#22c55e"/></svg>
              All services operational
            </a>
          </div>
        </div>
      </section>

      <!-- CTA band -->
      <section class="cta-band">
        <div class="rubik-container cta-band-inner">
          <div class="cta-band-content">
            <h2 class="cta-band-title">Enough reading. Open the editor.</h2>
            <p class="rubik-lede cta-band-lede">
              No sign-up wall for the first spike. Bring an idea; leave with
              something a stranger can click.
            </p>
          </div>
          <div class="cta-band-actions">
            <a href="/login" class="cta-primary">
              Launch spike.land
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/learn" class="cta-secondary">
              Read the docs first
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <!-- PWA Install Banner -->
    <div id="pwa-banner" class="pwa-banner" hidden>
      <div class="pwa-inner">
        <div class="pwa-content">
          <svg class="pwa-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <div>
            <p class="pwa-title">Install spike.land</p>
            <p class="pwa-sub">Get instant access from your home screen</p>
          </div>
        </div>
        <div class="pwa-actions">
          <button id="pwa-install" class="pwa-btn-install">Install</button>
          <button id="pwa-dismiss" class="pwa-btn-dismiss" aria-label="Dismiss">&times;</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- PWA Install + tracking script -->
<script is:inline>
(function() {
  let deferredPrompt = null;
  const banner = document.getElementById('pwa-banner');
  const installBtn = document.getElementById('pwa-install');
  const dismissBtn = document.getElementById('pwa-dismiss');

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    if (!localStorage.getItem('pwa-dismissed')) {
      setTimeout(function() {
        banner.hidden = false;
        banner.classList.add('pwa-visible');
      }, 8000);
    }
  });

  if (installBtn) {
    installBtn.addEventListener('click', function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function(result) {
          if (result.outcome === 'accepted') {
            trackEvent('pwa_install', 'accepted');
          }
          deferredPrompt = null;
          banner.hidden = true;
        });
      }
    });
  }

  if (dismissBtn) {
    dismissBtn.addEventListener('click', function() {
      banner.hidden = true;
      localStorage.setItem('pwa-dismissed', '1');
    });
  }

  function trackEvent(event, detail) {
    if (typeof navigator.sendBeacon === 'function') {
      navigator.sendBeacon('/analytics/ingest', JSON.stringify([{
        source: 'frontend',
        eventType: event,
        metadata: {
          path: location.pathname,
          detail: detail,
          ts: Date.now(),
        }
      }]));
    }
  }

  // Track scroll depth
  var maxScroll = 0;
  var scrollTicks = [25, 50, 75, 100];
  window.addEventListener('scroll', function() {
    var pct = Math.round((window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
    if (pct > maxScroll) {
      maxScroll = pct;
      for (var i = 0; i < scrollTicks.length; i++) {
        if (pct >= scrollTicks[i] && maxScroll - pct < 5) {
          trackEvent('scroll_depth', scrollTicks[i] + '%');
          scrollTicks.splice(i, 1);
          break;
        }
      }
    }
  }, { passive: true });

  // Track time on page
  setTimeout(function() { trackEvent('engaged', '30s'); }, 30000);
  setTimeout(function() { trackEvent('engaged', '60s'); }, 60000);

  // iOS PWA hint
  var isIos = /iPad|iPhone|iPod/.test(navigator.userAgent);
  var isStandalone = window.matchMedia('(display-mode: standalone)').matches;
  if (isIos && !isStandalone && !localStorage.getItem('pwa-dismissed')) {
    setTimeout(function() {
      banner.hidden = false;
      banner.classList.add('pwa-visible');
      if (installBtn) {
        installBtn.textContent = 'How to install';
        installBtn.addEventListener('click', function() {
          alert('Tap the Share button in Safari, then "Add to Home Screen"');
        }, { once: true });
      }
    }, 12000);
  }
})();
</script>


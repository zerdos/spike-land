---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Whisper from '../components/typography/Whisper.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { appCatalog } from '../data/apps';
import { PrdFilterDemo } from '../../../../src/core/block-website/ui/PrdFilterDemo';

const features = appCatalog;

const metrics = [
  { value: '80+', label: 'MCP Tools' },
  { value: '1,200+', label: 'Clones' },
  { value: '<1s', label: 'Boot Time' },
  { value: '28', label: 'Packages' },
];

// Fetch latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.draft && !post.data.unlisted)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const featuredPost = latestPosts[0];
const morePosts = latestPosts.slice(1, 4);
---

<Layout
  title="spike.land — Open AI App Store built on MCP"
  description="80+ hosted MCP tools, edge-native runtime on Cloudflare Workers. Build, test, and deploy AI apps in seconds. Open source."
>
  <Analytics slot="head" />
  <link slot="head" rel="manifest" href="/site.webmanifest" />
  <meta slot="head" name="apple-mobile-web-app-capable" content="yes" />
  <meta slot="head" name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta slot="head" name="mobile-web-app-capable" content="yes" />

  <div class="page-shell">
    <Nav activePath="/" />

    <main id="main-content">
      <!-- ── Hero ─────────────────────────────────────────────────────── -->
      <section class="hero-section">
        <div class="rubik-container hero-inner">
          <div class="hero-eyebrow">
            <span class="rubik-chip chip-live">
              <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
              Open beta — free to start
            </span>
          </div>

          <h1 class="hero-title">
            Your old chats are already PRDs.
          </h1>

          <p class="rubik-lede hero-lede">
            11 messages become 5 executable fields. No more lost requirements.
            spike.land extracts what matters from every AI conversation.
          </p>

          <div class="hero-ctas">
            <a href="/chat" class="cta-primary">
              Try Spike Chat
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/apps" class="cta-secondary">
              Browse 80+ Tools
            </a>
          </div>

          <!-- PRD Filter hero image — the centerpiece -->
          <div class="hero-image-wrap">
            <img
              src="/prd-filter-hero.jpg"
              alt="PRD Filter: 11 chat messages distilled into 5 executable requirement fields"
              class="hero-image"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <!-- Social proof -->
          <div class="social-proof">
            <div class="proof-avatars">
              <div class="avatar-stack">
                <span class="avatar" style="--a-bg: #3b82f6">Z</span>
                <span class="avatar" style="--a-bg: #10b981">R</span>
                <span class="avatar" style="--a-bg: #f59e0b">E</span>
              </div>
              <span class="proof-text">1,200+ developers cloned this week</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Metrics strip ───────────────────────────────────────────── -->
      <section class="metrics-strip">
        <div class="rubik-container metrics-inner">
          {metrics.map(m => (
            <div class="metric-item">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── One-command connect ──────────────────────────────────────── -->
      <section class="connect-section">
        <div class="rubik-container connect-inner">
          <p class="rubik-eyebrow">Zero config</p>
          <h2 class="connect-title">Connect in one command</h2>
          <div class="connect-terminal rubik-panel">
            <div class="terminal-dots">
              <span></span><span></span><span></span>
            </div>
            <code class="terminal-cmd">
              <span class="terminal-prompt">$</span>
              claude mcp add spike-land --transport http https://spike.land/mcp
            </code>
          </div>
          <p class="connect-sub">Works with Claude Code, Cursor, VS Code, and any MCP client.</p>
        </div>
      </section>

      <!-- ── PRD Filter Interactive Demo ──────────────────────────────── -->
      <PrdFilterDemo client:visible />

      <!-- ── Free tokens hook ─────────────────────────────────────────── -->
      <section class="hook-section hook-tokens">
        <div class="rubik-container hook-inner">
          <div class="hook-badge">Free forever</div>
          <h2 class="hook-title">You get 1,000 free tokens. Every day.</h2>
          <p class="hook-sub">
            No credit card. No trial expiry. No "contact sales" wall.
            Just open Spike Chat and start building. We pay what the AI costs.
          </p>
          <div class="hook-stats">
            <div class="hook-stat">
              <span class="hook-stat-value">$0</span>
              <span class="hook-stat-label">markup on AI calls</span>
            </div>
            <div class="hook-stat">
              <span class="hook-stat-value">5</span>
              <span class="hook-stat-label">AI providers</span>
            </div>
            <div class="hook-stat">
              <span class="hook-stat-value">0</span>
              <span class="hook-stat-label">features behind paywall</span>
            </div>
          </div>
          <a href="/chat" class="cta-primary">
            Start chatting — it's free
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>

      <!-- ── Meet the personas hook ───────────────────────────────────── -->
      <section class="hook-section hook-personas">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">AI Personas</p>
            <h2 class="section-title">Talk to minds, not chatbots</h2>
          </div>
          <p class="hook-sub" style="text-align:center; margin-bottom: 2rem;">
            Each persona has its own philosophy, voice, and expertise. No login required.
          </p>
          <div class="persona-grid">
            <a href="/arnold" class="persona-card rubik-panel" style="--p-accent: #e11d48">
              <div class="persona-avatar" style="background: #e11d48">A</div>
              <h3 class="persona-name">Arnold</h3>
              <p class="persona-role">UX Provocateur</p>
              <p class="persona-pitch">"Show me what you've got. I'll tell you what it's missing."</p>
            </a>
            <a href="/radix" class="persona-card rubik-panel" style="--p-accent: #0d9488">
              <div class="persona-avatar" style="background: #0d9488">R</div>
              <h3 class="persona-name">Radix</h3>
              <p class="persona-role">Builder & Root-finder</p>
              <p class="persona-pitch">"What is the root of your problem?"</p>
            </a>
            <a href="/zoltan" class="persona-card rubik-panel" style="--p-accent: #d97706">
              <div class="persona-avatar" style="background: #d97706">Z</div>
              <h3 class="persona-name">Zoltan</h3>
              <p class="persona-role">Grounded Mirror</p>
              <p class="persona-pitch">"Not therapy — calibration."</p>
            </a>
            <a href="/erdos" class="persona-card rubik-panel" style="--p-accent: #7c3aed">
              <div class="persona-avatar" style="background: #7c3aed">E</div>
              <h3 class="persona-name">Erdos</h3>
              <p class="persona-role">Elegance Judge</p>
              <p class="persona-pitch">"My brain is open."</p>
            </a>
          </div>
        </div>
      </section>

      <!-- ── Apps grid ───────────────────────────────────────────────── -->
      <section class="apps-section" id="apps">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">Platform Apps</p>
            <h2 class="section-title">Everything you need to ship AI</h2>
          </div>

          <div class="apps-grid">
            {features.map(app => (
              <a href={`/apps/${app.id}`} class="app-card rubik-panel" style={`--app-accent: ${app.accent}; --app-accent-bg: ${app.accentBg};`}>
                <div class="app-icon-wrap">
                  <svg class="app-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.iconPath}></path>
                  </svg>
                </div>
                <h3 class="app-name">{app.name}</h3>
                <p class="app-desc">{app.description}</p>
                <span class="app-link">
                  Open app
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Open source trust hook ───────────────────────────────────── -->
      <section class="hook-section hook-opensource">
        <div class="rubik-container hook-inner">
          <div class="hook-badge">100% open source</div>
          <h2 class="hook-title">Read every line. Fork the whole thing.</h2>
          <p class="hook-sub">
            28 packages. MIT license. No vendor lock-in. The code you see is the code that runs.
            Not "open core" with the good parts hidden — genuinely, fully open.
          </p>
          <div class="hero-ctas" style="justify-content: center;">
            <a href="https://github.com/spike-land-ai/spike.land" class="cta-secondary" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 4.238 9.617 9.634 10.828.576.106.788-.25.788-.556 0-.273-.01-1.185-.015-2.171-4.037.876-4.889-1.731-4.889-1.731-.66-1.676-1.61-2.122-1.61-2.122-1.318-.9.1-.882.1-.882 1.457.102 2.224 1.496 2.224 1.496 1.296 2.218 3.39 1.577 4.216 1.206.13-.938.533-1.577.976-1.94-3.221-.366-6.608-1.61-6.608-7.17 0-1.583.565-2.877 1.492-3.892-.15-.366-.647-1.84.142-3.838 0 0 1.217-.422 3.992 1.486 1.157-.322 2.397-.483 3.633-.488 1.235.005 2.476.166 3.635.488 2.772-1.908 3.987-1.486 3.987-1.486.791 1.998.294 3.472.144 3.838.929 1.015 1.49 2.309 1.49 3.892 0 5.574-3.393 6.801-6.624 7.16.524.452.991 1.344.991 2.709 0 1.957-.014 3.532-.014 4.012 0 .31.209.669.799.554 5.393-1.213 9.629-5.526 9.629-10.828 0-6.627-5.373-12-12-12z"/></svg>
              View on GitHub
            </a>
            <a href="/pricing" class="cta-secondary">
              See pricing (spoiler: it's free)
            </a>
          </div>
        </div>
      </section>

      <!-- ── Blog: Latest Intelligence ────────────────────────────────── -->
      <section class="blog-section">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">Latest Intelligence</p>
            <h2 class="section-title">From the engineering log</h2>
          </div>

          {featuredPost && (
            <a href={`/blog/${featuredPost.id}`} class="featured-post rubik-panel">
              {featuredPost.data.heroImage && (
                <div class="fp-image-wrap">
                  <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="fp-image" loading="lazy" />
                </div>
              )}
              <div class="fp-content">
                <div class="fp-meta">
                  <time datetime={featuredPost.data.date.toISOString()}>
                    {featuredPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </time>
                  {featuredPost.data.category && <span class="rubik-chip">{featuredPost.data.category}</span>}
                </div>
                <h3 class="fp-title">{featuredPost.data.title}</h3>
                {featuredPost.data.primer && <p class="fp-primer">{featuredPost.data.primer}</p>}
                {featuredPost.data.description && <p class="fp-desc">{featuredPost.data.description}</p>}
                <span class="read-link">Read article <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </a>
          )}

          <div class="blog-grid">
            {morePosts.map(post => (
              <a href={`/blog/${post.id}`} class="blog-card rubik-panel">
                {post.data.heroImage && (
                  <div class="bc-image-wrap">
                    <img src={post.data.heroImage} alt={post.data.title} class="bc-image" loading="lazy" />
                  </div>
                )}
                <div class="bc-content">
                  <div class="fp-meta">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                    {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
                  </div>
                  <h3 class="bc-title">{post.data.title}</h3>
                  {post.data.primer && <p class="bc-primer">{post.data.primer}</p>}
                </div>
              </a>
            ))}
          </div>

          <div class="blog-cta">
            <a href="/blog" class="cta-secondary">
              View all articles
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ── CTA band ────────────────────────────────────────────────── -->
      <section class="cta-band">
        <div class="rubik-container cta-band-inner">
          <div class="cta-band-content">
            <h2 class="cta-band-title">Ready to build?</h2>
            <p class="rubik-lede cta-band-lede">
              One command. 80+ tools. Ship today.
            </p>
          </div>
          <div class="cta-band-actions">
            <a href="/chat" class="cta-primary">
              Open Spike Chat
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="https://github.com/spike-land-ai/spike.land" class="cta-secondary" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 4.238 9.617 9.634 10.828.576.106.788-.25.788-.556 0-.273-.01-1.185-.015-2.171-4.037.876-4.889-1.731-4.889-1.731-.66-1.676-1.61-2.122-1.61-2.122-1.318-.9.1-.882.1-.882 1.457.102 2.224 1.496 2.224 1.496 1.296 2.218 3.39 1.577 4.216 1.206.13-.938.533-1.577.976-1.94-3.221-.366-6.608-1.61-6.608-7.17 0-1.583.565-2.877 1.492-3.892-.15-.366-.647-1.84.142-3.838 0 0 1.217-.422 3.992 1.486 1.157-.322 2.397-.483 3.633-.488 1.235.005 2.476.166 3.635.488 2.772-1.908 3.987-1.486 3.987-1.486.791 1.998.294 3.472.144 3.838.929 1.015 1.49 2.309 1.49 3.892 0 5.574-3.393 6.801-6.624 7.16.524.452.991 1.344.991 2.709 0 1.957-.014 3.532-.014 4.012 0 .31.209.669.799.554 5.393-1.213 9.629-5.526 9.629-10.828 0-6.627-5.373-12-12-12z"/></svg>
              Star on GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <CookieConsent />

    <!-- PWA Install Banner -->
    <div id="pwa-banner" class="pwa-banner" hidden>
      <div class="pwa-inner">
        <div class="pwa-content">
          <svg class="pwa-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <div>
            <p class="pwa-title">Install spike.land</p>
            <p class="pwa-sub">Get instant access from your home screen</p>
          </div>
        </div>
        <div class="pwa-actions">
          <button id="pwa-install" class="pwa-btn-install">Install</button>
          <button id="pwa-dismiss" class="pwa-btn-dismiss" aria-label="Dismiss">&times;</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- PWA Install + A/B tracking script -->
<script is:inline>
(function() {
  // ── PWA Install Prompt ──
  let deferredPrompt = null;
  const banner = document.getElementById('pwa-banner');
  const installBtn = document.getElementById('pwa-install');
  const dismissBtn = document.getElementById('pwa-dismiss');

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    if (!localStorage.getItem('pwa-dismissed')) {
      setTimeout(function() {
        banner.hidden = false;
        banner.classList.add('pwa-visible');
      }, 8000);
    }
  });

  if (installBtn) {
    installBtn.addEventListener('click', function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function(result) {
          if (result.outcome === 'accepted') {
            trackEvent('pwa_install', 'accepted');
          }
          deferredPrompt = null;
          banner.hidden = true;
        });
      }
    });
  }

  if (dismissBtn) {
    dismissBtn.addEventListener('click', function() {
      banner.hidden = true;
      localStorage.setItem('pwa-dismissed', '1');
    });
  }

  // ── Lightweight A/B experiment tracking ──
  function getVariant(experimentId) {
    var key = 'ab_' + experimentId;
    var stored = localStorage.getItem(key);
    if (stored) return stored;
    var variant = Math.random() < 0.5 ? 'a' : 'b';
    localStorage.setItem(key, variant);
    return variant;
  }

  function trackEvent(event, detail) {
    if (typeof navigator.sendBeacon === 'function') {
      navigator.sendBeacon('/api/analytics/pageview', JSON.stringify({
        path: location.pathname,
        event: event,
        detail: detail,
        ts: Date.now(),
      }));
    }
  }

  // Track scroll depth for engagement
  var maxScroll = 0;
  var scrollTicks = [25, 50, 75, 100];
  window.addEventListener('scroll', function() {
    var pct = Math.round((window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
    if (pct > maxScroll) {
      maxScroll = pct;
      for (var i = 0; i < scrollTicks.length; i++) {
        if (pct >= scrollTicks[i] && maxScroll - pct < 5) {
          trackEvent('scroll_depth', scrollTicks[i] + '%');
          scrollTicks.splice(i, 1);
          break;
        }
      }
    }
  }, { passive: true });

  // Track time on page
  setTimeout(function() { trackEvent('engaged', '30s'); }, 30000);
  setTimeout(function() { trackEvent('engaged', '60s'); }, 60000);

  // iOS PWA hint (no beforeinstallprompt)
  var isIos = /iPad|iPhone|iPod/.test(navigator.userAgent);
  var isStandalone = window.matchMedia('(display-mode: standalone)').matches;
  if (isIos && !isStandalone && !localStorage.getItem('pwa-dismissed')) {
    setTimeout(function() {
      banner.hidden = false;
      banner.classList.add('pwa-visible');
      if (installBtn) {
        installBtn.textContent = 'How to install';
        installBtn.addEventListener('click', function() {
          alert('Tap the Share button in Safari, then "Add to Home Screen"');
        }, { once: true });
      }
    }, 12000);
  }
})();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */
  .hero-section {
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 4vw, 3rem);
    background: radial-gradient(ellipse 80% 50% at 50% -10%, color-mix(in srgb, var(--primary-color) 12%, transparent), transparent);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-eyebrow { display: flex; justify-content: center; }

  .chip-live { color: var(--primary-color); border-color: color-mix(in srgb, var(--primary-color) 30%, transparent); }
  .chip-live svg { color: #22c55e; }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900;
    letter-spacing: -0.04em; line-height: 1.1;
    max-width: 100%; overflow-wrap: break-word;
  }
  .hero-lede { margin-inline: auto; max-width: 44ch; }

  .hero-image-wrap {
    margin-top: 0.5rem; width: 100%; max-width: 56rem;
    border-radius: var(--radius-xl, 1rem);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.06);
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1), box-shadow 0.5s ease;
  }
  .hero-image-wrap:hover {
    transform: translateY(-4px) scale(1.005);
    box-shadow: 0 28px 80px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.1);
  }
  .hero-image {
    width: 100%; height: auto; display: block;
  }

  .hero-ctas {
    display: flex; gap: 0.875rem; flex-wrap: wrap; justify-content: center; padding-top: 0.25rem;
  }

  .social-proof { margin-top: 0.5rem; }

  .proof-avatars {
    display: flex; align-items: center; gap: 0.75rem;
  }

  .avatar-stack { display: flex; }

  .avatar {
    width: 1.75rem; height: 1.75rem; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; font-weight: 700; color: white;
    background: var(--a-bg); border: 2px solid var(--bg);
    margin-left: -0.375rem;
  }
  .avatar:first-child { margin-left: 0; }

  .proof-text {
    font-size: 0.8125rem; color: var(--muted-fg); font-weight: 500;
  }

  /* ── CTAs ──────────────────────────────────────────────────────────── */
  .cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; background: var(--primary-color);
    color: var(--primary-fg); border-radius: var(--radius-lg);
    font-weight: 600; font-size: 0.9375rem; text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity var(--duration-fast) var(--ease), transform var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-md);
  }
  .cta-primary:hover { opacity: 0.88; transform: translateY(-1px); }

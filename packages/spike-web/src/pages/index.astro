---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
const metrics = [
  { value: '80+', label: 'MCP Tools' },
  { value: '26', label: 'AI Personas' },
  { value: '100%', label: 'Open Source' },
  { value: '$0', label: 'To Start' },
];

const personas = [
  { slug: 'zoltan', name: 'Zolt\u00e1n', role: 'The Arena', accent: '#d97706', pitch: 'Music. Math. Code. Human After All.', initial: 'Z' },
  { slug: 'erdos', name: 'Erd\u0151s', role: 'Mathematician', accent: '#4f46e5', pitch: 'My brain is open. Is yours?', initial: 'E' },
  { slug: 'einstein', name: 'Einstein', role: 'Physicist', accent: '#78716c', pitch: 'Imagination is more important than knowledge.', initial: 'A' },
  { slug: 'socrates', name: 'Socrates', role: 'Philosopher', accent: '#a16207', pitch: 'The unexamined life is not worth living.', initial: 'S' },
  { slug: 'buddha', name: 'Buddha', role: 'Teacher', accent: '#ca8a04', pitch: 'Peace comes from within. Do not seek it without.', initial: 'B' },
  { slug: 'camus', name: 'Camus', role: 'Absurdist', accent: '#dc2626', pitch: 'One must imagine Sisyphus happy.', initial: 'C' },
  { slug: 'arnold', name: 'Arnold', role: 'UX Provocateur', accent: '#e11d48', pitch: 'Show me what you\'ve got. I\'ll tell you what it\'s missing.', initial: 'A' },
  { slug: 'peti', name: 'Peti', role: 'QA Engineer', accent: '#22c55e', pitch: 'Does it work on mobile Safari? Test there first.', initial: 'P' },
  { slug: 'diogenes', name: 'Diogenes', role: 'Cynic', accent: '#854d0e', pitch: 'I am looking for an honest man.', initial: 'D' },
  { slug: 'arendt', name: 'Arendt', role: 'Political Thinker', accent: '#57534e', pitch: 'The sad truth is that most evil is done by people who never make up their minds to be good or evil.', initial: 'H' },
  { slug: 'nietzsche', name: 'Nietzsche', role: 'Philosopher', accent: '#9f1239', pitch: 'He who has a why to live can bear almost any how.', initial: 'N' },
  { slug: 'confucius', name: 'Confucius', role: 'Sage', accent: '#b91c1c', pitch: 'It does not matter how slowly you go as long as you do not stop.', initial: 'K' },
];

// Fetch latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.draft && !post.data.unlisted)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 10);

const featuredPost = latestPosts[0];
const morePosts = latestPosts.slice(1, 7);
---

<Layout
  title="spike.land — AI tools that actually work"
  description="80+ MCP tools for code, images, data, and automation. 26 AI personas to think with. Open source. Free to start."
>
  <Analytics slot="head" />
  <link slot="head" rel="manifest" href="/site.webmanifest" />
  <meta slot="head" name="apple-mobile-web-app-capable" content="yes" />
  <meta slot="head" name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta slot="head" name="mobile-web-app-capable" content="yes" />

  <div class="page-shell">
    <Nav activePath="/" />

    <main id="main-content">
      <!-- ── Hero ─────────────────────────────────────────────────────── -->
      <section class="hero-section gradient-mesh">
        <div class="rubik-container hero-inner stagger-in">
          <div class="hero-eyebrow">
            <span class="rubik-chip chip-live">
              <span class="live-dot"></span>
              80+ AI tools, one platform
            </span>
          </div>

          <h1 class="hero-title">
            AI tools that<br class="sm-break" /> actually work.
          </h1>

          <p class="rubik-lede hero-lede">
            80+ MCP tools for code, images, data, and automation.
            26 AI personas to think with. Start free, upgrade when you need more.
          </p>

          <div class="hero-ctas">
            <a href="/apps" class="cta-primary">
              Browse the App Store
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/chat" class="cta-secondary">
              Talk to a persona
            </a>
            <a href="/pricing" class="cta-secondary">
              See pricing
            </a>
          </div>
        </div>
      </section>

      <!-- ── Metrics strip ───────────────────────────────────────────── -->
      <section class="metrics-strip">
        <div class="rubik-container metrics-inner">
          {metrics.map(m => (
            <div class="metric-item">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Blog (first render path — high engagement) ───────────── -->
      <section class="blog-section scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">Writing</p>
            <h2 class="section-title">From the Arena</h2>
          </div>

          {featuredPost && (
            <a href={`/blog/${featuredPost.id}`} class="featured-post rubik-panel">
              {featuredPost.data.heroImage && (
                <div class="fp-image-wrap">
                  <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="fp-image" loading="lazy" />
                </div>
              )}
              <div class="fp-content">
                <div class="fp-meta">
                  <time datetime={featuredPost.data.date.toISOString()}>
                    {featuredPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </time>
                  {featuredPost.data.category && <span class="rubik-chip">{featuredPost.data.category}</span>}
                </div>
                <h3 class="fp-title">{featuredPost.data.title}</h3>
                {featuredPost.data.primer && <p class="fp-primer">{featuredPost.data.primer}</p>}
                {featuredPost.data.description && <p class="fp-desc">{featuredPost.data.description}</p>}
                <span class="read-link">Read article <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </a>
          )}

          <div class="blog-grid">
            {morePosts.map(post => (
              <a href={`/blog/${post.id}`} class="blog-card rubik-panel">
                {post.data.heroImage && (
                  <div class="bc-image-wrap">
                    <img src={post.data.heroImage} alt={post.data.title} class="bc-image" loading="lazy" />
                  </div>
                )}
                <div class="bc-content">
                  <div class="fp-meta">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                    {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
                  </div>
                  <h3 class="bc-title">{post.data.title}</h3>
                  {post.data.primer && <p class="bc-primer">{post.data.primer}</p>}
                </div>
              </a>
            ))}
          </div>

          <div class="blog-cta">
            <a href="/blog" class="cta-secondary">
              View all articles
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ── Meet the personas ──────────────────────────────────────── -->
      <section class="hook-section hook-personas scroll-reveal">
        <div class="rubik-container">
          <div class="section-header">
            <p class="rubik-eyebrow">The Arena</p>
            <h2 class="section-title">Pick a mind. Start talking.</h2>
          </div>
          <p class="hook-sub" style="text-align:center; margin-bottom: 2rem;">
            Mathematicians, philosophers, engineers. Each with their own worldview. Stay curious.
          </p>
          <div class="persona-grid stagger-in">
            {personas.map(p => (
              <a href={`/${p.slug}`} class="persona-card rubik-panel" style={`--p-accent: ${p.accent}`}>
                <div class="persona-avatar" style={`background: ${p.accent}`}>{p.initial}</div>
                <h3 class="persona-name">{p.name}</h3>
                <p class="persona-role">{p.role}</p>
                <p class="persona-pitch">"{p.pitch}"</p>
              </a>
            ))}
          </div>
          <div style="text-align: center; margin-top: 2rem;">
            <a href="/chat" class="cta-secondary">
              See all 26 personas
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ── For developers ──────────────────────────────────────────── -->
      <section class="hook-section hook-opensource">
        <div class="rubik-container hook-inner">
          <div class="hook-badge">For developers</div>
          <h2 class="hook-title">Open source. 30 packages. MIT license.</h2>
          <p class="hook-sub">
            Read every line. Fork the whole thing. The code you see is the code that runs.
          </p>
          <div class="connect-terminal rubik-panel" style="max-width: 44rem; width: 100%;">
            <div class="terminal-dots">
              <span></span><span></span><span></span>
            </div>
            <code class="terminal-cmd">
              <span class="terminal-prompt">$</span>
              claude mcp add spike-land --transport http https://spike.land/mcp
            </code>
          </div>
          <div class="hero-ctas" style="justify-content: center;">
            <a href="https://github.com/spike-land-ai/spike-land" class="cta-secondary" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 4.238 9.617 9.634 10.828.576.106.788-.25.788-.556 0-.273-.01-1.185-.015-2.171-4.037.876-4.889-1.731-4.889-1.731-.66-1.676-1.61-2.122-1.61-2.122-1.318-.9.1-.882.1-.882 1.457.102 2.224 1.496 2.224 1.496 1.296 2.218 3.39 1.577 4.216 1.206.13-.938.533-1.577.976-1.94-3.221-.366-6.608-1.61-6.608-7.17 0-1.583.565-2.877 1.492-3.892-.15-.366-.647-1.84.142-3.838 0 0 1.217-.422 3.992 1.486 1.157-.322 2.397-.483 3.633-.488 1.235.005 2.476.166 3.635.488 2.772-1.908 3.987-1.486 3.987-1.486.791 1.998.294 3.472.144 3.838.929 1.015 1.49 2.309 1.49 3.892 0 5.574-3.393 6.801-6.624 7.16.524.452.991 1.344.991 2.709 0 1.957-.014 3.532-.014 4.012 0 .31.209.669.799.554 5.393-1.213 9.629-5.526 9.629-10.828 0-6.627-5.373-12-12-12z"/></svg>
              View on GitHub
            </a>
            <a href="https://status.spike.land" class="cta-secondary" target="_blank" rel="noopener">
              <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="#22c55e"/></svg>
              7/7 services up
            </a>
          </div>
        </div>
      </section>

      <!-- ── CTA band ────────────────────────────────────────────────── -->
      <section class="cta-band">
        <div class="rubik-container cta-band-inner">
          <div class="cta-band-content">
            <h2 class="cta-band-title">Ready to build?</h2>
            <p class="rubik-lede cta-band-lede">
              80+ tools. 26 personas. Free to start.
            </p>
          </div>
          <div class="cta-band-actions">
            <a href="/apps" class="cta-primary">
              Explore the App Store
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <!-- PWA Install Banner -->
    <div id="pwa-banner" class="pwa-banner" hidden>
      <div class="pwa-inner">
        <div class="pwa-content">
          <svg class="pwa-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <div>
            <p class="pwa-title">Install spike.land</p>
            <p class="pwa-sub">Get instant access from your home screen</p>
          </div>
        </div>
        <div class="pwa-actions">
          <button id="pwa-install" class="pwa-btn-install">Install</button>
          <button id="pwa-dismiss" class="pwa-btn-dismiss" aria-label="Dismiss">&times;</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- GP audio player -->
<script is:inline>
(function() {
  var btn = document.getElementById('gp-play');
  var audio = document.getElementById('gp-audio');
  var iconPlay = btn && btn.querySelector('.gp-icon-play');
  var iconPause = btn && btn.querySelector('.gp-icon-pause');
  if (!btn || !audio) return;

  btn.addEventListener('click', function() {
    if (audio.paused) {
      audio.play();
      btn.classList.add('is-playing');
      iconPlay.style.display = 'none';
      iconPause.style.display = 'block';
    } else {
      audio.pause();
      btn.classList.remove('is-playing');
      iconPlay.style.display = 'block';
      iconPause.style.display = 'none';
    }
  });

  audio.addEventListener('ended', function() {
    btn.classList.remove('is-playing');
    iconPlay.style.display = 'block';
    iconPause.style.display = 'none';
  });
})();
</script>

<!-- PWA Install + A/B tracking script -->
<script is:inline>
(function() {
  // ── PWA Install Prompt ──
  let deferredPrompt = null;
  const banner = document.getElementById('pwa-banner');
  const installBtn = document.getElementById('pwa-install');
  const dismissBtn = document.getElementById('pwa-dismiss');

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    if (!localStorage.getItem('pwa-dismissed')) {
      setTimeout(function() {
        banner.hidden = false;
        banner.classList.add('pwa-visible');
      }, 8000);
    }
  });

  if (installBtn) {
    installBtn.addEventListener('click', function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function(result) {
          if (result.outcome === 'accepted') {
            trackEvent('pwa_install', 'accepted');
          }
          deferredPrompt = null;
          banner.hidden = true;
        });
      }
    });
  }

  if (dismissBtn) {
    dismissBtn.addEventListener('click', function() {
      banner.hidden = true;
      localStorage.setItem('pwa-dismissed', '1');
    });
  }

  // ── Lightweight A/B experiment tracking ──
  function getVariant(experimentId) {
    var key = 'ab_' + experimentId;
    var stored = localStorage.getItem(key);
    if (stored) return stored;
    var variant = Math.random() < 0.5 ? 'a' : 'b';
    localStorage.setItem(key, variant);
    return variant;
  }

  function trackEvent(event, detail) {
    if (typeof navigator.sendBeacon === 'function') {
      navigator.sendBeacon('/api/analytics/ingest', JSON.stringify([{
        source: 'frontend',
        eventType: event,
        metadata: {
          path: location.pathname,
          detail: detail,
          ts: Date.now(),
        }
      }]));
    }
  }

  // Track scroll depth for engagement
  var maxScroll = 0;
  var scrollTicks = [25, 50, 75, 100];
  window.addEventListener('scroll', function() {
    var pct = Math.round((window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
    if (pct > maxScroll) {
      maxScroll = pct;
      for (var i = 0; i < scrollTicks.length; i++) {
        if (pct >= scrollTicks[i] && maxScroll - pct < 5) {
          trackEvent('scroll_depth', scrollTicks[i] + '%');
          scrollTicks.splice(i, 1);
          break;
        }
      }
    }
  }, { passive: true });

  // Track time on page
  setTimeout(function() { trackEvent('engaged', '30s'); }, 30000);
  setTimeout(function() { trackEvent('engaged', '60s'); }, 60000);

  // iOS PWA hint (no beforeinstallprompt)
  var isIos = /iPad|iPhone|iPod/.test(navigator.userAgent);
  var isStandalone = window.matchMedia('(display-mode: standalone)').matches;
  if (isIos && !isStandalone && !localStorage.getItem('pwa-dismissed')) {
    setTimeout(function() {
      banner.hidden = false;
      banner.classList.add('pwa-visible');
      if (installBtn) {
        installBtn.textContent = 'How to install';
        installBtn.addEventListener('click', function() {
          alert('Tap the Share button in Safari, then "Add to Home Screen"');
        }, { once: true });
      }
    }, 12000);
  }
})();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */
  .hero-section {
    padding-block: clamp(4rem, 10vw, 8rem) clamp(2.5rem, 5vw, 4rem);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
  }

  .hero-eyebrow { display: flex; justify-content: center; }

  .chip-live {
    color: var(--primary-color);
    border-color: oklch(from var(--primary-color) l c h / 0.3);
  }
  .live-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-status-live);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  .sm-break { display: none; }
  @media (min-width: 640px) { .sm-break { display: inline; } }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem); font-weight: 900;
    letter-spacing: -0.045em; line-height: 1.05;
    max-width: 100%; overflow-wrap: break-word;
    background: linear-gradient(160deg, var(--fg) 40%, var(--primary-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-lede { margin-inline: auto; max-width: 48ch; }

  .hero-ctas {
    display: flex; gap: 0.875rem; flex-wrap: wrap; justify-content: center; padding-top: 0.5rem;
  }

  /* ── CTAs ──────────────────────────────────────────────────────────── */
  .cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8125rem 1.625rem; background: var(--primary-color);
    color: var(--primary-fg); border-radius: var(--radius-lg);
    font-weight: 600; font-size: 0.9375rem; text-decoration: none;
    letter-spacing: -0.01em;
    transition: transform var(--duration-fast) var(--ease),
                box-shadow var(--duration-fast) var(--ease),
                filter var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-md), 0 0 0 0 oklch(from var(--primary-color) l c h / 0);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), 0 4px 20px -4px oklch(from var(--primary-color) l c h / 0.35);
    filter: brightness(1.08);
  }
  .cta-primary:active { transform: translateY(0); }

  .cta-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; background: var(--card-bg);
    color: var(--fg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); font-weight: 500;
    font-size: 0.9375rem; text-decoration: none;
    transition: background var(--duration-fast) var(--ease),
                border-color var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-sm);
  }
  .cta-secondary:hover {
    background: var(--muted-bg);
    border-color: oklch(from var(--muted-fg) l c h / 0.4);
    transform: translateY(-1px);
  }

  /* ── Metrics strip ─────────────────────────────────────────────────── */
  .metrics-strip {
    border-block: 1px solid var(--border-color);
    background: var(--card-bg); padding-block: 2rem;
  }
  .metrics-inner {
    display: flex; justify-content: center; gap: clamp(2.5rem, 7vw, 6rem); flex-wrap: wrap;
  }
  .metric-item {
    display: flex; flex-direction: column; align-items: center; gap: 0.375rem;
    position: relative;
  }
  .metric-value {
    font-size: clamp(1.875rem, 3.5vw, 2.5rem); font-weight: 900;
    font-family: var(--font-display); letter-spacing: -0.04em;
    color: var(--fg); font-variation-settings: "wght" 900;
  }
  .metric-label {
    font-size: 0.75rem; color: var(--muted-fg); font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  /* ── Connect section ────────────────────────────────────────────── */
  .connect-section {
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .connect-inner {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1.25rem;
  }
  .connect-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; letter-spacing: -0.03em;
  }
  .connect-terminal {
    width: 100%; max-width: 44rem; text-align: left;
    padding: 1rem 1.25rem; font-family: ui-monospace, monospace;
    font-size: 0.875rem; overflow-x: auto;
    position: relative;
  }
  .terminal-dots {
    display: flex; gap: 0.375rem; margin-bottom: 0.75rem;
  }
  .terminal-dots span {
    width: 0.625rem; height: 0.625rem; border-radius: 50%;
    background: var(--border-color);
  }
  .terminal-dots span:nth-child(1) { background: #ef4444aa; }
  .terminal-dots span:nth-child(2) { background: #f59e0baa; }
  .terminal-dots span:nth-child(3) { background: #22c55eaa; }
  .terminal-prompt { color: var(--primary-color); margin-right: 0.5rem; }
  .terminal-cmd { color: var(--fg); word-break: break-all; }
  .connect-sub { font-size: 0.875rem; color: var(--muted-fg); }

  .section-header {
    text-align: center; margin-bottom: 3rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
  }
  .section-title { max-width: 24ch; }

  /* ── Blog section ──────────────────────────────────────────────────── */
  .blog-section {
    padding-block: clamp(4rem, 8vw, 7rem);
    border-top: 1px solid var(--border-color);
    background: var(--primary-glow);
  }

  .featured-post {
    display: grid; grid-template-columns: 1fr 1fr;
    text-decoration: none; color: inherit; overflow: hidden; padding: 0;
    margin-bottom: 2rem;
    transition: box-shadow var(--duration-normal) var(--ease),

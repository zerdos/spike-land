---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';

const plans = [
    {
      id: "free",
      name: "Free",
      price: "$0",
      period: "/forever",
      description: "Get started with 50 credits/day and core MCP tools.",
      features: [
        "50 AI credits/day",
        "Core MCP tools",
        "Spike Chat",
        "CodeSpace editor",
        "Community support"
      ],
      cta: "Start Building",
      highlighted: false,
    },
    {
      id: "pro",
      name: "Pro",
      price: "$29",
      period: "/month",
      annualPrice: "$23",
      annualTotal: "$276",
      dailyPrice: "$0.97",
      description: "For power users who build daily.",
      features: [
        "500 AI credits/day",
        "All 80+ MCP tools",
        "Priority AI queue",
        "Extended context windows",
        "Email support",
        "Analytics dashboard"
      ],
      cta: "Go Pro",
      highlighted: true,
    },
    {
      id: "business",
      name: "Business",
      price: "$99",
      period: "/month",
      annualPrice: "$79",
      annualTotal: "$948",
      dailyPrice: "$3.30",
      description: "For teams shipping AI-powered products.",
      features: [
        "Unlimited AI credits",
        "Everything in Pro",
        "Team management & RBAC",
        "90-day audit logs",
        "Dedicated support"
      ],
      cta: "Go Business",
      highlighted: false,
    },
    {
      id: "enterprise",
      name: "Enterprise",
      price: "Custom",
      period: "",
      description: "For organizations with custom requirements.",
      features: [
        "Everything in Business",
        "Dedicated success manager",
        "Custom integrations",
        "SLA & uptime guarantees",
        "On-premise deployment"
      ],
      cta: "Contact Sales",
      highlighted: false,
    }
];

const faqs = [
  {
    q: "Wait — is it really free? What's the catch?",
    a: "The Free tier gives you 50 credits per day and access to core tools — no credit card required. Pro and Business unlock more credits, all tools, and team features.",
  },
  {
    q: "Why would I pay?",
    a: "Free users get 50 credits/day. Pro gives you 500 credits/day, all 80+ tools, and priority AI processing. Business adds unlimited credits and team management. Most builders upgrade within a week.",
  },
  {
    q: "What payment methods do you accept?",
    a: "All major credit cards and debit cards via Stripe. Secure, PCI-compliant. We never see your card number.",
  },
  {
    q: "Can I cancel anytime?",
    a: "Yes. One click. No retention dark patterns. No 'are you sure?' modals. We're engineers, not used-car salespeople.",
  },
];
---

<Layout
  title="Pricing - spike.land"
  description="Simple, transparent pricing for spike.land. Start for free, upgrade when you need more power."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/pricing" />

    <main>
      <!-- Header -->
      <section class="pricing-header">
        <div class="rubik-container pricing-header-inner">
          <p class="rubik-eyebrow">Pricing</p>
          <span class="beta-badge">Open Beta</span>
          <h1 class="pricing-title">Simple pricing. Start free, scale up.</h1>
          <p class="rubik-lede">Try every tool free. Upgrade for more credits, priority AI, and team features.</p>
        </div>
      </section>

      <!-- Plans grid -->
      <section class="plans-section">
        <div class="rubik-container">
          <p id="pricing-feedback" class="pricing-feedback" role="status" aria-live="polite" hidden></p>
          <div
            class="promo-banner"
            id="promo-banner"
            data-promo-expires="2026-04-30T23:59:59Z"
            hidden
          >
            <span class="promo-icon" aria-hidden="true">🎁</span>
            <span class="promo-copy">
              <strong>Launch offer:</strong> £20 off monthly Pro &amp; Business plans —
              <time datetime="2026-04-30">offer ends April 30</time>.
            </span>
          </div>
          <div class="billing-toggle">
            <button class="toggle-btn active" data-billing="monthly" type="button">Monthly</button>
            <button class="toggle-btn" data-billing="annual" type="button">
              Annual
              <span class="save-badge">Save 20%</span>
            </button>
          </div>
          <div class="plans-grid">
            {plans.map(plan => (
              <div class={`plan-card ${plan.highlighted ? 'plan-card--pro' : ''}`}>
                {plan.highlighted && (
                  <div class="pro-badge">Most Popular</div>
                )}

                <div class="plan-header">
                  <h2 class="plan-name">{plan.name}</h2>
                  <div class="plan-price-row">
                    <span class="plan-price" data-full-monthly={plan.price}>{plan.price}</span>
                    {plan.period && <span class="plan-period">{plan.period}</span>}
                  </div>
                  {(plan.id === 'pro' || plan.id === 'business') && (
                    <p
                      class="plan-promo"
                      data-promo-for="monthly"
                      data-full-price={plan.price}
                      hidden
                    >
                      <span class="plan-promo-strike">{plan.price}</span>
                      <span class="plan-promo-badge">£20 off until Apr 30</span>
                    </p>
                  )}
                  {plan.annualTotal && (
                    <p class="plan-annual-total" data-annual-total={plan.annualTotal} hidden>
                      {plan.annualTotal} billed today · save ~20% vs monthly
                    </p>
                  )}
                  <p class="plan-desc">{plan.description}</p>
                  {plan.dailyPrice && (
                    <p
                      class="plan-daily"
                      data-daily-monthly={`${plan.dailyPrice}/day`}
                      data-daily-annual={plan.id === 'pro' ? '$0.77/day' : '$2.63/day'}
                    >{plan.dailyPrice}/day</p>
                  )}
                </div>

                <ul class="plan-features">
                  {plan.features.map(feature => (
                    <li class="feature-row">
                      <svg class="feature-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                <div class="plan-cta-wrap">
                  {plan.id === 'free' && (
                    <a href="/chat" class={`plan-cta ${plan.highlighted ? 'plan-cta--primary' : 'plan-cta--secondary'}`}>
                      {plan.cta}
                    </a>
                  )}
                  {plan.id === 'pro' && (
                    <button
                      class="plan-cta plan-cta--primary"
                      type="button"
                      data-checkout-tier="pro"
                    >
                      {plan.cta}
                    </button>
                  )}
                  {plan.id === 'business' && (
                    <button
                      class="plan-cta plan-cta--secondary"
                      type="button"
                      data-checkout-tier="business"
                    >
                      {plan.cta}
                    </button>
                  )}
                  {plan.id === 'enterprise' && (
                    <a href="mailto:hello@spike.land?subject=Enterprise%20Plan" class="plan-cta plan-cta--secondary">
                      {plan.cta}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Feature comparison table -->
      <section class="comparison-section">
        <div class="rubik-container">
          <h2 class="comparison-title">Compare features</h2>
          <div class="comparison-table rubik-panel" style="padding: 0; overflow: hidden;">
            <table class="comp-table">
              <thead>
                <tr class="comp-head-row">
                  <th class="comp-feature-col">Feature</th>
                  <th>Free</th>
                  <th>Pro</th>
                  <th>Business</th>
                  <th>Enterprise</th>
                </tr>
              </thead>
              <tbody>
                <tr class="comp-row">
                  <td class="comp-feature">AI Credits/day</td>
                  <td>50</td>
                  <td>500</td>
                  <td>Unlimited</td>
                  <td>Unlimited</td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">MCP Tools</td>
                  <td>Core</td>
                  <td>All 80+</td>
                  <td>All 80+</td>
                  <td>All 80+</td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Priority AI Queue</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Team Management</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Audit Logs</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td>90 days</td>
                  <td>Custom</td>
                </tr>
                <tr class="comp-row comp-row-last">
                  <td class="comp-feature">SLA & Dedicated Support</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="faq-section">
        <div class="rubik-container faq-inner">
          <h2 class="faq-title">Frequently asked</h2>
          <div class="faq-list">
            {faqs.map((faq, i) => (
              <details class="faq-item" name="faq">
                <summary class="faq-q">
                  {faq.q}
                  <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </summary>
                <p class="faq-a">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- BYOK Alternative -->
      <section class="byok-section" id="byok">
        <div class="rubik-container">
          <div class="byok-card glass-card">
            <div class="byok-icon">🔑</div>
            <div class="byok-content">
              <h2 class="byok-title">Already have an API key?</h2>
              <p class="byok-desc">Skip the subscription. Store your own Anthropic, OpenAI, or Google API key and get <strong>Pro features free</strong>. Your key, your costs, zero markup.</p>
              <div class="byok-steps">
                <div class="byok-step">
                  <span class="step-num">1</span>
                  <span>Get an API key from your provider</span>
                </div>
                <div class="byok-step">
                  <span class="step-num">2</span>
                  <span>Store it via <code>byok_store_key</code> MCP tool</span>
                </div>
                <div class="byok-step">
                  <span class="step-num">3</span>
                  <span>All AI calls use your key — no credit limits</span>
                </div>
              </div>
              <a href="/chat" class="byok-cta">Set Up BYOK →</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Enterprise CTA -->
      <section class="enterprise-cta">
        <div class="rubik-container">
          <div class="enterprise-card glass-card">
            <div class="enterprise-content">
              <p class="rubik-eyebrow">Enterprise</p>
              <h2 class="enterprise-title">Built for teams shipping AI products</h2>
              <p class="rubik-lede enterprise-lede">Custom contracts, dedicated infrastructure, and white-glove onboarding for organizations of any size.</p>
              <ul class="enterprise-benefits">
                <li>Unlimited AI credits for your entire team</li>
                <li>RBAC with SSO/SAML integration</li>
                <li>Dedicated success manager and SLA</li>
                <li>Custom MCP tool development</li>
                <li>On-premise deployment option</li>
                <li>90-day audit logs with compliance export</li>
              </ul>
            </div>
            <div class="enterprise-actions">
              <a href="mailto:hello@spike.land?subject=Enterprise%20Plan" class="enterprise-cta-btn">
                Talk to Sales
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/chat" class="enterprise-team-btn">
                Invite Your Team
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* Header */
  .pricing-header {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border-color);
    background: radial-gradient(ellipse 70% 50% at 50% 0%, color-mix(in srgb, var(--primary-color) 8%, transparent), transparent);
  }

  .pricing-header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    align-items: center;
  }

  .pricing-title { max-width: 22ch; }

  /* Plans grid */
  .plans-section {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .pricing-feedback {
    margin: 0 0 1rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--primary-color) 25%, var(--border-color));
    background: color-mix(in srgb, var(--primary-color) 8%, var(--card-bg));
    color: var(--fg);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .plan-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: box-shadow var(--duration-normal) var(--ease);
  }

  .plan-card:hover {
    box-shadow: var(--shadow-md);
  }

  .plan-card--pro {
    border-color: var(--primary-color);
    background: color-mix(in srgb, var(--primary-color) 4%, var(--card-bg));
    box-shadow: 0 0 0 1px var(--primary-color),
                0 0 24px color-mix(in srgb, var(--primary-color) 15%, transparent);
  }

  .plan-card--pro:hover {
    box-shadow: 0 0 0 1px var(--primary-color),
                0 0 40px color-mix(in srgb, var(--primary-color) 22%, transparent),
                var(--shadow-lg);
  }

  .pro-badge {
    position: absolute;
    top: -0.875rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary-color);
    color: var(--primary-fg);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.25rem 0.875rem;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
  }

  .plan-header { display: flex; flex-direction: column; gap: 0.5rem; }

  .plan-name {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .plan-price {
    font-size: 2.25rem;
    font-weight: 900;
    font-family: var(--font-display);
    letter-spacing: -0.04em;
    font-variation-settings: "wght" 900;
  }

  .plan-period {
    font-size: 0.875rem;
    color: var(--muted-fg);
  }

  .plan-desc {
    font-size: 0.875rem;
    color: var(--muted-fg);
    line-height: 1.55;
    margin: 0;
    min-height: 2.5rem;
  }

  .plan-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .feature-row {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .feature-check {
    color: var(--primary-color);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .plan-cta-wrap { margin-top: 0.5rem; }

  .plan-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.6875rem 1rem;
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: opacity var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .plan-cta--primary {
    background: var(--primary-color);
    color: var(--primary-fg);
    box-shadow: var(--shadow-sm);
  }

  .plan-cta--secondary {
    background: var(--fg);
    color: var(--bg);
  }

  .plan-cta:hover { opacity: 0.88; transform: translateY(-1px); }
  .plan-cta:active { transform: translateY(0); }
  .plan-cta:disabled {
    opacity: 0.65;
    cursor: wait;
    transform: none;
  }

  /* Comparison table */
  .comparison-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .comparison-title {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .comp-head-row th {
    padding: 0.875rem 1.25rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--muted-fg);
    background: var(--muted-bg);
    border-bottom: 1px solid var(--border-color);
  }

  .comp-head-row th.comp-feature-col {
    text-align: left;
  }

  .comp-row td {
    padding: 0.75rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
    color: var(--fg);
  }

  .comp-row td.comp-feature {
    text-align: left;
    color: var(--muted-fg);
    font-weight: 500;
  }

  .comp-row-last td { border-bottom: none; }
  .comp-row:hover td { background: var(--muted-bg); }

  .comp-check { color: var(--primary-color); font-size: 1rem; }
  .comp-dash { color: var(--border-color); }

  /* FAQ */
  .faq-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .faq-inner { max-width: 52rem; }

  .faq-title {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .faq-list { display: flex; flex-direction: column; gap: 0; }

  .faq-item {
    border-bottom: 1px solid var(--border-color);
  }

  .faq-item:first-child { border-top: 1px solid var(--border-color); }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.125rem 0;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: var(--fg);
    transition: color var(--duration-fast) var(--ease);
  }

  .faq-q:hover { color: var(--primary-color); }
  .faq-q::-webkit-details-marker { display: none; }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--muted-fg);
    transition: transform var(--duration-normal) var(--ease);
  }

  details[open] .faq-chevron { transform: rotate(180deg); }

  .faq-a {
    padding: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--muted-fg);
    margin: 0;
  }

  /* Enterprise CTA */
  .enterprise-cta {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .enterprise-card {
    padding: clamp(2rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .enterprise-content { display: flex; flex-direction: column; gap: 0.75rem; }
  .enterprise-title { font-size: clamp(1.375rem, 2vw, 1.875rem); margin: 0; }
  .enterprise-lede { margin: 0; }

  .enterprise-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--fg);
    color: var(--bg);
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-md);
  }

  .enterprise-cta-btn:hover { opacity: 0.88; transform: translateY(-1px); }

  .enterprise-benefits {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1.5rem;
  }

  .enterprise-benefits li {
    font-size: 0.875rem;
    color: var(--muted-fg);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .enterprise-benefits li::before {
    content: "✓";
    color: var(--primary-color);
    font-weight: 700;
    flex-shrink: 0;
  }

  .enterprise-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .enterprise-team-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.5rem;
    border: 1px solid var(--border-color);
    color: var(--fg);
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color var(--duration-fast) var(--ease);
  }

  .enterprise-team-btn:hover {
    border-color: var(--primary-color);
  }

  @media (max-width: 640px) {
    .enterprise-benefits { grid-template-columns: 1fr; }
  }

  /* Launch promo */
  .promo-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 auto 1.25rem;
    padding: 0.625rem 1rem;
    max-width: 40rem;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--primary-color) 40%, transparent);
    background: color-mix(in srgb, var(--primary-color) 10%, var(--card-bg));
    color: var(--fg);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .promo-banner[hidden] { display: none; }

  .promo-icon { font-size: 1.125rem; line-height: 1; }

  .promo-copy strong { font-weight: 700; color: var(--primary-color); }

  .plan-promo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.8125rem;
  }

  .plan-promo[hidden] { display: none; }

  .plan-promo-strike {
    color: var(--muted-fg);
    text-decoration: line-through;
    font-weight: 600;
  }

  .plan-promo-badge {
    background: var(--primary-color);
    color: var(--primary-fg);
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .plan-annual-total {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted-fg);
    font-weight: 600;
  }

  .plan-annual-total[hidden] { display: none; }

  /* Billing toggle */
  .billing-toggle {
    display: flex;
    gap: 0;
    margin: 0 auto 2rem;
    width: fit-content;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--muted-bg);
  }

  .toggle-btn {
    padding: 0.5rem 1.25rem;
    border: none;
    background: transparent;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--muted-fg);
    font-family: var(--font-sans);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background var(--duration-fast) var(--ease), color var(--duration-fast) var(--ease);
  }

  .toggle-btn.active {
    background: var(--card-bg);
    color: var(--fg);
    box-shadow: var(--shadow-sm);
  }

  .save-badge {
    font-size: 0.6875rem;
    background: #22c55e;
    color: white;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    font-weight: 700;
  }

  /* Daily price */
  .plan-daily {
    font-size: 0.75rem;
    color: var(--muted-fg);
    margin: 0.125rem 0 0;
    font-weight: 500;
  }

  /* Beta badge */
  .beta-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: linear-gradient(135deg, #8b5cf6, #6366f1);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-top: 0.25rem;
  }

  /* BYOK section */
  .byok-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .byok-card {
    padding: clamp(2rem, 4vw, 3rem);
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .byok-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .byok-content {
    flex: 1;
  }

  .byok-title {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .byok-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--muted-fg);
    margin: 0 0 1.5rem;
  }

  .byok-steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .byok-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
  }

  .step-num {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--primary-color);
    color: var(--primary-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .byok-step code {
    font-size: 0.8125rem;
    background: var(--muted-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
  }

  .byok-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--primary-color);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .byok-cta:hover { opacity: 0.8; }

  @media (max-width: 640px) {
    .byok-card { flex-direction: column; }
  }
</style>

<script>
  const feedback = document.getElementById('pricing-feedback');
  const checkoutButtons = Array.from(document.querySelectorAll('[data-checkout-tier]'));

  function setFeedback(message: string | null) {
    if (!feedback) return;
    if (!message) {
      feedback.hidden = true;
      feedback.textContent = '';
      return;
    }

    feedback.hidden = false;
    feedback.textContent = message;
  }

  // Module-level in-flight flag so a second tap on any pricing tile
  // cannot start another checkout session while the first is still
  // being created or the redirect is pending.
  let checkoutInFlight = false;

  async function startCheckout(button: HTMLButtonElement) {
    if (checkoutInFlight) return;
    const tier = button.dataset.checkoutTier;
    if (!tier) return;

    const activeToggle = document.querySelector<HTMLElement>('.toggle-btn.active');
    const billing = activeToggle?.dataset.billing === 'annual' ? 'annual' : 'monthly';

    const originalLabel = button.textContent?.trim() || 'Continue';
    setFeedback(null);
    checkoutInFlight = true;
    const allCheckoutButtons = document.querySelectorAll<HTMLButtonElement>('[data-checkout-tier]');
    allCheckoutButtons.forEach(b => (b.disabled = true));
    button.textContent = 'Redirecting…';

    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ tier, billing })
      });
      if (res.status === 401) {
        window.location.href = '/login?redirect=/pricing';
        return;
      }

      const data = await res.json().catch(() => null);
      if (res.status === 409 && typeof data?.manage_url === 'string') {
        window.location.href = data.manage_url;
        return;
      }
      if (!res.ok) {
        throw new Error(
          typeof data?.error === 'string' ? data.error : `Unable to start checkout (${res.status})`,
        );
      }

      if (typeof data?.url !== 'string' || data.url.length === 0) {
        throw new Error('No checkout URL returned.');
      }

      // Leave buttons disabled through navigation — if the redirect is
      // cancelled the user can reload to reset.
      window.location.href = data.url;
    } catch (err) {
      console.error('Checkout error:', err);
      setFeedback(
        err instanceof Error ? err.message : 'Unable to start checkout right now. Please try again.',
      );
      // Only re-enable on error. Success paths navigate away.
      checkoutInFlight = false;
      allCheckoutButtons.forEach(b => (b.disabled = false));
      button.textContent = originalLabel;
    }
  }

  checkoutButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener('click', () => {
      void startCheckout(button);
    });
  });

  // Billing toggle
  const toggleBtns = document.querySelectorAll('.toggle-btn');
  const annualPrices: Record<string, string> = { pro: '$23', business: '$79' };
  const monthlyPrices: Record<string, string> = { pro: '$29', business: '$99' };

  // Launch promo: £20 off monthly plans, expires 2026-04-30
  const promoBanner = document.getElementById('promo-banner');
  const promoExpiresAttr = promoBanner?.dataset.promoExpires;
  const promoExpiresAt = promoExpiresAttr ? Date.parse(promoExpiresAttr) : NaN;
  const promoActive = Number.isFinite(promoExpiresAt) && Date.now() <= promoExpiresAt;
  const planPromos = Array.from(document.querySelectorAll<HTMLElement>('.plan-promo'));

  function applyPromoVisibility(isAnnual: boolean) {
    const show = promoActive && !isAnnual;
    if (promoBanner) promoBanner.hidden = !show;
    planPromos.forEach(p => {
      p.hidden = !show;
    });
  }

  const annualTotals = Array.from(document.querySelectorAll<HTMLElement>('.plan-annual-total'));
  function applyAnnualTotals(isAnnual: boolean) {
    annualTotals.forEach(el => {
      el.hidden = !isAnnual;
    });
  }

  applyPromoVisibility(false);
  applyAnnualTotals(false);

  toggleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const billing = (btn as HTMLElement).dataset.billing;
      toggleBtns.forEach(b => b.classList.toggle('active', b === btn));

      const isAnnual = billing === 'annual';

      // Update Pro card
      const proCard = document.querySelector('[data-checkout-tier="pro"]')?.closest('.plan-card');
      if (proCard) {
        const price = proCard.querySelector('.plan-price');
        const period = proCard.querySelector('.plan-period');
        const daily = proCard.querySelector('.plan-daily') as HTMLElement | null;
        if (price) price.textContent = isAnnual ? annualPrices.pro : monthlyPrices.pro;
        if (period) period.textContent = isAnnual ? '/mo (billed annually)' : '/month';
        if (daily) daily.textContent = daily.dataset[isAnnual ? 'dailyAnnual' : 'dailyMonthly'] || '';
      }

      // Update Business card
      const bizCard = document.querySelector('[data-checkout-tier="business"]')?.closest('.plan-card');
      if (bizCard) {
        const price = bizCard.querySelector('.plan-price');
        const period = bizCard.querySelector('.plan-period');
        const daily = bizCard.querySelector('.plan-daily') as HTMLElement | null;
        if (price) price.textContent = isAnnual ? annualPrices.business : monthlyPrices.business;
        if (period) period.textContent = isAnnual ? '/mo (billed annually)' : '/month';
        if (daily) daily.textContent = daily.dataset[isAnnual ? 'dailyAnnual' : 'dailyMonthly'] || '';
      }

      applyPromoVisibility(isAnnual);
      applyAnnualTotals(isAnnual);
    });
  });

</script>

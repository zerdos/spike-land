---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
---

<Layout title="Zoltan Erdos - Curriculum Vitae" description="CV of Zoltan Erdos - Founder, Music Producer, and Engineer.">
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/cv" />

    <main class="flex-1 container mx-auto max-w-4xl py-16 px-4">
      <div class="glass-card p-10 rounded-3xl border border-border">
        
        <!-- Header Section -->
        <header class="border-b border-border pb-8 mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-2">Zoltan Erdos</h1>
            <p class="text-xl text-primary font-medium">Founder, Software Engineer & Music Producer</p>
          </div>
          <div class="text-muted-foreground text-sm flex flex-col gap-1">
            <a href="mailto:hello@spike.land" class="hover:text-primary transition-colors flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              hello@spike.land
            </a>
            <a href="https://spike.land" class="hover:text-primary transition-colors flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              spike.land
            </a>
            <a href="https://github.com/spike-land-ai" class="hover:text-primary transition-colors flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              GitHub
            </a>
          </div>
        </header>

        <!-- Professional Summary -->
        <section class="mb-12">
          <h2 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-4">Professional Summary</h2>
          <p class="text-lg leading-relaxed text-foreground/90">
            Visionary software engineer and entrepreneur specializing in multi-agent AI systems, high-performance edge infrastructure, and creative technology. Founder of <strong>spike.land</strong>, an ecosystem built for deploying autonomous agents and scaling AI-first applications natively on the edge. Deeply passionate about integrating rigorous engineering practices with music production, blending technical excellence with an artistic ethos to create products that feel alive.
          </p>
        </section>

        <!-- Experience Section -->
        <section class="mb-12">
          <h2 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-6">Experience</h2>
          
          <div class="space-y-10">
            <!-- Job 1 -->
            <div class="relative pl-6 border-l-2 border-primary/30">
              <div class="absolute w-3 h-3 bg-primary rounded-full -left-[7px] top-1.5"></div>
              <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-2">
                <h3 class="text-xl font-bold">Founder & Lead Engineer</h3>
                <span class="text-sm font-semibold text-muted-foreground">2024 — Present</span>
              </div>
              <p class="text-primary font-medium mb-3">spike.land</p>
              <ul class="space-y-2 text-muted-foreground list-disc list-inside ml-2">
                <li>Architected and launched a fully autonomous, multi-agent AI platform built on Cloudflare Workers and the Model Context Protocol (MCP).</li>
                <li>Developed the "Arena" framework: a highly scalable system executing background async agents in isolated git worktrees for continuous parallel deployments.</li>
                <li>Created the BAZDMEG QA suite, an automated evaluation pipeline validating complex system interactions 24/7.</li>
                <li>Authored the underlying Edge APIs utilizing D1 databases, Vectorize for Bayesian memory, and WebSockets for real-time human-AI interaction.</li>
              </ul>
            </div>

            <!-- Job 2 -->
            <div class="relative pl-6 border-l-2 border-border">
              <div class="absolute w-3 h-3 bg-muted rounded-full -left-[7px] top-1.5"></div>
              <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-2">
                <h3 class="text-xl font-bold text-foreground/80">Senior Software Engineer & Architect</h3>
                <span class="text-sm font-semibold text-muted-foreground">2018 — 2024</span>
              </div>
              <p class="text-foreground/60 font-medium mb-3">Various High-Growth Tech Companies</p>
              <ul class="space-y-2 text-muted-foreground list-disc list-inside ml-2">
                <li>Spearheaded migrations from monolithic Next.js applications to highly distributed, edge-native micro-frontends (Astro, Solid, Cloudflare Pages).</li>
                <li>Led backend teams in designing complex state machines and synchronization algorithms for real-time distributed platforms.</li>
                <li>Mentored engineering teams in Test-Driven Development (TDD) and Domain-Driven Design (DDD), dramatically reducing technical debt across major production codebases.</li>
              </ul>
            </div>
            
            <!-- Job 3 (Music) -->
            <div class="relative pl-6 border-l-2 border-border">
              <div class="absolute w-3 h-3 bg-muted rounded-full -left-[7px] top-1.5"></div>
              <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-2">
                <h3 class="text-xl font-bold text-foreground/80">Music Producer & Audio Engineer</h3>
                <span class="text-sm font-semibold text-muted-foreground">2015 — Present</span>
              </div>
              <p class="text-foreground/60 font-medium mb-3">Independent</p>
              <ul class="space-y-2 text-muted-foreground list-disc list-inside ml-2">
                <li>Composed, mixed, and mastered expansive electronic and ambient tracks (e.g., <em>Sixty-Nine Mises</em>, <em>Dusk Negroni</em>) distributed exclusively via spike.land records.</li>
                <li>Engineered interactive generative Web Audio API synthesis engines, simulating cinematic orchestral and analog synth hardware directly within the browser.</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Technical Skills Section -->
        <section class="mb-12">
          <h2 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-6">Technical Skills</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-bold mb-3 border-b border-border/50 pb-2">Systems & Architecture</h3>
              <div class="flex flex-wrap gap-2">
                <span class="skill-tag">Cloudflare Workers & D1</span>
                <span class="skill-tag">Model Context Protocol (MCP)</span>
                <span class="skill-tag">Multi-Agent Systems</span>
                <span class="skill-tag">Distributed Edge Compute</span>
                <span class="skill-tag">Vector Databases</span>
                <span class="skill-tag">WebSockets & WebRTC</span>
              </div>
            </div>
            <div>
              <h3 class="font-bold mb-3 border-b border-border/50 pb-2">Languages & Frameworks</h3>
              <div class="flex flex-wrap gap-2">
                <span class="skill-tag">TypeScript & Node.js</span>
                <span class="skill-tag">React & Astro</span>
                <span class="skill-tag">Hono</span>
                <span class="skill-tag">Tailwind CSS (Vanilla bias)</span>
                <span class="skill-tag">Web Audio API</span>
                <span class="skill-tag">PostgreSQL / SQLite</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Philosophy Section -->
        <section class="bg-muted/30 p-8 rounded-2xl border border-border">
          <h2 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-4">Engineering Philosophy</h2>
          <blockquote class="text-lg italic text-foreground/80 border-l-4 border-primary pl-4">
            "A system is only as good as the feedback loop it provides. Build tools that give you immediate insight, deploy fearlessly to the edge, and never sacrifice the artistic pulse of an application for mere utility."
          </blockquote>
        </section>

      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .skill-tag {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent);
    color: var(--fg);
    border: 1px solid color-mix(in srgb, var(--primary-color) 25%, transparent);
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .skill-tag:hover {
    background: var(--primary-color);
    color: var(--primary-fg);
  }
</style>

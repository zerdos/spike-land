---
import RadixChat from '../components/react/radix-chat/RadixChat.tsx';
import TrackPageView from '../components/TrackPageView.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="index, follow" />
    <title>Rubik 3.0 — spike.land</title>
    <meta name="description" content="Rubik 3.0 mega-persona — the full spike.land AI experience in one conversation." />
    <meta name="theme-color" content="#00E5FF" />
    <meta property="og:title" content="Rubik 3.0 — spike.land" />
    <meta property="og:description" content="Rubik 3.0 mega-persona — the full spike.land AI experience in one conversation." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://spike.land/rubik-3" />
    <meta property="og:site_name" content="spike.land" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@spike_land" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; overflow: hidden; -webkit-text-size-adjust: 100%; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    </style>
    <TrackPageView />
  </head>
  <body>
    <RadixChat client:only="react" persona="rubik-3" />
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
---

<Layout
  title="Chess Arena — spike.land"
  description="Play chess against friends or AI. Track your ELO rating, accept challenges, and climb the leaderboard."
  noindex={true}
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav />

    <main id="main-content" class="chess-main">
      <div class="rubik-container">
        <header class="chess-header">
          <h1 class="chess-title">Chess Arena</h1>
          <p class="chess-sub">Play. Compete. Climb the leaderboard.</p>
        </header>

        <!-- Tabs -->
        <div class="tabs" role="tablist">
          <button class="tab tab--active" role="tab" data-tab="play" aria-selected="true">Play</button>
          <button class="tab" role="tab" data-tab="leaderboard" aria-selected="false">Leaderboard</button>
        </div>

        <!-- Play Tab -->
        <section class="tab-panel" id="panel-play" role="tabpanel">
          <div class="board-container">
            <div class="chess-board" id="chess-board"></div>
            <div class="game-controls">
              <p class="board-label">Demo Board</p>
              <p class="board-hint">Click squares to explore. Sign in to play real games.</p>
              <a href="/login" class="play-cta">Sign in to play</a>
            </div>
          </div>
        </section>

        <!-- Leaderboard Tab -->
        <section class="tab-panel" id="panel-leaderboard" role="tabpanel" hidden>
          <div class="leaderboard" id="leaderboard">
            <p class="loading-text">Loading leaderboard…</p>
          </div>
        </section>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </div>
</Layout>

<script is:inline>
(function () {
  'use strict';

  // ── Tab switching ──
  var tabs = document.querySelectorAll('[role="tab"]');
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) {
        t.classList.remove('tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('tab--active');
      tab.setAttribute('aria-selected', 'true');

      document.querySelectorAll('[role="tabpanel"]').forEach(function (p) { p.hidden = true; });
      var panel = document.getElementById('panel-' + tab.getAttribute('data-tab'));
      if (panel) panel.hidden = false;
    });
  });

  // ── Demo chess board ──
  var board = document.getElementById('chess-board');
  var PIECES = {
    'r': '♜', 'n': '♞', 'b': '♝', 'q': '♛', 'k': '♚', 'p': '♟',
    'R': '♖', 'N': '♘', 'B': '♗', 'Q': '♕', 'K': '♔', 'P': '♙',
  };
  var INIT = [
    'rnbqkbnr',
    'pppppppp',
    '........',
    '........',
    '........',
    '........',
    'PPPPPPPP',
    'RNBQKBNR',
  ];

  for (var row = 0; row < 8; row++) {
    for (var col = 0; col < 8; col++) {
      var sq = document.createElement('div');
      sq.className = 'square ' + ((row + col) % 2 === 0 ? 'sq-light' : 'sq-dark');
      var piece = INIT[row][col];
      if (piece !== '.') {
        sq.textContent = PIECES[piece] || '';
        sq.classList.add(piece === piece.toUpperCase() ? 'piece-white' : 'piece-black');
      }
      sq.addEventListener('click', function () {
        document.querySelectorAll('.square.sq-selected').forEach(function (s) { s.classList.remove('sq-selected'); });
        if (this.textContent) this.classList.add('sq-selected');
      });
      board.appendChild(sq);
    }
  }

  // ── Leaderboard ──
  var lb = document.getElementById('leaderboard');
  fetch('https://edge.spike.land/api/chess/players/top?limit=20')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var players = data.players || data || [];
      if (!players.length) {
        lb.innerHTML = '<p class="empty-text">No players yet. Be the first!</p>';
        return;
      }
      lb.innerHTML = '<table class="lb-table"><thead><tr><th>#</th><th>Player</th><th>ELO</th><th>W/L/D</th></tr></thead><tbody>' +
        players.map(function (p, i) {
          return '<tr><td>' + (i + 1) + '</td><td>' + (p.name || p.username || 'Anon') + '</td><td class="elo">' + (p.elo || p.rating || 1200) + '</td><td>' + (p.wins || 0) + '/' + (p.losses || 0) + '/' + (p.draws || 0) + '</td></tr>';
        }).join('') +
      '</tbody></table>';
    })
    .catch(function () {
      lb.innerHTML = '<p class="empty-text">Could not load leaderboard.</p>';
    });
})();
</script>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .chess-main {
    flex: 1;
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .chess-header {
    margin-bottom: 2rem;
  }

  .chess-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0;
  }

  .chess-sub {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    margin: 0.25rem 0 0;
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2rem;
  }

  .tab {
    padding: 0.625rem 1.25rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--muted-fg);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    font-family: var(--font-sans);
  }

  .tab:hover { color: var(--fg); }
  .tab--active { color: var(--fg); border-bottom-color: var(--primary-color); }

  .board-container {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .chess-board {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    width: min(100%, 28rem);
    aspect-ratio: 1;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .square {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(1.25rem, 4vw, 2rem);
    cursor: pointer;
    transition: background 0.1s;
    aspect-ratio: 1;
  }

  .sq-light { background: #f0d9b5; }
  .sq-dark { background: #b58863; }
  .sq-selected { background: #829769 !important; }
  .piece-white { filter: drop-shadow(0 1px 1px rgba(0,0,0,0.3)); }
  .piece-black { filter: drop-shadow(0 1px 1px rgba(0,0,0,0.3)); }

  .game-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .board-label {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0;
  }

  .board-hint {
    font-size: 0.875rem;
    color: var(--muted-fg);
    margin: 0;
    max-width: 20ch;
    line-height: 1.5;
  }

  .play-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    background: var(--fg);
    color: var(--bg);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }

  .play-cta:hover { opacity: 0.88; transform: translateY(-1px); }

  .lb-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .lb-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-fg);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .lb-table td {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--fg);
  }

  .elo { font-weight: 700; font-variant-numeric: tabular-nums; }

  .loading-text, .empty-text {
    color: var(--muted-fg);
    font-size: 0.875rem;
    padding: 2rem 0;
  }

  @media (max-width: 640px) {
    .board-container { flex-direction: column; }
  }
</style>

{
  "private": true,
  "name": "spike-land-ai",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    ".github/packages/*",
    "src-reorganized/*/*/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -Apt run build",
    "build:src": "npx tsx esbuild.config.ts --all",
    "test": "vitest run --config .tests/vitest.config.ts",
    "test:src": "vitest run --config .tests/vitest.config.ts --changed HEAD~1",
    "typecheck": "tsc --noEmit --incremental",
    "typecheck:legacy": "yarn workspaces foreach -Apt run typecheck",
    "lint": "eslint --fix --cache src/ ",
    "lint:legacy": "yarn workspaces foreach -Ap run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "release": "changeset publish",
    "bazdmeg": "npx tsx scripts/bazdmeg.ts",
    "bazdmeg:verbose": "npx tsx scripts/bazdmeg.ts --verbose",
    "COVERAGE:INCREMENTAL": "npx tsx scripts/incremental-coverage.ts",
    "generate:apple-secret": "npx tsx scripts/generate-apple-secret.ts",
    "seed:blog": "npx tsx scripts/seed-blog.ts",
    "seed:blog:remote": "npx tsx scripts/seed-blog.ts --remote",
    "reorganize": "npx tsx scripts/reorganize.ts",
    "test:reorganize": "vitest run --config scripts/__tests__/vitest.config.ts",
    "dev": "bash scripts/dev-local.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "agents": "^0.7.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "rehype-raw": "^7.0.0",
    "yaml": "^2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "2.30.0",
    "@google/genai": "^1.44.0",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "@yarnpkg/esbuild-plugin-pnp": "^3.0.0-rc.15",
    "agent-browser": "^0.16.3",
    "esbuild": "^0.27.3",
    "eslint": "10.0.2",

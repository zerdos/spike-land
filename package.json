{
  "private": true,
  "name": "spike-land-ai",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "src/*",
    "packages/spike.land"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -Apt run build",
    "build:src": "npx tsx esbuild.config.ts --all",
    "test": "yarn workspaces foreach -Ap run test",
    "test:src": "vitest run",
    "typecheck": "tsc --noEmit --incremental",
    "typecheck:legacy": "yarn workspaces foreach -Apt run typecheck",
    "lint": "eslint src/",
    "lint:legacy": "yarn workspaces foreach -Ap run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "rehype-raw": "^7.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "2.30.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "10.0.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18",
    "wrangler": "^4.69.0"
  },
  "resolutions": {
    "eslint": "10.0.2",
    "typescript": "5.9.3",
    "@modelcontextprotocol/sdk": "1.27.1"
  }
}

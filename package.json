{
  "private": true,
  "name": "spike-land-ai",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "src/monaco-editor",
    "vendor/*",
    "vendor/*/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "yarn workspaces foreach -Apt run build",
    "build:src": "node --import tsx esbuild.config.ts --all",
    "test": "vitest run --config .tests/vitest.config.ts",
    "test:pkg": "vitest run --config .tests/vitest.config.ts --project",
    "test:watch": "vitest --config .tests/vitest.config.ts",
    "test:watch:pkg": "vitest --config .tests/vitest.config.ts --project",
    "test:src": "bash scripts/test-changed.sh --base HEAD --head WORKTREE",
    "test:staged": "bash scripts/test-changed.sh --base main --head WORKTREE",
    "typecheck": "tsc --noEmit --incremental",
    "typecheck:tests": "tsc --noEmit --project tsconfig.test.json",
    "typecheck:hardened": "npx tsc --noEmit --project packages/shared/tsconfig.json && npx tsc --noEmit --project packages/mcp-server-base/tsconfig.json && npx tsc --noEmit --project packages/spike-land-mcp/tsconfig.json",
    "typecheck:excluded": "npx tsc --noEmit --project src/frontend/monaco-editor/tsconfig.json && npx tsc --noEmit --project src/media/educational-videos/tsconfig.json",
    "typecheck:all": "yarn typecheck && yarn typecheck:excluded",
    "typecheck:changed": "bash scripts/typecheck-changed.sh --base HEAD --head WORKTREE",
    "typecheck:autofix": "bash scripts/typecheck-autofix.sh",
    "typecheck:legacy": "yarn workspaces foreach -Apt run typecheck",
    "lint": "eslint --fix --cache src/ .tests/",
    "lint:check": "eslint --cache src/ .tests/",
    "lint:changed": "bash scripts/lint-changed.sh --base HEAD --head WORKTREE",
    "lint:changed:fix": "bash scripts/lint-changed.sh --fix --base HEAD --head WORKTREE",
    "lint:legacy": "yarn workspaces foreach -Ap run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "format:changed": "bash scripts/format-changed.sh --base HEAD --head WORKTREE",
    "format:changed:write": "bash scripts/format-changed.sh --write --base HEAD --head WORKTREE",
    "check": "yarn format:changed && yarn lint:changed && yarn typecheck:changed && yarn test:changed",
    "fix": "yarn format:changed:write && yarn lint:changed:fix",
    "changeset": "changeset",
    "release": "changeset publish",
    "bazdmeg": "node --import tsx scripts/bazdmeg.ts",
    "bazdmeg:verbose": "node --import tsx scripts/bazdmeg.ts --verbose",
    "bazdmeg:status": "node --import tsx scripts/bazdmeg.ts status",
    "bazdmeg:dry-run": "node --import tsx scripts/bazdmeg.ts dry-run",
    "pageindex:self-improve": "node --import tsx scripts/pageindex-self-improve-loop.ts",
    "COVERAGE:INCREMENTAL": "node --import tsx scripts/incremental-coverage.ts",
    "generate:apple-secret": "node --import tsx scripts/generate-apple-secret.ts",
    "sentry:setup": "node --import tsx scripts/setup-sentry.ts",
    "seed:apps": "node --import tsx scripts/seed-apps.ts",
    "seed:apps:remote": "node --import tsx scripts/seed-apps.ts --remote",
    "seed:blog": "node --import tsx scripts/seed-blog.ts",
    "seed:blog:remote": "node --import tsx scripts/seed-blog.ts --remote",
    "warm:blog:heroes": "node --import tsx scripts/warm-blog-heroes.ts",
    "reorganize": "node --import tsx scripts/reorganize.ts",
    "reorganize:mcp": "node --import tsx src/mcp-tools/reorganize/mcp/index.ts",
    "test:reorganize": "vitest run --config scripts/__tests__/vitest.config.ts",
    "dev": "bash scripts/dev-local.sh",
    "docker:build": "yarn typecheck && yarn lint && yarn test:src",
    "docker:setup": "bash docker/scripts/setup-certs.sh && bash docker/scripts/setup-dns.sh",
    "docker:dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "qa:docker:build": "node --import tsx scripts/qa-studio-docker.ts build",
    "qa:docker:start": "node --import tsx scripts/qa-studio-docker.ts start",
    "qa:docker:stop": "node --import tsx scripts/qa-studio-docker.ts stop",
    "qa:docker:status": "node --import tsx scripts/qa-studio-docker.ts status",
    "qa:docker:logs": "node --import tsx scripts/qa-studio-docker.ts logs",
    "qa:docker:attach": "node --import tsx scripts/qa-studio-docker.ts attach",
    "review": "bash scripts/gemini-review.sh",
    "agent:claude:plan": "bash scripts/agents/claude-plan.sh",
    "agent:gemini:plan": "bash scripts/agents/gemini-plan.sh",
    "agent:gemini:test-quality": "bash scripts/agents/gemini-test-quality.sh",
    "agent:jules:new": "bash scripts/agents/jules-new.sh",
    "agent:jules:repos": "jules remote list --repo",
    "agent:jules:sessions": "jules remote list --session",
    "agent:status": "node --import tsx scripts/agents/orchestrate.ts status",
    "agent:triage:outage": "node --import tsx scripts/agents/orchestrate.ts triage-outage --url https://spike.land",
    "agent:orchestrate": "node --import tsx scripts/agents/orchestrate.ts",
    "test:changed": "bash scripts/test-changed.sh",
    "test:changed:ci": "bash scripts/test-changed.sh --base origin/main",
    "test:docker": "bash scripts/docker-test.sh",
    "test:docker:all": "bash scripts/docker-test.sh --all",
    "test:docker:ci": "bash scripts/docker-test.sh --base origin/main",
    "dev:edge": "cd packages/spike-edge && npx wrangler dev --port 8787 --inspector-port 9230",
    "dev:mcp": "cd packages/spike-land-mcp && npx wrangler dev --port 8790 --inspector-port 9231",
    "dev:auth": "cd packages/mcp-auth && npx wrangler dev --port 8791 --inspector-port 9232",
    "tunnel:setup": "cloudflared tunnel create spike-land-dev && cloudflared tunnel route dns spike-land-dev local.spike.land && cloudflared tunnel route dns spike-land-dev local-mcp.spike.land && cloudflared tunnel route dns spike-land-dev local-auth.spike.land",
    "tunnel:start": "cloudflared tunnel --config tunnel.yml run",
    "dev:full": "bash scripts/dev-full.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-tabs": "workspace:*",
    "@remotion/cli": "workspace:*",
    "@remotion/transitions": "workspace:*",
    "@tailwindcss/browser": "workspace:*",
    "@tanstack/react-query": "workspace:*",
    "@tanstack/react-router": "workspace:*",
    "@tanstack/router-cli": "workspace:*",
    "framer-motion": "workspace:*",
    "i18next": "workspace:*",
    "i18next-browser-languagedetector": "workspace:*",
    "lucide-react": "workspace:*",
    "react": "workspace:*",
    "react-dom": "workspace:*",
    "react-i18next": "workspace:*",
    "react-markdown": "workspace:*",
    "remotion": "workspace:*",
    "shiki": "workspace:*",
    "tailwind-merge": "workspace:*",
    "yaml": "workspace:*",
    "zod": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@spike-land-ai/mcp-server-base": "workspace:*",
    "@spike-land-ai/shared": "workspace:*",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
